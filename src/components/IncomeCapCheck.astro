---
// Next-Best-Action income-cap self-check (PEO #13).
//
// Routes visitors by *intent* instead of pushing every visitor at the buy
// button:
//   - income at/below the cap -> "you may not need a QIT yet" (researcher
//     path; explicitly tells them NOT to buy and links the explainer). Honest,
//     and it captures the top-of-funnel cohort the single buy-path drops.
//   - income above the cap    -> "a Miller Trust is the standard fix" and nudge
//     to the state guides.
//   - not sure / no JS        -> the form degrades to a labeled control set and
//     a link to the explainer; nothing is gated behind script.
//
// 2026 figures (annual update with the rest of the site each January — 300% of
// the Federal Benefit Rate).
const CAP_SINGLE_2026 = 2982;
const CAP_COUPLE_2026 = 5964;
const fmt = (n: number) => n.toLocaleString('en-US');
---

<section
  class="mx-auto my-10 max-w-3xl px-4"
  aria-labelledby="capcheck-heading"
>
  <div class="rounded-xl border border-primary/20 bg-primary-tint/20 p-5 md:p-6">
    <p class="text-xs font-semibold uppercase tracking-wider text-primary">60-second check</p>
    <h2 id="capcheck-heading" class="!mt-1 !text-xl md:!text-2xl">
      Do you even need a Miller Trust?
    </h2>
    <p class="mt-2 text-sm text-ink-muted">
      A Qualified Income Trust only matters if the applicant's monthly income is over the 2026
      long-term-care Medicaid cap (<strong>${fmt(CAP_SINGLE_2026)}</strong> single,
      <strong>${fmt(CAP_COUPLE_2026)}</strong> couple). Check before you buy anything.
    </p>

    <form id="capcheck-form" class="mt-4 grid gap-4 sm:grid-cols-[auto,1fr,auto] sm:items-end" novalidate>
      <fieldset class="min-w-0">
        <legend class="text-sm font-medium text-ink">Who is applying?</legend>
        <div class="mt-1 flex gap-3 text-sm">
          <label class="inline-flex items-center gap-1.5">
            <input type="radio" name="household" value="single" checked /> One person
          </label>
          <label class="inline-flex items-center gap-1.5">
            <input type="radio" name="household" value="couple" /> A couple
          </label>
        </div>
      </fieldset>

      <div class="min-w-0">
        <label for="capcheck-income" class="text-sm font-medium text-ink">
          Gross monthly income (Social Security + pension + everything)
        </label>
        <div class="mt-1 flex items-center gap-2">
          <span aria-hidden="true" class="text-ink-muted">$</span>
          <input
            id="capcheck-income"
            name="income"
            type="number"
            inputmode="numeric"
            min="0"
            step="1"
            placeholder="3,200"
            class="w-full rounded-md border border-border-strong px-3 py-2"
          />
        </div>
      </div>

      <button
        type="submit"
        class="rounded-md bg-primary px-4 py-2 font-semibold text-white hover:bg-primary-dark"
      >
        Check
      </button>
    </form>

    <div
      id="capcheck-result"
      role="status"
      aria-live="polite"
      class="mt-4 hidden rounded-lg border p-4 text-sm leading-relaxed"
    >
    </div>

    <p class="mt-3 text-xs text-ink-muted">
      Not sure how to total income, or have an unusual situation?
      <a class="underline" href="/states">See the state guides</a> or read
      <a class="underline" href="/about">what we do and don't help with</a>.
      This check is informational, not legal advice.
    </p>
  </div>

  <script is:inline define:vars={{ CAP_SINGLE_2026, CAP_COUPLE_2026 }}>
    (function () {
      var form = document.getElementById('capcheck-form');
      var out = document.getElementById('capcheck-result');
      if (!form || !out) return;
      var fmt = function (n) { return n.toLocaleString('en-US'); };

      function classify(income, cap) {
        var over = income - cap;
        if (income <= 0 || isNaN(income)) {
          return {
            tone: 'border-border bg-bg-elevated text-ink',
            html: 'Enter a gross monthly income above to see whether a Miller Trust applies.',
          };
        }
        if (income <= cap) {
          var margin = cap - income;
          return {
            tone: 'border-emerald-300 bg-emerald-50 text-ink',
            html:
              '<strong>You probably do NOT need a Miller Trust yet.</strong> At $' + fmt(income) +
              '/month you are $' + fmt(margin) + ' under the 2026 cap of $' + fmt(cap) +
              '. Most applicants under the cap qualify without a Qualified Income Trust — don’t buy a kit you don’t need. ' +
              'If income may rise (a pension start, a COLA), re-check then. ' +
              '<a class="underline" href="/about">Learn what we do and don’t help with →</a>',
          };
        }
        return {
          tone: 'border-cta/40 bg-amber-50 text-ink',
          html:
            '<strong>A Miller Trust is the standard fix.</strong> At $' + fmt(income) +
            '/month you are $' + fmt(over) + ' over the 2026 cap of $' + fmt(cap) +
            '. A Qualified Income Trust diverts the excess so the applicant qualifies. ' +
            'Find your state below — every month of delay is another month of private-pay care. ' +
            '<a class="underline" href="/states">Find your state guide →</a>',
        };
      }

      form.addEventListener('submit', function (e) {
        e.preventDefault();
        var data = new FormData(form);
        var household = data.get('household') === 'couple' ? 'couple' : 'single';
        var cap = household === 'couple' ? CAP_COUPLE_2026 : CAP_SINGLE_2026;
        var income = parseInt(String(data.get('income') || '').replace(/[^0-9]/g, ''), 10);
        var r = classify(income, cap);
        out.className = 'mt-4 rounded-lg border p-4 text-sm leading-relaxed ' + r.tone;
        out.innerHTML = r.html;
      });
    })();
  </script>
</section>
