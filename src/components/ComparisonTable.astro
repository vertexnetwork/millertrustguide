---
interface Props {
  stateName: string;
  price: number;
  privatePayMonthlyLow: number;
  privatePayMonthlyHigh: number;
  // Hybrid (HCB-waiver) states buy in-home eligibility, not a nursing-home bed —
  // so the cost anchor + cap label flex. Defaults to the income-cap/nursing model.
  hcb?: boolean;
  // 'requirements-brief' states publish no fill-in QIT form — there is no "Free
  // state PDF" alternative to compare against, and an attorney is the drafting
  // path either way. The table's whole shape flexes: "this kit" is the guide
  // PLUS a (cheaper, faster) attorney engagement, not a full substitute for one.
  reqBrief?: boolean;
}

const { stateName, price, privatePayMonthlyLow, privatePayMonthlyHigh, hcb = false, reqBrief = false } = Astro.props;

const fmt = (n: number) => n.toLocaleString('en-US');
// State-specific private-pay range, kept in sync with the state page + kit so
// the figure can never contradict them.
const privatePayRange = `$${fmt(privatePayMonthlyLow)}–$${fmt(privatePayMonthlyHigh)}`;
---

<section aria-labelledby="comparison-heading" class="my-12">
  <h2 id="comparison-heading">How this compares</h2>
  {reqBrief ? (
    <p class="mt-2 text-ink">
      {stateName} doesn't publish a fill-in QIT form, so an attorney drafts the trust either way. The ${price}{' '}
      is for the guide — the requirements checklist and everything around it — that turns the attorney's job into
      drafting alone, instead of research-and-drafting on your bill.
    </p>
  ) : (
    <p class="mt-2 text-ink">
      {/* T10 — two-number honesty: name the free .gov form outright and tie it to the
          "Free state PDF" column, so the ${price} reads as the playbook around the form. */}
      Yes — {stateName}'s own QIT form is free (that's the <strong>Free state PDF</strong> column below). The ${price}{' '}
      is for everything the free PDF leaves you to work out alone: the bank step, the funding-month timing, and the
      denial traps.
    </p>
  )}
  <div class="overflow-x-auto">
    <table class="mt-4 w-full border-collapse text-left text-sm md:text-base">
      <thead>
        <tr class="border-b border-border-strong text-ink-heading">
          <th class="py-3 pr-4 font-semibold"></th>
          <th class="py-3 pr-4 font-semibold">This kit</th>
          <th class="py-3 pr-4 font-semibold">{reqBrief ? 'Attorney alone (no prep)' : 'Elder-law attorney'}</th>
          <th class="py-3 pr-4 font-semibold">{reqBrief ? 'DIY research, no guide' : 'Free state PDF'}</th>
          <th class="py-3 pr-4 font-semibold">Doing nothing</th>
        </tr>
      </thead>
      {reqBrief ? (
        <tbody class="divide-y divide-border">
          <tr>
            <th scope="row" class="py-3 pr-4 font-medium">Cost</th>
            <td class="py-3 pr-4">${price} + attorney's drafting fee</td>
            <td class="py-3 pr-4">$1,000–2,500 (research + drafting)</td>
            <td class="py-3 pr-4">$0 upfront — real risk of a rejected trust</td>
            <td class="py-3 pr-4">$0, then {privatePayRange}/mo private-pay</td>
          </tr>
          <tr>
            <th scope="row" class="py-3 pr-4 font-medium">Time to qualified</th>
            <td class="py-3 pr-4">Faster — drafting only</td>
            <td class="py-3 pr-4">2–6 weeks (research + drafting)</td>
            <td class="py-3 pr-4">Unpredictable</td>
            <td class="py-3 pr-4">Not until you act</td>
          </tr>
          <tr>
            <th scope="row" class="py-3 pr-4 font-medium">Bank-refusal script</th>
            <td class="py-3 pr-4">Yes</td>
            <td class="py-3 pr-4">Sometimes</td>
            <td class="py-3 pr-4">No</td>
            <td class="py-3 pr-4">n/a</td>
          </tr>
          <tr>
            <th scope="row" class="py-3 pr-4 font-medium">State agency citations</th>
            <td class="py-3 pr-4">Yes</td>
            <td class="py-3 pr-4">n/a</td>
            <td class="py-3 pr-4">If you find them yourself</td>
            <td class="py-3 pr-4">n/a</td>
          </tr>
          <tr>
            <th scope="row" class="py-3 pr-4 font-medium">Updated for the current income cap</th>
            <td class="py-3 pr-4">Yes</td>
            <td class="py-3 pr-4">Yes</td>
            <td class="py-3 pr-4">If you catch the update</td>
            <td class="py-3 pr-4">n/a</td>
          </tr>
          <tr>
            <th scope="row" class="py-3 pr-4 font-medium">"What to say to family" script</th>
            <td class="py-3 pr-4">Yes</td>
            <td class="py-3 pr-4">No</td>
            <td class="py-3 pr-4">No</td>
            <td class="py-3 pr-4">n/a</td>
          </tr>
          <tr>
            <th scope="row" class="py-3 pr-4 font-medium">Delivery time</th>
            <td class="py-3 pr-4">Instant (guide); attorney schedules separately</td>
            <td class="py-3 pr-4">After consult + retainer</td>
            <td class="py-3 pr-4">Instant, but unverified</td>
            <td class="py-3 pr-4">n/a</td>
          </tr>
        </tbody>
      ) : (
        <tbody class="divide-y divide-border">
          <tr>
            <th scope="row" class="py-3 pr-4 font-medium">Cost</th>
            <td class="py-3 pr-4">${price}</td>
            <td class="py-3 pr-4">$1,000–2,500</td>
            <td class="py-3 pr-4">$0</td>
            <td class="py-3 pr-4">$0, then {privatePayRange}/mo private-pay</td>
          </tr>
          <tr>
            <th scope="row" class="py-3 pr-4 font-medium">Time to qualified</th>
            <td class="py-3 pr-4">Same week</td>
            <td class="py-3 pr-4">2–6 weeks</td>
            <td class="py-3 pr-4">If you can decode it alone</td>
            <td class="py-3 pr-4">Not until you act</td>
          </tr>
          <tr>
            <th scope="row" class="py-3 pr-4 font-medium">Bank-refusal script</th>
            <td class="py-3 pr-4">Yes</td>
            <td class="py-3 pr-4">Sometimes</td>
            <td class="py-3 pr-4">No</td>
            <td class="py-3 pr-4">n/a</td>
          </tr>
          <tr>
            <th scope="row" class="py-3 pr-4 font-medium">State agency citations</th>
            <td class="py-3 pr-4">Yes</td>
            <td class="py-3 pr-4">n/a</td>
            <td class="py-3 pr-4">n/a</td>
            <td class="py-3 pr-4">n/a</td>
          </tr>
          <tr>
            <th scope="row" class="py-3 pr-4 font-medium">Updated for {hcb ? 'the current HCB income maximum' : '2026 income cap'}</th>
            <td class="py-3 pr-4">Yes</td>
            <td class="py-3 pr-4">Yes</td>
            <td class="py-3 pr-4">If {stateName} has updated PDF</td>
            <td class="py-3 pr-4">n/a</td>
          </tr>
          <tr>
            <th scope="row" class="py-3 pr-4 font-medium">"What to say to family" script</th>
            <td class="py-3 pr-4">Yes</td>
            <td class="py-3 pr-4">No</td>
            <td class="py-3 pr-4">No</td>
            <td class="py-3 pr-4">n/a</td>
          </tr>
          <tr>
            <th scope="row" class="py-3 pr-4 font-medium">Delivery time</th>
            <td class="py-3 pr-4">Instant download</td>
            <td class="py-3 pr-4">After consult + retainer</td>
            <td class="py-3 pr-4">Instant</td>
            <td class="py-3 pr-4">n/a</td>
          </tr>
        </tbody>
      )}
    </table>
  </div>
  <p class="mt-3 text-xs text-ink-muted">
    Attorney costs reflect typical {stateName} elder-law retainers for a Miller Trust setup. Private-pay
    {hcb ? ' in-home and assisted-living' : ' nursing-home'} figures reflect recent {stateName} market averages.
  </p>
</section>
