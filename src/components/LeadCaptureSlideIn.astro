---
// Engagement-triggered slide-in — the mobile-friendly answer to "the capture is
// at the bottom and nobody scrolls there." Instead of ambushing on arrival, it
// waits for demonstrated interest (dwell + scroll depth, both of which work on
// mobile where mouseleave exit-intent does not), then offers the same free
// checklist as a small, dismissible corner card.
//
// The "zero nagging" contract (see src/lib/lead-capture.ts):
//   - Shows AT MOST ONCE, ever (localStorage). The budget is CLAIMED the moment
//     it appears — not on dismiss — so ignoring it never brings it back.
//   - Shares that single interruptive-prompt budget with the exit-intent modal:
//     a visitor sees one pop total, never both.
//   - Never shows to a subscriber; closes instantly if any form succeeds.
//   - Won't fire while the bottom anchor form is already on screen (no double-up).
//
// Not a dark pattern: engagement-gated, calm, one clear dismiss, no confirmshame.

interface Props {
  stateSlug: string;
  stateName: string;
  agencyAbbreviation: string;
}

const { stateSlug, stateName, agencyAbbreviation } = Astro.props;
const formId = `lead-slidein-${Math.random().toString(36).slice(2, 8)}`;
---

<div
  id={formId}
  class="lead-slidein fixed inset-x-0 bottom-0 z-50 hidden px-3 pb-3 sm:inset-x-auto sm:bottom-6 sm:right-6 sm:max-w-sm sm:px-0 sm:pb-0"
  role="dialog"
  aria-labelledby={`${formId}-heading`}
  aria-modal="false"
>
  <div class="relative rounded-xl border border-border bg-surface-elevated p-5 shadow-xl">
    <button
      type="button"
      data-dismiss
      class="absolute right-3 top-3 flex h-8 w-8 items-center justify-center rounded-md text-ink-muted hover:bg-primary-tint/40 hover:text-ink focus:outline-none focus:ring-2 focus:ring-primary/30"
      aria-label="Dismiss"
    >
      <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M6 6l12 12M18 6L6 18" stroke-linecap="round" />
      </svg>
    </button>

    <p class="text-xs font-semibold uppercase tracking-wider text-primary">Free checklist</p>
    <h2 id={`${formId}-heading`} class="!mt-1 !mb-1 !text-lg pr-6">
      Take the {stateName} checklist with you
    </h2>
    <p class="!mt-0 text-sm text-ink">
      The {agencyAbbreviation} denial traps on one page — so you can verify before you file. We'll email it now.
    </p>

    <form id={`${formId}-form`} class="mt-4" data-capture="slidein" data-state-slug={stateSlug} novalidate>
      <label class="sr-only" for={`${formId}-email`}>Email address</label>
      <input
        type="email"
        id={`${formId}-email`}
        name="email"
        required
        autocomplete="email"
        inputmode="email"
        placeholder="you@example.com"
        class="w-full rounded-md border border-border-strong bg-surface px-4 py-2.5 text-base text-ink placeholder:text-ink-muted focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/30"
      />
      <button type="submit" class="btn-cta mt-2 w-full">Email it to me</button>
      <p class="mt-2 hidden text-sm" data-feedback role="status" aria-live="polite"></p>
      <p class="mt-2 text-xs text-ink-muted">Email only. No income or family details. Unsubscribe anytime.</p>
    </form>
  </div>
</div>

<style>
  .lead-slidein {
    transform: translateY(1rem);
    opacity: 0;
    transition: transform 260ms ease, opacity 260ms ease;
  }
  .lead-slidein.is-visible {
    transform: translateY(0);
    opacity: 1;
  }
  @media (prefers-reduced-motion: reduce) {
    .lead-slidein { transition: none; }
  }
</style>

<script>
  import {
    wireLeadForm,
    canShowInterruptivePrompt,
    markInterruptivePromptShown,
    SUBSCRIBED_EVENT,
    PROMPT_SHOWN_EVENT,
  } from '~/lib/lead-capture';
  import { trackEvent } from '~/lib/analytics-client';

  const DWELL_MS = 30_000; // 30s of presence before we ever consider showing
  const SCROLL_TRIGGER = 0.55; // must have scrolled ≥55% of the page
  const SCROLL_CEILING = 0.92; // ...but not already at the bottom anchor form

  document.querySelectorAll<HTMLElement>('.lead-slidein').forEach((panel) => {
    const form = panel.querySelector<HTMLFormElement>('form[data-capture="slidein"]');
    if (!form) return;
    wireLeadForm(form, { source: 'slidein' });

    let armed = true;
    let dwellReached = false;
    let rafPending = false;

    const scrollFraction = (): number => {
      const doc = document.documentElement;
      const scrollable = doc.scrollHeight - window.innerHeight;
      return scrollable <= 0 ? 1 : window.scrollY / scrollable;
    };

    const anchorFormInView = (): boolean => {
      const main = document.querySelector('form[data-capture="main"]');
      if (!main) return false;
      const r = main.getBoundingClientRect();
      return r.top < window.innerHeight && r.bottom > 0;
    };

    const disarm = () => {
      armed = false;
      window.removeEventListener('scroll', onScroll);
      clearTimeout(dwellTimer);
    };

    const show = () => {
      disarm();
      markInterruptivePromptShown(); // claim the budget on SHOW, not dismiss
      panel.classList.remove('hidden');
      // next frame so the transition runs from the hidden->visible state
      requestAnimationFrame(() => panel.classList.add('is-visible'));
      trackEvent('lead_prompt_view', { source: 'slidein' });
    };

    const hide = () => {
      panel.classList.remove('is-visible');
      window.setTimeout(() => panel.classList.add('hidden'), 280);
    };

    const maybeShow = () => {
      if (!armed) return;
      if (!canShowInterruptivePrompt()) { disarm(); return; }
      if (!dwellReached) return;
      const f = scrollFraction();
      if (f < SCROLL_TRIGGER || f > SCROLL_CEILING) return;
      if (anchorFormInView()) return; // they're already at the anchor form
      show();
    };

    const onScroll = () => {
      if (rafPending) return;
      rafPending = true;
      requestAnimationFrame(() => {
        rafPending = false;
        maybeShow();
      });
    };

    // Don't even arm if the visitor already subscribed or already saw a prompt.
    if (!canShowInterruptivePrompt()) return;

    const dwellTimer = window.setTimeout(() => {
      dwellReached = true;
      maybeShow();
    }, DWELL_MS);

    window.addEventListener('scroll', onScroll, { passive: true });

    panel.querySelector('[data-dismiss]')?.addEventListener('click', hide);
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !panel.classList.contains('hidden')) hide();
    });
    // Any successful subscribe (here or elsewhere) closes it.
    document.addEventListener(SUBSCRIBED_EVENT, hide);
    // If the exit-intent modal fires first, stand down (shared single budget).
    document.addEventListener(PROMPT_SHOWN_EVENT, disarm);
  });
</script>
