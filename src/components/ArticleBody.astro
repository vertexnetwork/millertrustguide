---
// Renders the body of an operational article from state frontmatter. One
// component, three topic variants — all content is derived from already-vetted
// state data, so it stays inside the four hard rules (no drafted trust text, no
// advice, links to the .gov template). The site-wide disclaimer/footer come
// from BaseLayout, so Rule 4 is satisfied without anything here.
import type { StateData } from '~/content/config';
import { getHowToSteps, getArticleFaq, articlePath, type ArticleTopic } from '~/lib/articles';
import { firstSentence } from '~/lib/text';
import { FOUNDER } from '~/config/founder';
import InlineLeadCapture from '~/components/InlineLeadCapture.astro';

interface Props {
  state: StateData;
  topic: ArticleTopic;
}

const { state, topic } = Astro.props;
const fmt = (n: number) => n.toLocaleString('en-US');
// Hybrid (HCB-waiver) states: in-home waiver, excess-only funding, no
// nursing-facility PNA / patient-liability. Flexes the copy below.
const hcb = state.medicaidStructure === 'hybrid';
// 'requirements-brief' states (e.g. Oklahoma) publish no fill-in QIT
// instrument — see KitPdfLayout for the full explanation.
const reqBrief = state.productModel === 'requirements-brief';

const statePath = `/states/${state.slug}`;
const bankPath = articlePath(state.slug, 'what-to-say-at-the-bank');
const howLongPath = articlePath(state.slug, 'how-long-to-set-up');
const howToPath = articlePath(state.slug, 'how-to-set-up');

const steps = topic === 'how-to-set-up' ? getHowToSteps(state) : [];
const faq = getArticleFaq(state, topic);

// Articles render only for live states (see getStaticPaths in the page
// route), so the founder offer is always potentially active here. Mirrors
// the same read of FOUNDER that StatePageLayout uses, for price parity.
const founderActive = FOUNDER.unitsSold < FOUNDER.unitLimit;
const founderSpotsLeft = founderActive ? FOUNDER.unitLimit - FOUNDER.unitsSold : 0;
---

<div class="prose-content">
  {
    topic === 'how-to-set-up' && (
      <>
        <p>
          {reqBrief ? (
            <Fragment>
              {state.name} does not publish a fill-in Miller Trust form, so the trust is drafted — by an attorney,
              or by you where permitted — to meet {state.agencyName}'s own published requirements. Here is the full
              sequence, with the {state.agencyAbbreviation} fact behind each step.
            </Fragment>
          ) : (
            <Fragment>
              Setting up a Miller Trust in {state.name} is an operational task, not a legal one, as long as you use{' '}
              {state.agencyName}'s own published template and do not deviate from it. Here is the full sequence, with the{' '}
              {state.agencyAbbreviation} fact behind each step.
            </Fragment>
          )}
        </p>

        <ol class="not-prose mt-6 space-y-5">
          {steps.map((s, i) => (
            <li class="flex gap-4">
              <span
                aria-hidden="true"
                class="mt-0.5 flex h-8 w-8 flex-none items-center justify-center rounded-full bg-primary text-sm font-bold text-white"
              >
                {i + 1}
              </span>
              <div>
                <p class="font-semibold text-ink-heading">{s.name}</p>
                <p class="mt-1 text-ink">{s.text}</p>
              </div>
            </li>
          ))}
        </ol>

        <div class="mt-6 rounded-lg border border-border bg-surface-elevated p-4 text-sm">
          <p class="!mt-0">
            The two steps families get stuck on are <a href={bankPath}>opening the bank account in {state.name}</a> and
            funding the trust before the calendar month closes — see{' '}
            <a href={howLongPath}>how long setting up a {state.name} Miller Trust takes</a> for the timing rules.
          </p>
        </div>

        {reqBrief ? (
          <Fragment>
            <h2>What your {state.name} trust must contain</h2>
            <p>
              {state.name} does not publish a fill-in Qualified Income Trust form.
              {' '}{state.requirementsIntroNote}
            </p>
          </Fragment>
        ) : (
          <Fragment>
            <h2>Get the official {state.agencyAbbreviation} template</h2>
            <p>
              Download the model Qualified Income Trust instrument directly from {state.agencyName}:{' '}
              <a href={state.officialTemplateUrl} rel="external nofollow">
                {state.agencyAbbreviation} Qualified Income Trust template
              </a>
              . {state.officialTemplateNote}
            </p>
          </Fragment>
        )}
      </>
    )
  }

  {
    topic === 'how-long-to-set-up' && (
      <>
        <h2>The short answer</h2>
        {reqBrief ? (
          <p>
            {state.name} does not publish a fill-in form, so most of the timeline is attorney scheduling and
            drafting, not paperwork — walking in with the requirements checklist already compiled (rather than
            having the attorney research it) is what keeps that part short. What stretches the timeline after that
            is <strong>opening the bank account</strong> and <strong>the calendar-month deadline</strong>. When the
            bank balks, it can take a week or more — which is why knowing{' '}
            <a href={bankPath}>what to say at the bank</a> up front matters.
          </p>
        ) : (
          <p>
            The paperwork is fast — completing {state.agencyName}'s template is usually under an hour, and signing it takes
            minutes. What stretches the timeline is two things: <strong>opening the bank account</strong> and{' '}
            <strong>the calendar-month deadline</strong>. When both go smoothly, families complete a {state.name} Miller
            Trust in a few days. When the bank balks, it can take a week or more — which is why knowing{' '}
            <a href={bankPath}>what to say at the bank</a> up front matters.
          </p>
        )}

        <h2>The one deadline that actually controls eligibility</h2>
        <p>
          A {state.name} Qualified Income Trust only diverts income in a calendar month where it is <em>signed</em>, has a{' '}
          <em>funded</em> bank account, and receives enough of the applicant's income to bring remaining countable income
          below the {state.asOf} cap of <strong>${fmt(state.incomeCap2026)}/month</strong> — all within that same month.
          Per {state.agencyAbbreviation} {state.policyManualSection}, there is no back-dating: coverage begins the month
          you complete funding, not the month you started the paperwork.
        </p>

        <h2>What slows families down</h2>
        <ul>
          <li>
            <strong>The bank.</strong> Most branches have never opened a Qualified Income Trust account and refuse or
            stall on the first request. This is the single biggest source of delay — and it is avoidable.
          </li>
          {state.commonDenialReasons.slice(0, 2).map((d) => (
            <li>
              <strong>{d.title}.</strong> {d.description}
            </li>
          ))}
        </ul>

        <div class="mt-6 rounded-lg border-l-4 border-primary bg-primary-tint/30 p-5">
          {hcb ? (
            <p class="!mt-0">
              <strong>Why the delay is expensive:</strong> {state.name} private-pay in-home and assisted-living care
              runs <strong>${fmt(state.privatePayMonthlyLow)}–${fmt(state.privatePayMonthlyHigh)} a month.</strong>{' '}
              Because the HCB income limit is absolute — no spend-down fallback — and eligibility cannot be back-dated,
              every calendar month you miss is another month your family pays out of pocket. The next step is the{' '}
              <a href={howToPath}>step-by-step setup</a>.
            </p>
          ) : (
            <p class="!mt-0">
              <strong>Why the delay is expensive:</strong> {state.name} private-pay nursing care runs{' '}
              <strong>${fmt(state.privatePayMonthlyLow)}–${fmt(state.privatePayMonthlyHigh)} a month.</strong> Because
              eligibility cannot be back-dated, every calendar month you miss is a five-figure check your family pays out of
              pocket. The next step is the <a href={howToPath}>step-by-step setup</a>.
            </p>
          )}
        </div>
      </>
    )
  }

  {
    topic === 'what-to-say-at-the-bank' && (
      <>
        <h2>Why the bank says no</h2>
        <p>
          Opening a {state.name} Miller Trust account is not legally complicated, but it is unfamiliar to most branch
          staff — they rarely see a Qualified Income Trust, so the default reaction is caution. The fix is almost never
          arguing; it is handing the branch the right {state.agencyAbbreviation} document and asking for the right account
          type. Below are the {state.bankRefusalNotes.length} refusals families hit most often in {state.name} and the
          {state.agencyAbbreviation} rule that resolves each one.
        </p>

        <div class="not-prose mt-6 space-y-4">
          {state.bankRefusalNotes.map((b, i) => (
            <div class="rounded-lg border border-border bg-surface-elevated p-4">
              <p class="text-sm font-semibold uppercase tracking-wide text-primary">Refusal {i + 1}</p>
              <p class="mt-1 font-semibold text-ink-heading">{b.refusalType}</p>
              <p class="mt-2 text-ink">{firstSentence(b.response).lead}</p>
              <p class="mt-2 text-sm text-ink-muted">
                The kit's bank section has the exact wording to say at the counter{b.documentNeeded ? ' and which document to bring' : ''}.
              </p>
            </div>
          ))}
        </div>

        <h2>If the branch still won't open it</h2>
        <p>
          Ask for the bank's trust department, or switch to a community bank or credit union — their account opening
          tends to involve a human review rather than a screen-driven template, so they accommodate unusual account types
          more readily. The account itself is ordinary: a dedicated checking account titled to the trust, opened with the
          beneficiary's Social Security number.
        </p>
      </>
    )
  }

  {
    topic === 'who-can-be-trustee' && (
      <>
        <p>
          The trustee does not have to be an attorney or a professional fiduciary. Managing a Qualified Income
          Trust is an operational job, not a legal one: open the account, move the applicant's income through it
          each month, and pay out only what {state.agencyAbbreviation} allows — the same short list of tasks every
          month.
        </p>

        <h2>What the trustee does each month</h2>
        <ul>
          {hcb ? (
            <>
              <li>
                Moves only the applicant's over-the-limit income — the amount above the HCB maximum — into the
                dedicated trust account each month, keeping the rest in the applicant's own name.
              </li>
              <li>
                Spends the trust only on the applicant's own allowable medical and care costs (and any allowable
                fee). There is no nursing-facility personal-needs allowance and no payment to a facility, because HCB
                care is provided at home.
              </li>
            </>
          ) : (
            <>
              <li>
                Deposits the applicant's income — Social Security, pension, and any other named sources — into the
                dedicated trust account.
              </li>
              <li>
                Pays out only the amounts {state.agencyAbbreviation} permits: typically the applicant's personal-needs
                allowance of <strong>${fmt(state.personalNeedsAllowance)}/month</strong>, any spousal allowance, and the
                applicant's share of medical and care costs.
              </li>
            </>
          )}
          <li>
            Keeps simple records of what went in and what came out, so the trust stays compliant and Medicaid has
            no reason to question it.
          </li>
        </ul>

        <h2>Name a backup trustee</h2>
        <p>
          Many families name a successor trustee when they set the trust up, so that if the first trustee cannot
          continue, the trust keeps running without interruption. Either way the {state.name} setup is the same —
          see the <a href={howToPath}>step-by-step setup</a> and <a href={bankPath}>what to say at the bank</a>.
        </p>
      </>
    )
  }

  {
    topic === 'do-you-need-an-ein' && (
      <>
        {state.einRequired ? (
          <>
            <h2>Getting the EIN — free, from the IRS</h2>
            <p>
              An EIN (Employer Identification Number) costs nothing. Apply directly with the IRS at{' '}
              <a
                href="https://www.irs.gov/businesses/small-businesses-self-employed/get-an-employer-identification-number"
                rel="external nofollow noopener"
              >
                irs.gov
              </a>{' '}
              — the online application issues the number immediately. Never pay a third-party service to "get" an
              EIN for you; the IRS does not charge for one.
            </p>
          </>
        ) : (
          <>
            <h2>Why the bank may still ask for one</h2>
            <p>
              Even though {state.agencyAbbreviation} does not require it, branch staff often ask for an EIN out of
              habit, because most trusts they open need a separate tax ID. If that happens, keep to how the account
              is titled under {state.agencyAbbreviation}'s guidance, and ask for the bank's trust department if the
              first person can't help.
            </p>
          </>
        )}

        <h2>Either way, the account is an ordinary bank account</h2>
        <p>
          Whether or not an EIN is involved, a {state.name} Miller Trust account is a plain dedicated checking
          account titled to the trust — not a special product. What trips families up is rarely the tax ID; it is
          the branch's unfamiliarity with the account type. Knowing the answer before you go keeps the EIN question
          from turning into a wasted trip.
        </p>

        <div class="mt-6 rounded-lg border border-border bg-surface-elevated p-4 text-sm">
          <p class="!mt-0">
            The EIN question almost always surfaces at the counter. See{' '}
            <a href={bankPath}>what to say at the bank in {state.name}</a> for the other refusals families hit, and
            the <a href={howToPath}>full step-by-step setup</a>.
          </p>
        </div>
      </>
    )
  }

  {
    topic === 'what-happens-to-the-money' && (
      <>
        <h2>Why the money doesn't just pass to the family</h2>
        <p>
          A Miller Trust is the mechanism that let the applicant qualify for Medicaid despite income over the{' '}
          {hcb ? 'HCB income maximum' : `${state.asOf} cap`} of <strong>${fmt(state.incomeCap2026)}/month</strong>. In exchange, the trust is set up
          so that whatever remains when the beneficiary dies is first used to reimburse the state for the care
          Medicaid paid for. That is a condition of using the trust, not a penalty.
        </p>

        <h2>Why the trust is irrevocable</h2>
        <p>
          A Qualified Income Trust only works if it is irrevocable: the applicant cannot pull the money back out for
          other purposes, and the trustee can only make the distributions {state.agencyAbbreviation} allows. That is
          what lets the diverted income go uncounted for eligibility.
        </p>

        <h2>What's usually left</h2>
        {hcb ? (
          <p>
            In an HCB waiver trust, only the income above the HCB maximum flows through the trust, and {state.name}
            {' '}lets the trust hold accumulated income to spend on the applicant's care over time — so the balance at
            death varies rather than always sitting near zero. Whatever remains is applied first to the State's
            Medicaid payback.
          </p>
        ) : (
          <p>
            In practice the balance at death is often small. Most of the applicant's income flows into the trust and
            back out again each month to pay the personal-needs allowance and the applicant's share of care — so the
            trust is a pass-through, not a place where money piles up.
          </p>
        )}
      </>
    )
  }

  {/* Passive email capture — the "not ready to buy" bridge. Every spoke gets
      this now (previously only the main state page did), so a reader who
      finishes the operational content but isn't ready to purchase this
      session still gets captured into the nurture sequence instead of
      leaving with nothing. Same component/wiring as the state page. */}
  <InlineLeadCapture stateSlug={state.slug} stateName={state.name} agencyAbbreviation={state.agencyAbbreviation} />

  {
    faq.length > 0 && (
      <section class="mt-10" aria-labelledby="article-faq-heading">
        <h2 id="article-faq-heading">Common questions</h2>
        <dl class="mt-4 space-y-5">
          {faq.map((f) => (
            <div>
              <dt class="faq-question font-semibold text-ink-heading">{f.question}</dt>
              <dd class="faq-answer mt-1 text-ink">{f.answer}</dd>
            </div>
          ))}
        </dl>
      </section>
    )
  }

  {/* CTA back to the purchasable state kit (the buy flow lives there, not
      here). Value-stacked: price anchor against attorney cost, founder
      scarcity (kept live by FounderLive via the data-founder-spots hooks,
      same mechanism the state page uses), and a one-line echo of the
      author's story already told in full on the state page — no new claims. */}
  <aside class="mt-10 rounded-lg border border-primary/30 bg-primary-tint/20 p-6">
    <p class="!mt-0 text-xs font-semibold uppercase tracking-wider text-primary">The {state.name} kit does this for you</p>
    <h2 class="!mt-1 !text-xl">Everything above, plus the parts that actually trip families up</h2>
    <ul class="mt-3 space-y-1.5 text-sm text-ink">
      <li>The verbatim bank-refusal script and a printable resolution letter for the branch manager</li>
      <li>A pre-filled monthly funding worksheet using {state.name}'s {state.asOf} income {hcb ? 'maximum' : 'cap'}</li>
      <li>All {state.commonDenialReasons.length} {state.agencyAbbreviation} denial traps, each with the policy citation</li>
      {reqBrief ? (
        <li>The {state.requiredTrustProvisions.length}-item required-provisions checklist, cited to {state.agencyAbbreviation}'s own policy</li>
      ) : (
        <li>The direct link to the official {state.agencyAbbreviation} template, already built in</li>
      )}
    </ul>
    <p class="mt-3 text-ink">
      {reqBrief ? (
        <Fragment>
          An elder-law attorney typically charges $1,000&ndash;$2,500 to research {state.name}'s requirements
          {' '}<em>and</em> draft the trust; this kit does the research part, so the attorney's fee should reflect
          drafting alone.{' '}
        </Fragment>
      ) : (
        <Fragment>An elder-law attorney typically charges $1,000&ndash;$2,500 for this.{' '}</Fragment>
      )}
      {founderActive ? (
        <>
          The kit is <strong>${FOUNDER.price}</strong> at the founding price &mdash; only{' '}
          <span data-founder-spots>{founderSpotsLeft}</span>{' '}
          <span data-founder-spot-word>{founderSpotsLeft === 1 ? 'spot' : 'spots'}</span> left at this rate, then $
          {state.price}.
        </>
      ) : (
        <>
          The kit is <strong>${state.price}</strong>.
        </>
      )}{' '}
      Instant download. <strong>Informational only — not legal advice.</strong>
    </p>
    <p class="mt-3 text-sm text-ink-muted">
      &mdash; James Whitfield, who built this kit after two attorneys quoted $1,500 and $2,200, and his own bank
      refused the account twice.
    </p>
    <p class="mt-4">
      <a
        href={statePath}
        class="inline-flex items-center rounded-md bg-primary px-5 py-2.5 font-semibold text-white no-underline hover:bg-primary-dark"
      >
        See the {state.name} kit &rarr;
      </a>
    </p>
  </aside>
</div>
