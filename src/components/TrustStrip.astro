---
// Cold-conversion trust strip. Four honest, verifiable signals for a visitor
// arriving from search who has never heard of the publisher and is weighing a
// paid purchase. No badges we haven't earned, no invented numbers — every item
// is literally true of the product (the .gov template link, the per-claim
// citations, Stripe, and the refund guarantee).

interface Props {
  agencyAbbreviation: string;
}

const { agencyAbbreviation } = Astro.props;

const items = [
  `Built on ${agencyAbbreviation}'s own .gov template`,
  `Every claim cited to ${agencyAbbreviation} policy`,
  'Secure checkout by Stripe',
  'Money-back if the trust is rejected',
];
---

<ul
  class="mt-5 flex flex-wrap gap-x-5 gap-y-2 border-y border-border py-3 text-sm text-ink"
  aria-label="What backs this guide"
>
  {
    items.map((item) => (
      <li class="inline-flex items-center gap-1.5">
        <svg aria-hidden="true" viewBox="0 0 24 24" class="h-4 w-4 flex-shrink-0 text-primary" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="M20 6L9 17l-5-5" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
        <span>{item}</span>
      </li>
    ))
  }
</ul>
