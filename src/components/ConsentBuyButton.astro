---
// Rule 4 enforcer. Pairs the consent checkbox with the buy button as one
// island. The checkbox toggles the button's `disabled` attribute via a tiny
// inline script (no React, no framework — just DOM). On click, the script
// POSTs to /api/create-checkout with consent=true; the server validates again
// and refuses to create a Stripe session if consent is missing.

import { randomUUID } from 'node:crypto';

interface Props {
  stateSlug: string;
  price: number;
  buttonLabel?: string;
}

const { stateSlug, price, buttonLabel = `Get the kit — $${price}` } = Astro.props;

// A state page renders this twice (buy panel + repeat CTA). A stable
// `buy-<slug>` formId made BOTH instances share element IDs, so the second
// button's getElementById(consentId) resolved to the FIRST checkbox — the
// bottom checkbox toggled nothing. A per-instance suffix keeps IDs unique.
const uid = randomUUID().slice(0, 8);
const formId = `buy-${stateSlug}-${uid}`;
const consentId = `${formId}-consent`;
const buttonId = `${formId}-button`;
const errorId = `${formId}-error`;
---

<div class="rounded-lg border border-border bg-surface-elevated p-6 shadow-sm" data-consent-widget>
  <label
    for={consentId}
    class="flex cursor-pointer items-start gap-3 text-sm leading-relaxed text-ink"
  >
    <input
      type="checkbox"
      id={consentId}
      name="consent"
      class="mt-1 h-5 w-5 flex-shrink-0 cursor-pointer rounded border-border-strong"
      aria-describedby={`${formId}-consent-text`}
      required
    />
    <span id={`${formId}-consent-text`}>
      I understand this is an informational guide, not legal advice. I will consult a licensed attorney for advice on my
      specific situation. I am purchasing a guide that explains how to use my state's public Medicaid forms.
    </span>
  </label>

  {/*
    The button is intentionally NOT `disabled`: a disabled button fires no
    click event, so a visitor who misses the checkbox taps a dead control and
    gets no feedback (a silent abandon). Instead it stays clickable but looks
    gated (aria-disabled + reduced opacity, managed in the script); clicking
    without consent surfaces guidance and flashes the checkbox.
  */}
  <button
    type="button"
    id={buttonId}
    data-state-slug={stateSlug}
    class="btn-cta btn-consent-gate mt-5 w-full"
    aria-disabled="true"
  >
    {buttonLabel}
  </button>

  <p
    id={errorId}
    data-consent-error
    class="mt-3 hidden text-sm text-error"
    role="alert"
    aria-live="polite"
  ></p>

  <p class="mt-3 text-center text-sm text-ink-muted">
    Secure checkout by Stripe &middot; Instant download &middot; Money-back guarantee
  </p>
</div>

<script>
  import { trackEvent } from '~/lib/analytics-client';
  import { getRef } from '~/lib/referral';

  // Each ConsentBuyButton is a self-contained widget. Scope every lookup to the
  // widget element so the two instances on a state page (buy panel + repeat CTA)
  // wire independently — no globally-unique IDs, no getElementById, no cross-wiring.
  // This is robust even if a stale/mismatched cache serves old markup.
  document.querySelectorAll<HTMLElement>('[data-consent-widget]').forEach((widget) => {
    const button = widget.querySelector<HTMLButtonElement>('button[data-state-slug]');
    const checkbox = widget.querySelector<HTMLInputElement>('input[type="checkbox"][name="consent"]');
    const errorEl = widget.querySelector<HTMLElement>('[data-consent-error]');
    if (!button || !checkbox || !errorEl) return;
    const stateSlug = button.dataset.stateSlug!;

    let submitting = false;

    // Reflect consent state in the button's LOOK only — never the `disabled`
    // property, so the click handler always runs and can give feedback.
    const sync = () => {
      const checked = checkbox.checked;
      button.setAttribute('aria-disabled', String(!checked));
      button.classList.toggle('is-ready', checked); // .btn-consent-gate.is-ready lights it up
      if (checked) errorEl.classList.add('hidden');
    };
    checkbox.addEventListener('change', sync);
    sync();

    button.addEventListener('click', async () => {
      if (submitting) return;

      if (!checkbox.checked) {
        errorEl.textContent =
          'Please check the box above to confirm you understand this is an informational guide, then continue.';
        errorEl.classList.remove('hidden');
        // Draw the eye to the checkbox.
        checkbox.focus();
        const label = checkbox.closest('label');
        label?.classList.add('ring-2', 'ring-primary', 'ring-offset-2', 'rounded-md');
        window.setTimeout(
          () => label?.classList.remove('ring-2', 'ring-primary', 'ring-offset-2', 'rounded-md'),
          1400
        );
        return;
      }

      submitting = true;
      const ref = getRef();
      trackEvent('buy_click', ref ? { state: stateSlug, ref } : { state: stateSlug });
      button.setAttribute('aria-disabled', 'true');
      button.classList.remove('is-ready');
      button.textContent = 'Redirecting to secure checkout…';
      try {
        const res = await fetch('/api/create-checkout', {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify({
            stateSlug,
            consent: true,
            consentTimestamp: new Date().toISOString(),
            ...(ref ? { ref } : {}),
          }),
        });
        if (!res.ok) {
          const text = await res.text();
          throw new Error(text || `Checkout failed (${res.status})`);
        }
        const data = (await res.json()) as { url?: string };
        if (!data.url) throw new Error('No checkout URL returned.');
        trackEvent('checkout_redirect', { state: stateSlug });
        window.location.href = data.url;
      } catch (err) {
        const message =
          err instanceof Error ? err.message : 'Something went wrong. Please try again or email support@millertrustguide.com.';
        errorEl.textContent = message;
        errorEl.classList.remove('hidden');
        submitting = false;
        button.classList.add('is-ready');
        button.setAttribute('aria-disabled', 'false');
        button.textContent = 'Try again';
      }
    });
  });
</script>
