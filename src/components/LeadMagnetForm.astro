---
// Bottom-of-page email capture for the nurture series + the free checklist.
// Rule 2 enforced by design: exactly one field — email. No name, no income,
// no age, no family facts. `stateSlug` is a page-level prop (not user input);
// it only selects the welcome-email copy and the checklist deep-link.
//
// This is the PASSIVE anchor capture. The interruptive surfaces (slide-in,
// exit-intent) and the mid-page inline variant share the same offer and the
// same wiring (src/lib/lead-capture.ts) but layer on trigger/placement logic.
//
// Posts to /api/subscribe; shows inline success/error (with an instant link to
// the checklist) without a page nav.

interface Props {
  stateSlug?: string;
  heading?: string;
  blurb?: string;
  buttonLabel?: string;
}

const {
  stateSlug = '',
  heading = 'Not ready to buy? Get the free denial-trap checklist.',
  blurb = 'One page: the most common reasons Medicaid denies a Miller Trust, each with the state-agency citation behind it — plus a few short, plain-English emails on the funding-month rule, the bank step, and the traps. No sales pressure. Unsubscribe anytime.',
  buttonLabel = 'Email me the checklist',
} = Astro.props;

const formId = `lead-main-${Math.random().toString(36).slice(2, 8)}`;
---

<section
  class="my-12 rounded-lg border border-primary/20 bg-primary-tint/20 p-6"
  aria-labelledby={`${formId}-heading`}
>
  <h2 id={`${formId}-heading`} class="!mt-0 !text-2xl">{heading}</h2>
  <p class="mt-2 text-ink">{blurb}</p>

  <form id={formId} class="mt-5" data-capture="main" data-state-slug={stateSlug} novalidate>
    <div class="flex flex-col gap-3 sm:flex-row">
      <label class="sr-only" for={`${formId}-email`}>Email address</label>
      <input
        type="email"
        id={`${formId}-email`}
        name="email"
        required
        autocomplete="email"
        inputmode="email"
        placeholder="you@example.com"
        class="w-full flex-1 rounded-md border border-border-strong bg-surface-elevated px-4 py-3 text-base text-ink placeholder:text-ink-muted focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/30"
      />
      <button type="submit" class="btn-cta whitespace-nowrap">
        {buttonLabel}
      </button>
    </div>

    <p class="mt-3 hidden text-sm" data-feedback role="status" aria-live="polite"></p>

    <p class="mt-3 text-xs text-ink-muted">
      Email only — we never ask for income, age, or any detail about your family, and we never sell your
      address. <a href="/privacy">Privacy policy.</a>
    </p>
  </form>
</section>

<script>
  import { wireLeadForm } from '~/lib/lead-capture';

  document
    .querySelectorAll<HTMLFormElement>('form[data-capture="main"]')
    .forEach((form) => wireLeadForm(form, { source: 'main' }));
</script>
