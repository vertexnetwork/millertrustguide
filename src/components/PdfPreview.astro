// Text-based table of contents for the kit PDF. We deliberately avoid
// placeholder "preview" image boxes — paid ad traffic reads them as an
// unfinished site. When real PDF page screenshots are produced, swap this
// component for an image grid (aspect-ratio reserved so CLS stays clean).

const sections = [
  {
    label: 'Section 1',
    title: 'How a Miller Trust actually works',
    body: 'Plain-English walkthrough of why income-cap states require a QIT, what gets diverted, and what stays with your parent.',
  },
  {
    label: 'Section 2',
    title: 'Download the official state template',
    body: 'Direct .gov link, the version date to check for, and what to do if your state has just updated the template.',
  },
  {
    label: 'Section 3',
    title: 'Fill in the obvious fields',
    body: 'Applicant, trustee, listed income sources, residual beneficiary clause — every field, with what the state actually wants in each blank.',
  },
  {
    label: 'Section 4',
    title: 'The monthly funding worksheet',
    body: 'Pre-filled with the 2026 income cap so you know exactly how much income to redirect each month.',
