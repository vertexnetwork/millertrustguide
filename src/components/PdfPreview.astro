---
// Gallery of actual kit-page screenshots. Filesystem-driven: any image
// present at /public/kit-previews/{state-slug}/0N-*.png gets rendered with
// the matching caption from the previews[] array below.
//
// To add or change a preview, drop a PNG into public/kit-previews/{state}/
// using one of the filenames listed below. No code change required.

interface Props {
  stateSlug?: string;
}

const { stateSlug = 'texas' } = Astro.props;

// Per-state preview manifest. Captions are conversion copy — they tell the
// buyer what the page is *for*, not just what page it is.
const previews = [
  {
    file: '01-cover.png',
    title: 'Cover & key facts',
    caption: 'Version, last-reviewed date, the 2026 income cap, and the disclaimer — all on page 1.',
  },
  {
    file: '02-toc.png',
    title: 'Table of contents',
    caption: 'Ten operational sections plus three reference appendices. Every section in the order you\'ll use it.',
  },
  {
    file: '03-glossary.png',
    title: 'Plain-English glossary',
    caption: 'Eleven key terms translated for a non-attorney reader. The vocabulary the rest of the kit assumes.',
  },
  {
    file: '04-section5-intro.png',
    title: 'The bank-account walkthrough',
    caption: 'The opening of the section most buyers tell other buyers about — what to bring, what to expect at the counter.',
  },
  {
    file: '06-appendix-a.png',
    title: 'Citations index',
    caption: 'Every operational claim sourced to a primary HHSC, CMS, SSA, or federal-statute citation.',
  },
];

// Build URL for each preview against the requested state's folder. We do
// not import-glob the images because Astro's prerender pass needs the URLs
// to resolve at build time; missing files simply 404 and the <img> shows
// alt-text (the caption already conveys the value).
const previewsWithUrl = previews.map((p) => ({
  ...p,
  url: `/kit-previews/${stateSlug}/${p.file}`,
}));
---

<section aria-labelledby="preview-heading" class="my-12">
  <p class="text-xs font-semibold uppercase tracking-wider text-primary">What it actually looks like</p>
  <h2 id="preview-heading" class="!mt-1">Sample pages from the kit</h2>
  <p class="mt-2 text-ink-muted">
    Real pages from the {stateSlug.charAt(0).toUpperCase() + stateSlug.slice(1)} kit PDF. Click any page to enlarge.
  </p>

  <ul class="mt-6 grid grid-cols-1 gap-5 sm:grid-cols-2 md:grid-cols-3">
    {
      previewsWithUrl.map((p) => (
        <li class="overflow-hidden rounded-lg border border-border bg-surface-elevated shadow-sm">
          <a href={p.url} target="_blank" rel="noopener" class="block no-underline">
            {/* Crop+zoom to the top-left of the page (~1.3x) so the heading and
               first lines render legibly. Showing a full 8.5x11 page in a ~275px
               card shrinks body text to ~2px and reads as a blur. Source PNGs are
               1632x2112 (sharp); this is a display-fidelity fix, not a re-export. */}
            <div
              class="relative w-full overflow-hidden border-b border-border bg-white"
              style="aspect-ratio: 4 / 3;"
            >
              <img
                src={p.url}
                alt={`${p.title} — sample page from the Miller Trust Setup Kit`}
                class="absolute left-0 top-0 max-w-none"
                style="width: 130%;"
                loading="lazy"
                decoding="async"
              />
              {/* Soft fade hints the page continues below the crop. */}
              <div class="pointer-events-none absolute inset-x-0 bottom-0 h-10 bg-gradient-to-t from-white to-transparent"></div>
            </div>
            <div class="p-3">
              <p class="text-sm font-semibold text-ink-heading">{p.title}</p>
              <p class="mt-1 text-xs leading-snug text-ink">{p.caption}</p>
            </div>
          </a>
        </li>
      ))
    }
  </ul>

  <p class="mt-4 text-xs text-ink-muted">
    Print-friendly, readable on a phone or tablet, and designed to be taken to the bank. Every operational claim
    cites a primary state agency or federal source.
  </p>
</section>
