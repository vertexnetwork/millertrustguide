---
// Rule 4 — disclaimer on every page. Sticky thin strip at top.
// Short copy that fits on a single line at 360px without clipping the link;
// wraps naturally when it can't. Never truncate the link — full disclaimer
// must always be one tap away.
---

<aside
  id="site-disclaimer"
  class="no-print sticky top-0 z-40 border-b border-disclaimer-border bg-disclaimer-bg text-disclaimer-text"
  role="note"
  aria-label="Site disclaimer"
>
  <div class="mx-auto flex max-w-5xl items-center justify-between gap-4 px-4 py-2 text-xs leading-snug sm:text-sm">
    <p class="min-w-0">
      <span class="font-semibold">Informational only — not legal advice.</span>{' '}
      <a href="/disclaimer" class="whitespace-nowrap underline decoration-disclaimer-text">Read full disclaimer &rarr;</a>
    </p>
    <p class="hidden whitespace-nowrap text-disclaimer-text/80 md:block">
      Updated for 2026 income cap
    </p>
  </div>
</aside>
