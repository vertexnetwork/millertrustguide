---
import { getCollection } from 'astro:content';
import StatePageLayout from '~/layouts/StatePageLayout.astro';
import BaseLayout from '~/layouts/BaseLayout.astro';

export const prerender = true;

export async function getStaticPaths() {
  const states = await getCollection('states');
  return states.map((s) => ({
    params: { slug: s.slug },
    props: { state: { ...s.data, slug: s.slug } },
  }));
}

const { state } = Astro.props;
---

{
  state ? (
    <StatePageLayout state={state} />
  ) : (
    <BaseLayout title="State not found" description="We do not currently publish a kit for that state.">
      <article class="prose-content mx-auto max-w-3xl px-4 py-16">
        <h1>State not found</h1>
        <p>We do not currently publish a kit for the state you requested.</p>
        <p>
          <a href="/">Return to the home page</a> to see the states we cover.
        </p>
      </article>
    </BaseLayout>
  )
}
