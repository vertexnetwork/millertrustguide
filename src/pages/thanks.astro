---
import BaseLayout from '~/layouts/BaseLayout.astro';

// SSR so we can look up the Stripe session and confirm payment status before
// telling the buyer to check their inbox. Avoids the rare "thanks page loads
// before webhook fires" trust-erosion edge case.
export const prerender = false;

import { getStripe } from '~/lib/stripe';

const sessionId = Astro.url.searchParams.get('session_id');
let stateName: string | null = null;
let stateSlug: string | null = null;
let paymentConfirmed = false;
let lookupError = false;
// Actual charged amount for the Google Ads conversion value — reads from Stripe
// so it's always correct ($99 founder / $129 full / any tax), never hard-coded.
let amountTotal: number | null = null;
let currency = 'USD';

if (sessionId) {
  try {
    const stripe = getStripe();
    const session = await stripe.checkout.sessions.retrieve(sessionId);
    paymentConfirmed = session.payment_status === 'paid';
    stateName =
      (session.metadata?.state_name as string | undefined) ??
      (session.metadata?.state_slug
        ? String(session.metadata.state_slug).charAt(0).toUpperCase() + String(session.metadata.state_slug).slice(1)
        : null);
    stateSlug = (session.metadata?.state_slug as string | undefined) ?? null;
    if (typeof session.amount_total === 'number') amountTotal = session.amount_total / 100;
    if (session.currency) currency = session.currency.toUpperCase();
  } catch {
    lookupError = true;
  }
}

// Google Ads conversion identifiers — the purchase conversion fires below only
// when both are set (see docs/ad-campaign-playbook.md §0.5 + GoogleAdsTag.astro).
const adsId = import.meta.env.PUBLIC_GOOGLE_ADS_ID;
const adsPurchaseLabel = import.meta.env.PUBLIC_GOOGLE_ADS_PURCHASE_LABEL;
---

<BaseLayout
  title="Thank you — Miller Trust Guide"
  description="Payment received. Your kit is on its way to your inbox."
>
  <article class="prose-content mx-auto max-w-2xl px-4 py-16 text-center">
    {
      paymentConfirmed ? (
        <>
          <h1>Thank you{stateName ? ` — your ${stateName} kit is on the way` : ''}.</h1>
          <p>
            Your payment is confirmed. The download link is on its way to your inbox from
            <strong> support@millertrustguide.com</strong> — usually within a couple of minutes.
          </p>
          <p>
            The link is valid for 7 days. If you don't see it, check your spam folder, or just reply to any email from
            us and we'll resend right away. Add <strong>support@millertrustguide.com</strong> to your contacts so the
            next emails — the bank-step reminders, the income-cap updates — don't get filtered.
          </p>
          <p class="text-sm text-ink-muted">
            One practical next step: open the PDF on the device you'll take to the bank. The bank-refusal script in
            Section 5 is what you'll want at the counter.
          </p>
          <p class="text-sm text-ink-muted">
            Once you've had a chance to use it, we'd value your read on the kit:{' '}
            <a href={stateSlug ? `/feedback?state=${stateSlug}` : '/feedback'}>tell us how it went</a>. A real person
            reads every note, and it shapes the next version.
          </p>
        </>
      ) : lookupError || !sessionId ? (
        <>
          <h1>Thank you</h1>
          <p>
            If you just completed checkout, your kit will arrive in your inbox within a few minutes from
            <strong> support@millertrustguide.com</strong>.
          </p>
          <p>
            If you don't see it within 15 minutes, please email
            <a href="mailto:support@millertrustguide.com"> support@millertrustguide.com</a> and we'll resend.
          </p>
        </>
      ) : (
        <>
          <h1>Almost there</h1>
          <p>
            Stripe is still confirming your payment. The kit will be emailed the moment it clears — usually within a
            minute or two. If you haven't received it within 15 minutes, email
            <a href="mailto:support@millertrustguide.com"> support@millertrustguide.com</a> and we'll resend.
          </p>
        </>
      )
    }

    <p class="mt-8 text-sm text-ink-muted">
      Reminder: this kit is informational only and is not legal advice. For advice on your specific situation, consult
      a licensed elder-law attorney in your state.
    </p>
  </article>

  {/*
    Conversion event — joins confirmed purchases to the Vercel Web Analytics
    funnel (buy_click → checkout_redirect → purchase). Fires only on a paid
    session and dedupes on the Stripe session id so a page refresh can't
    double-count. Inline (define:vars) because it needs the server-side values.
  */}
  {
    paymentConfirmed && sessionId && (
      <script is:inline define:vars={{ sessionId, stateName }}>
        try {
          const key = 'mtg_purchase_tracked:' + sessionId;
          if (!sessionStorage.getItem(key)) {
            window.va &&
              window.va('event', { name: 'purchase', data: stateName ? { state: stateName } : {} });
            sessionStorage.setItem(key, '1');
          }
        } catch (e) {
          /* analytics must never break the page */
        }
      </script>
    )
  }

  {/*
    Google Ads purchase conversion — fires only on a paid session AND when the
    conversion id + label are configured. Dedupes per Stripe session id (a page
    refresh can't double-count); Google also dedupes on transaction_id. Dynamic
    value = the actual amount Stripe charged. Inert if the env vars are unset.
  */}
  {
    paymentConfirmed && sessionId && adsId && adsPurchaseLabel && (
      <script is:inline define:vars={{ adsId, adsPurchaseLabel, sessionId, amountTotal, currency }}>
        try {
          const key = 'mtg_gads_tracked:' + sessionId;
          if (window.gtag && !sessionStorage.getItem(key)) {
            window.gtag('event', 'conversion', {
              send_to: adsId + '/' + adsPurchaseLabel,
              value: typeof amountTotal === 'number' ? amountTotal : undefined,
              currency: currency || 'USD',
              transaction_id: sessionId,
            });
            sessionStorage.setItem(key, '1');
          }
        } catch (e) {
          /* analytics must never break the page */
        }
      </script>
    )
  }
</BaseLayout>
