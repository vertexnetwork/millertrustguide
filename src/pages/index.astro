---
import { getCollection } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import LeadMagnetForm from '~/components/LeadMagnetForm.astro';
import IncomeCapCheck from '~/components/IncomeCapCheck.astro';
import {
  faqPageSchemaFromPairs,
  articleSchema,
  breadcrumbSchema,
} from '~/lib/schema';
import { firstSentence } from '~/lib/text';
import { FOUNDER } from '~/config/founder';

export const prerender = true;

// GLOBAL founder offer (shared across all states) — see src/config/founder.ts.
// Display-only; Stripe's coupon is the hard enforcement of the discounted charge.
const founderActive = FOUNDER.unitsSold < FOUNDER.unitLimit;

const states = (await getCollection('states'))
  .map((s) => ({ ...s.data, slug: s.slug }))
  .sort((a, b) => a.name.localeCompare(b.name));

const live = states.filter((s) => s.status === 'live');
const draft = states.filter((s) => s.status === 'draft');
const blocked = states.filter((s) => s.status === 'blocked');

const SITE_URL = 'https://millertrustguide.com';

// Homepage FAQ — generic QIT questions (separate from per-state FAQ).
// Ordered for the skim path: transactional questions first
// (delivery, cost, refund), informational/explainer second, legal
// disclaimer last. Powers the FAQPage schema and the visible accordion.
const homeFaq = [
  {
    question: 'How fast do I get the kit and start the trust?',
    answer:
      'Instant. The download link arrives by email within minutes of payment. Most families have the trust signed, the bank account open, and the first month\'s income redirected within seven days — fast enough to qualify for the next Medicaid eligibility month and stop the private-pay clock.',
  },
  {
    question: 'What does the kit cost and what\'s the guarantee?',
    answer:
      'A single-state digital download is $129. Two-state bundle is $219; three-state bundle is $299. If your state Medicaid agency rejects the Qualified Income Trust for any reason traceable to following the kit, we refund the full purchase price within one business day. No phone tag, no forms.',
  },
  {
    question: 'When does Medicaid coverage actually begin?',
    answer:
      'Coverage begins the calendar month the QIT is signed AND funded — both in the same calendar month. There is no back-dating. Every month of delay is another month of full private-pay nursing-home cost ($7,500–$15,000 in most US markets). That is the single biggest reason to start now rather than at the next attorney consult opening.',
  },
  {
    question: 'Why not just hire an elder-law attorney?',
    answer:
      'You can — and for complex estates (significant assets, prior gifting, second marriages, multi-state property) you probably should. But for the core Miller Trust setup, the work is following a state-published template and opening a specific kind of bank account. Attorneys typically charge $1,000–$2,500 for this. Our kit is $129 and includes the bank-refusal script most attorneys handle themselves but never write down.',
  },
  {
    question: 'What is a Miller Trust?',
    answer:
      'A Miller Trust (also called a Qualified Income Trust or QIT) is an irrevocable trust used in 24 US "income-cap" states to divert income above the Medicaid long-term-care threshold so the applicant qualifies for nursing-home Medicaid or HCBS waiver benefits. Income deposited into the QIT is not counted by Medicaid when determining eligibility.',
  },
  {
    question: 'What is the 2026 Medicaid income limit?',
    answer:
      'For 2026, the long-term-care Medicaid income limit is $2,982 per month for a single applicant and $5,964 per month for a couple where both spouses are applying. These figures derive from 300% of the 2026 Federal Benefit Rate, effective January 1, 2026. If your parent\'s monthly income is above this, a Miller Trust is the standard mechanism to qualify.',
  },
  {
    question: 'Which states allow Miller Trusts?',
    answer:
      'As of December 2025, 24 income-cap states permit Qualified Income Trusts: Alabama, Alaska, Arizona, Arkansas, Colorado, Delaware, Florida, Georgia, Idaho, Indiana, Iowa, Kentucky, Mississippi, Nevada, New Jersey, New Mexico, Ohio, Oklahoma, Oregon, South Carolina, South Dakota, Tennessee, Texas, and Wyoming. Louisiana allows QITs conditionally; Missouri permits them for HCBS waivers only.',
  },
  {
    question: 'Do you draft the trust document?',
    answer:
      'No. We never author or host trust instrument text. The kit links you to your state\'s publicly-published Qualified Income Trust template on the state agency .gov website. You download the template directly from the agency. We explain how to use it, how to fund it, and how to keep it compliant month to month.',
  },
  {
    question: 'Is this legal advice?',
    answer:
      'No. Miller Trust Guide is an informational publisher, not a law firm. We are not attorneys and we do not practice law. We do not customize the kit based on your specific situation. For advice on your specific situation, consult a licensed elder-law attorney in your state.',
  },
];

const canonical = SITE_URL + '/';
const jsonLd = [
  articleSchema({
    headline: 'Miller Trust Guide — State-Specific Operational Guides for Medicaid Qualified Income Trusts',
    description:
      'State-specific operational guides for setting up a Qualified Income Trust (Miller Trust) to qualify a family member for Medicaid long-term care. Informational, not legal advice.',
    url: canonical,
    dateModified: '2026-05-20',
    lastReviewed: '2026-05-20',
    speakableCssSelectors: ['#tldr', '.faq-question', '.faq-answer__lead'],
  }),
  faqPageSchemaFromPairs(homeFaq),
  breadcrumbSchema([{ name: 'Home', url: canonical }]),
];
---

<BaseLayout
  title="Miller Trust Guide — State-Specific Setup Guides for Medicaid Qualified Income Trusts (2026)"
  description="State-specific operational guides for setting up a Qualified Income Trust (Miller Trust) to qualify a family member for Medicaid long-term care. Built around each state's official .gov template. Informational, not legal advice."
  canonical={canonical}
  jsonLd={jsonLd}
  ogImage={`${SITE_URL}/og-default.png`}
  ogImageAlt="Miller Trust Guide — state-specific operational guides for Medicaid Qualified Income Trusts."
  speakableSelector="#tldr"
>
  <section class="mx-auto max-w-3xl px-4 pt-8 pb-4 md:pt-12">
    <p class="text-sm font-medium uppercase tracking-wide text-ink-muted">Miller Trust Guide</p>
    <h1 class="mt-2 !text-3xl md:!text-5xl">
      Set up a Miller Trust before your parent loses a month of Medicaid coverage.
    </h1>

    {/* Answer-first lede. Speakable. */}
    <p
      id="tldr"
      class="mt-5 rounded-lg border border-primary/20 bg-primary-tint/30 p-4 text-base leading-relaxed text-ink"
    >
      A Miller Trust (Qualified Income Trust, or QIT) is an irrevocable trust used in 24 US income-cap states to qualify
      a Medicaid applicant whose monthly income exceeds the long-term-care threshold (2026 cap: $2,982/month for a
      single applicant). Each state publishes its own QIT template on its Medicaid agency site. Our state-specific kit
      is the step-by-step playbook around that template — how to fund it, how to open the bank account when the branch
      refuses, how to redirect Social Security and pension, and how to avoid the denial reasons most families trip on.
      $129, instant download, money-back if the agency rejects the trust. We are researchers, not attorneys.
    </p>

    <p class="mt-4 text-sm text-ink-muted">
      Last reviewed <time datetime="2026-05-20">2026-05-20</time>. Annual update each January after CMS publishes the
      new Federal Benefit Rate.
    </p>
  </section>

  <IncomeCapCheck />

  <section id="states" class="mx-auto max-w-3xl px-4 py-6">
    <h2>Pick your state to start</h2>
    {
      live.length === 0 ? (
        <p class="mt-2 text-ink-muted">
          No kits are currently published. Join the free email series below to be notified when we launch.
        </p>
      ) : (
        <ul class="mt-4 grid grid-cols-1 gap-4 md:grid-cols-2">
          {live.map((s) => (
            <li class="rounded-lg border border-border bg-surface-elevated p-5">
              <div class="flex items-baseline justify-between gap-3">
                <a
                  href={`/states/${s.slug}`}
                  class="text-lg font-semibold no-underline hover:underline"
                  aria-label={`${s.name} Miller Trust Setup Guide — $${founderActive ? FOUNDER.price : s.price}`}
                >
                  {s.name} Miller Trust Kit
                </a>
                {founderActive ? (
                  <span class="flex items-baseline gap-1.5 whitespace-nowrap">
                    <span class="text-lg font-bold text-ink-heading">${FOUNDER.price}</span>
                    <span class="text-sm text-ink-muted line-through">${s.price}</span>
                  </span>
                ) : (
                  <span class="text-lg font-bold text-ink-heading">${s.price}</span>
                )}
              </div>
              {founderActive && (
                <p class="mt-1 text-xs font-medium text-primary">Founding price — limited early-customer offer.</p>
              )}
              <p class="mt-2 text-sm text-ink">
                Built around the official {s.agencyAbbreviation} template. Bank-refusal script, monthly funding
                worksheet, denial-avoidance checklist. Instant download, money-back if {s.agencyAbbreviation} rejects.
              </p>
              <p class="mt-3 text-sm">
                <a href={`/states/${s.slug}`} class="font-medium text-primary">
                  See what's in the {s.name} kit &rarr;
                </a>
              </p>
            </li>
          ))}
        </ul>
      )
    }
  </section>

  {
    draft.length > 0 && (
      <section class="mx-auto max-w-3xl px-4 py-6">
        <h2>In progress</h2>
        <p class="mt-2 text-ink-muted">
          Drafting kits for: {draft.map((s) => s.name).join(', ')}.
        </p>
      </section>
    )
  }

  {
    blocked.length > 0 && (
      <section class="mx-auto max-w-3xl px-4 py-6">
        <h2>Not currently available</h2>
        <p class="mt-2 text-ink-muted">
          We do not currently publish kits for: {blocked.map((s) => s.name).join(', ')}.
        </p>
      </section>
    )
  }

  <section class="mx-auto max-w-3xl px-4 py-10">
    <h2>What this is — and what it isn't</h2>
    <ul class="mt-3 list-disc space-y-2 pl-6">
      <li>An informational operational guide. Plain-English explanations of state Medicaid policy, citations, and step-by-step instructions.</li>
      <li>Not legal advice. Not a substitute for a licensed attorney. We do not draft trust instruments.</li>
      <li>Not personalized. Every buyer in a given state receives the byte-identical kit.</li>
      <li>Support is email-only and limited to product and refund questions. For advice on your specific situation, consult a licensed elder-law attorney in your state.</li>
    </ul>
  </section>

  <section class="mx-auto max-w-3xl px-4">
    <LeadMagnetForm
      heading="Not ready to buy? Start with the free email series."
      blurb="A handful of short, plain-English emails on how Miller Trusts actually work — the funding-month rule, the bank step, the denial traps. No sales pressure. Unsubscribe anytime."
    />
  </section>

  <section class="mx-auto max-w-3xl px-4 py-10" aria-labelledby="home-faq-heading">
    <h2 id="home-faq-heading">Frequently asked questions</h2>
    <dl class="mt-4 divide-y divide-border">
      {
        homeFaq.map((f, i) => {
          const { lead, rest } = firstSentence(f.answer);
          return (
            <details class="group py-4" open={i === 0}>
              <summary class="faq-question cursor-pointer list-none font-semibold text-ink-heading marker:hidden">
                <span class="inline-block transition-transform group-open:rotate-90" aria-hidden="true">▸</span>{' '}
                {f.question}
              </summary>
              <div class="faq-answer mt-2 pl-5 leading-relaxed text-ink">
                <span class="faq-answer__lead">{lead}</span>
                {rest && <> {rest}</>}
              </div>
            </details>
          );
        })
      }
    </dl>
  </section>

  <section class="mx-auto max-w-3xl px-4 py-10">
    <h2>Editorial sources</h2>
    <p class="text-ink-muted">
      Every claim on this site cites a primary state agency document or a recognized source. The official
      state-agency template behind each state we cover:
    </p>
    {/* Data-driven from the live-states collection so this list stays current
        automatically as states are added — no hand-maintained URLs to go stale.
        Each link is the state's URL-verified officialTemplateUrl (.gov/.us). */}
    <ul class="mt-3 list-disc space-y-1 pl-6 text-sm">
      {live.map((s) => (
        <li>
          <a href={s.officialTemplateUrl} rel="external nofollow noopener">
            {s.name} — {s.agencyAbbreviation} {s.policyCitationShort}
          </a>
        </li>
      ))}
      <li>
        <a href="https://www.medicaidplanningassistance.org/miller-trusts/" rel="external nofollow noopener">
          American Council on Aging — Miller Trusts / income-cap states overview
        </a>
      </li>
    </ul>
    <p class="mt-4 text-sm text-ink-muted">
      <a href="/editorial-process">Editorial process &rarr;</a> &middot;{' '}
      <a href="/authors/james-whitfield">About the author &rarr;</a>
    </p>
  </section>
</BaseLayout>
