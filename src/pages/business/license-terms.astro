---
// B2B Business License Terms — the clickwrap agreement a facility accepts at
// /business/pricing (the consent checkbox links here). Prose/legal page in the
// same house style as disclaimer.astro / refund-policy.astro. noindex: this is
// pre-launch B2B fine print, not a marketing surface.
import BaseLayout from '~/layouts/BaseLayout.astro';
import { B2B_CONSENT_VERSION } from '~/config/b2b';
export const prerender = true;
---

