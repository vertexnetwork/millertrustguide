---
import '~/styles/kit-print.css';
import type { StateData } from '~/content/config';

interface Props {
  state: StateData;
}

const { state } = Astro.props;

const fmt = (n: number) => n.toLocaleString('en-US');

/* Hybrid (HCB-waiver) states — e.g. Missouri — use the QIT ONLY to meet the
   absolute income maximum of an in-home Home & Community-Based waiver, NOT for
   nursing-facility Medicaid (that uses spend-down). The whole distribution model
   differs: the participant keeps income up to the cap, deposits only the excess,
   and the trust spends on the participant's OWN allowable medical/care costs —
   there is no nursing-facility Personal Needs Allowance and no patient-liability
   paid to a facility. Every `hcb` branch below renders that model; the else
   branch is byte-identical to the income-cap/nursing-facility narrative all
   other states ship, so their output is unchanged. */
const hcb = state.medicaidStructure === 'hybrid';

/* The kit content is structured as a single layout that renders the full
   PDF for any state by interpolating state-specific facts pulled from the
   state's frontmatter. ~95% of the prose is state-agnostic; the
   ~5% that varies (income cap, agency name, policy section, denial list,
   bank-refusal patterns, trustee restrictions, state-bar referral URL) is
   pulled from frontmatter. This is the same pattern the site uses for
   state pages — single template, N states, no template forks. */
---

<!doctype html>
<html lang="en-US">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{state.name} Miller Trust Setup Kit — {state.kitVersion}</title>
    <meta name="robots" content="noindex,nofollow,noarchive" />
    <meta name="generator" content="Miller Trust Guide Kit Builder" />
    <link rel="preconnect" href="https://rsms.me" crossorigin />
    <link rel="stylesheet" href="https://rsms.me/inter/inter.css" />
    {/* Paged.js: turns this HTML into paginated, header/footer/page-numbered
       output that Playwright captures to PDF. Loaded only at build time. */}
    <script src="https://unpkg.com/pagedjs@0.4.3/dist/paged.polyfill.js" defer is:inline></script>

    {/* Floating print-UI injector. Lives in <head> so it runs at parse time
       (independent of any body manipulation by Paged.js), attaches to
       documentElement rather than body (Paged.js applies transforms inside
       body that can trap position:fixed on body descendants), and fires
       both on the pagedjs-rendered event and on a 1.5s fallback timer. */}
    <script is:inline>
      (function () {
        function injectPrintUi() {
          if (document.getElementById('kit-print-button')) return;
          var btn = document.createElement('button');
          btn.id = 'kit-print-button';
          btn.className = 'kit-print-button';
          btn.type = 'button';
          btn.setAttribute('aria-label', 'Open print dialog to save as PDF');
          btn.innerHTML =
            '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">' +
              '<path d="M6 9V2h12v7" stroke-linecap="round" stroke-linejoin="round" />' +
              '<rect x="4" y="9" width="16" height="9" rx="1" />' +
              '<path d="M6 18v4h12v-4" stroke-linecap="round" stroke-linejoin="round" />' +
            '</svg> Save as PDF';
          btn.onclick = function () { window.print(); };

          var hint = document.createElement('p');
          hint.id = 'kit-print-hint';
          hint.className = 'kit-print-hint';
          hint.textContent =
            'Tip: in your browser print dialog, choose "Save as PDF" and enable "Background graphics" so colors print.';

          // documentElement (the <html>) is outside the body subtree that
          // Paged.js transforms, so position:fixed works reliably from here.
          document.documentElement.appendChild(btn);
          document.documentElement.appendChild(hint);
        }

        function ready(fn) {
          if (document.readyState !== 'loading') fn();
          else document.addEventListener('DOMContentLoaded', fn);
        }

        ready(function () {
          document.addEventListener('pagedjs-rendered', injectPrintUi);
          window.setTimeout(injectPrintUi, 1500);
        });
      })();
    </script>
  </head>
  <body class="kit">

    {/* ============================== COVER ============================== */}
    <section class="kit-cover">
      {/* Strings consumed by the @page running headers/footers. Placed inside
         the first section (not before it) so Paged.js doesn't treat them as
         floating pre-content that needs its own page. */}
      <span class="kit-state-string" aria-hidden="true" style="position:absolute;left:-9999px;width:0;height:0;overflow:hidden">{state.name}</span>
      <span class="kit-version-string" aria-hidden="true" style="position:absolute;left:-9999px;width:0;height:0;overflow:hidden">{state.kitVersion}</span>

      <div class="kit-cover-inner">
        <div>
          <div class="kit-cover-mark">
            <span class="kit-cover-mark-square">MT</span>
            <span>Miller Trust Guide</span>
          </div>
          <p style="margin-top: 90pt; font-size: 9pt; text-transform: uppercase; letter-spacing: 0.18em; color: #6B7280;">
            {state.abbreviation} &middot; Setup Kit
          </p>
          <h1 class="kit-cover-title">
            {state.name} Miller Trust Setup Kit
          </h1>
          <p class="kit-cover-subtitle">
            A step-by-step operational guide to qualifying a family member for {state.name} Medicaid long-term care
            using the official {state.agencyAbbreviation} Qualified Income Trust template.
          </p>
        </div>

        <dl class="kit-cover-meta">
          <dt>Edition</dt>
          <dd>{state.kitVersion}</dd>
          <dt>Last reviewed</dt>
          <dd>{state.kitVersionDate}</dd>
          <dt>State</dt>
          <dd>{state.name} ({state.abbreviation})</dd>
          <dt>State agency</dt>
          <dd>{state.agencyAbbreviation}</dd>
          <dt>{hcb ? 'HCB income maximum' : '2026 income cap'}</dt>
          <dd>${fmt(state.incomeCap2026)}/month {hcb ? '(per applicant)' : '(single)'}</dd>
          <dt>Publisher</dt>
          <dd>Miller Trust Guide &middot; millertrustguide.com</dd>
        </dl>

        <p style="font-size: 8.5pt; color: #6B7280; line-height: 1.5; margin-top: 18pt; border-top: 0.5pt solid #D1D5DB; padding-top: 10pt;">
          Informational only. Not legal advice. Not a substitute for consultation with a licensed attorney.
          Miller Trust Guide is not a law firm and does not practice law. We do not draft legal documents. State
          Medicaid rules vary and change; verify all information with your state Medicaid agency and an attorney
          licensed in your state before acting.
        </p>
      </div>
    </section>

    {/* ====================== DISCLAIMER / RULE 4 ======================== */}
    <section id="disclaimer" class="kit-page-break kit-front-matter">
      <p class="kit-eyebrow">Required reading</p>
      <h1>Disclaimer and consent acknowledgment</h1>

      <p>
        <strong>This kit is informational only.</strong> It is not legal advice. It is not a substitute for
        consultation with a licensed attorney. Miller Trust Guide is not a law firm and does not practice law.
        We do not draft legal documents. We do not host trust instrument text.
      </p>

      <p>
        The kit teaches you how to use {state.name}'s publicly-published Qualified Income Trust template — published
        by {state.agencyName} on its official .gov website — to qualify a family member for long-term-care Medicaid.
        We explain how to use the template, how to fund the trust, how to open the bank account, and how to avoid
        common denial reasons. <strong>We never apply legal judgment to your family's specific situation.</strong>
      </p>

      <p>
        State Medicaid rules vary and change. The figures, policy sections, and procedures cited in this kit reflect
        publicly-available {state.agencyAbbreviation} materials as of <strong>{state.kitVersionDate}</strong>.
        Verify all information directly with {state.agencyAbbreviation} and an attorney licensed in {state.name}
        before acting on any step in this kit.
      </p>

      <div class="kit-callout kit-callout--rule">
        <p style="font-weight: 600;">By using this kit, you acknowledge:</p>
        <ul style="margin-bottom: 0;">
          <li>This is an informational guide, not legal advice.</li>
          <li>You will consult a licensed attorney in {state.name} for advice on your specific situation.</li>
          <li>You are using a guide that explains how to use {state.agencyAbbreviation}'s public Medicaid forms.</li>
          <li>Miller Trust Guide cannot and does not represent you in any matter.</li>
        </ul>
      </div>

      <h3>Support scope</h3>
      <p>
        Email support is limited to two categories: product/refund questions, and the canned redirect for any
        question about your specific situation. For advice on your specific situation, please consult a licensed
        {state.name} elder-law attorney — you can find one through the
        <a href={state.stateBarLrsUrl}>{state.stateBarLrsName}</a>. We do not offer phone support.
      </p>

      <h3>Refund</h3>
      <p>
        If {state.agencyAbbreviation} rejects your QIT for any reason traceable to following this kit, email
        <strong> support@millertrustguide.com</strong> with the agency's stated denial reason and we issue a full
        refund within one business day. See the refund policy at
        <a href="https://millertrustguide.com/refund-policy">millertrustguide.com/refund-policy</a>.
      </p>
    </section>

    {/* ============================ HOW TO USE =========================== */}
    <section id="how-to-use" class="kit-page-break kit-front-matter">
      <p class="kit-eyebrow">Orientation</p>
      <h1>How to use this kit</h1>

      <p>
        This kit is designed to be read in order the first time, then used as a reference throughout the setup
        process. Most {state.name} families complete the full process in seven to ten days from the day they
        download the kit to the day Medicaid coverage begins.
      </p>

      <h3>Recommended sequence</h3>
      <ol>
        <li><strong>Read Sections 1 and 2 first.</strong> They establish what a Miller Trust is and where the official {state.agencyAbbreviation} template lives.</li>
        <li><strong>Complete the worksheet in Section 4</strong> before you fill in the template. The worksheet tells you exactly how much income to redirect each month.</li>
        <li><strong>Print Section 5</strong> (the bank-account walkthrough) and bring it with you to the bank. Bring the resolution letter at the end of Section 5 with you in case the branch refuses.</li>
        <li><strong>Use Section 7</strong> as your pre-submission checklist before you file the Medicaid application.</li>
      </ol>

      <h3>What you'll need before you start</h3>
      <ul>
        <li>The applicant's Social Security card and a government-issued photo ID.</li>
        <li>Documentation of every income source the applicant receives (most recent Social Security award letter, pension statement, annuity statement, etc.).</li>
        <li>The trustee's photo ID. The trustee is the person who will manage the trust account — see Section 3 for who can serve.</li>
        <li>Power of attorney documentation if the trustee is acting under POA.</li>
        <li>A working email address you check daily — {state.agencyAbbreviation} and your bank will communicate by phone and mail, but the {state.agencyAbbreviation} portal sends notices by email.</li>
      </ul>

      <div class="kit-callout">
        <p>
          <strong>Time-sensitive:</strong> Medicaid eligibility in {state.name} begins the calendar month the QIT
          is signed <em>and</em> funded — not earlier. There is no back-dating. If you start this process in the
          last week of a month, plan to sign and fund the trust by the last business day of that month, or accept
          that coverage starts the following month.
        </p>
      </div>
    </section>

    {/* ============================= GLOSSARY ============================ */}
    <section id="glossary" class="kit-page-break kit-front-matter">
      <p class="kit-eyebrow">Plain-English glossary</p>
      <h1>Key terms</h1>

      <dl class="kit-glossary">
        <dt><strong>Qualified Income Trust (QIT) / Miller Trust</strong></dt>
        <dd>An irrevocable trust authorized by federal law ({state.federalStatuteCitation}) that diverts income above a state's Medicaid long-term-care income limit so the applicant qualifies for benefits. The two names refer to the same instrument; "Miller Trust" comes from the 1990 case <em>Miller v. Ibarra</em>, which established the mechanism.</dd>

        <dt><strong>Applicant</strong></dt>
        <dd>The person applying for Medicaid long-term-care benefits. The QIT is funded with the applicant's own income.</dd>

        <dt><strong>Community spouse</strong></dt>
        <dd>The non-applicant spouse of a married applicant. The community spouse remains at home (or in a non-institutional setting) while the applicant receives Medicaid-covered long-term care. Different rules apply to the community spouse's income and assets.</dd>

        <dt><strong>Trustee</strong></dt>
        <dd>The person who manages the QIT bank account. The trustee deposits the applicant's income each month and disburses the distributions the trust authorizes. See Section 3 for who can — and cannot — serve as trustee in {state.name}.</dd>

        <dt><strong>Residual beneficiary</strong></dt>
        <dd>The party that receives anything left in the QIT after the applicant's death. Federal law requires the state Medicaid agency to be named as the residual beneficiary up to the total amount Medicaid paid on the applicant's behalf.</dd>

        {hcb ? (
          <Fragment>
            <dt><strong>Allowable distributions</strong></dt>
            <dd>What the HCB trust may spend on — the applicant's own benefit only: non-covered medical costs, health-insurance premiums other than {state.ltcProgramAbbrev}, dental / therapy / rehabilitation and similar care, transportation to medical and care appointments, and the trust's own allowable bank and trustee fees. There is no nursing-facility Personal Needs Allowance and no patient-liability payment to a facility, because HCB care is delivered in the applicant's home. See Section 1.</dd>

            <dt><strong>HCB income maximum (income cap)</strong></dt>
            <dd>The maximum monthly income an applicant can have and still qualify for {state.name}'s Home and Community-Based (HCB) waiver. {state.name}'s current maximum is <strong>${fmt(state.incomeCap2026)}/month</strong> ({state.asOf}). It is an <em>absolute</em> limit — an over-income applicant cannot spend down to qualify, which is why a Qualified Income Trust is the only path. Each spouse is tested individually; there is no higher combined couple limit.</dd>
          </Fragment>
        ) : (
          <Fragment>
            <dt><strong>Personal Needs Allowance (PNA)</strong></dt>
            <dd>The amount of the applicant's income retained each month for personal expenses while in a nursing facility. {state.name}'s PNA is <strong>${fmt(state.personalNeedsAllowance)}/month</strong>.</dd>

            <dt><strong>Income cap</strong></dt>
            <dd>The maximum monthly income a single applicant can have and still qualify for long-term-care Medicaid in an "income-cap state." {state.name}'s 2026 cap is <strong>${fmt(state.incomeCap2026)}/month</strong> (single) and <strong>${fmt(state.incomeCapCouple2026)}/month</strong> for a couple where both spouses are applying. Computed as 300% of the CMS Federal Benefit Rate, which CMS publishes each January.</dd>
          </Fragment>
        )}

        <dt><strong>{state.agencyAbbreviation}</strong></dt>
        <dd>{state.agencyName}. The {state.name} state agency that administers Medicaid eligibility and publishes the QIT template referenced in Section 2.</dd>

        <dt><strong>{state.policyManualSection}</strong></dt>
        <dd>The {state.agencyAbbreviation} policy manual section(s) that govern Qualified Income Trusts in {state.name}. Cited throughout this kit and indexed in Appendix A.</dd>

        <dt><strong>{state.ltcProgramAbbrev}</strong></dt>
        <dd>{state.ltcProgramName} — the {state.agencyAbbreviation} program category that covers long-term-care Medicaid eligibility.</dd>

        <dt><strong>Look-back period</strong></dt>
        <dd>A 60-month (5-year) window before the Medicaid application date during which uncompensated asset transfers may trigger a transfer penalty (period of ineligibility). The QIT does not affect the look-back analysis. If the applicant has made gifts or transfers in the last five years, consult an attorney — see Section 9.</dd>

        <dt><strong>Estate recovery</strong></dt>
        <dd>The state's right to recover Medicaid spending from the applicant's estate after death. Each state has its own estate-recovery rules and exemptions (homestead, surviving spouse, certain dependents). The QIT's residual beneficiary clause is part of this framework. See Section 8.</dd>
      </dl>
    </section>

    {/* ========================== TABLE OF CONTENTS ====================== */}
    <section id="toc" class="kit-page-break kit-front-matter">
      <p class="kit-eyebrow">What's inside</p>
      <h1>Table of contents</h1>

      <ul class="kit-toc-list">
        <li><a href="#section-1"><span class="toc-title">Section 1 &middot; What a {state.name} Miller Trust does</span></a></li>
        <li><a href="#section-2"><span class="toc-title">Section 2 &middot; Where to download the official {state.agencyAbbreviation} template</span></a></li>
        <li><a href="#section-3"><span class="toc-title">Section 3 &middot; Filling in the obvious fields</span></a></li>
        <li><a href="#section-4"><span class="toc-title">Section 4 &middot; The monthly funding worksheet</span></a></li>
        <li><a href="#section-5"><span class="toc-title">Section 5 &middot; The bank-account walkthrough</span></a></li>
        <li><a href="#section-6"><span class="toc-title">Section 6 &middot; Funding the trust month by month</span></a></li>
        <li><a href="#section-7"><span class="toc-title">Section 7 &middot; Common {state.name} Medicaid denials</span></a></li>
        <li><a href="#section-8"><span class="toc-title">Section 8 &middot; Post-death distribution</span></a></li>
        <li><a href="#section-9"><span class="toc-title">Section 9 &middot; When to call an attorney</span></a></li>
        <li><a href="#section-10"><span class="toc-title">Section 10 &middot; What to say to family members</span></a></li>
        <li><a href="#appendix-a"><span class="toc-title">Appendix A &middot; {state.agencyAbbreviation} citations index</span></a></li>
        <li><a href="#appendix-b"><span class="toc-title">Appendix B &middot; Trustee record-keeping checklist</span></a></li>
        <li><a href="#appendix-c"><span class="toc-title">Appendix C &middot; Version history</span></a></li>
      </ul>
    </section>

    {/* ============================ SECTION 1 ============================ */}
    <section id="section-1" class="kit-page-break">
      <p class="kit-eyebrow kit-section-title">Section 1 &middot; What a {state.name} Miller Trust does</p>
      <h1>What a {state.name} Miller Trust does, in plain English</h1>

      {hcb ? (
        <p>
          A <strong>Miller Trust</strong> — formally called a <strong>Qualified Income Trust (QIT)</strong> — is an
          irrevocable trust that lets a Medicaid applicant whose monthly income is above a program's limit still
          qualify. {state.name} is a special case: its nursing-facility Medicaid uses a medically-needy spend-down
          (no QIT), so the QIT here is used only to meet the <em>absolute</em> income maximum of the
          {' '}<strong>Home and Community-Based (HCB) waiver</strong> — {state.name}'s in-home and community care
          program for people age 63 and over — and the MOCDD program. Because the HCB maximum is absolute (an
          over-income applicant cannot spend down to qualify for the waiver), the QIT is the only path to in-home HCB
          eligibility for someone over the limit.
        </p>
      ) : (
        <p>
          A <strong>Miller Trust</strong> — formally called a <strong>Qualified Income Trust (QIT)</strong> — is an
          irrevocable trust used in twenty-four U.S. "income-cap" states to qualify a Medicaid applicant whose monthly
          income is above the long-term-care income threshold. {state.name} is an income-cap state.
        </p>
      )}

      <p>
        The mechanism is federal: <a href={state.federalStatuteUrl}>{state.federalStatuteCitation}</a> exempts
        income deposited into a properly drafted QIT from the income-eligibility count, on the condition that the
        trust meets specific drafting and operational requirements (irrevocability, designated income sources,
        Medicaid as residual beneficiary, and post-death distribution to the state).
      </p>

      <h3>The {state.name} numbers that matter</h3>
      <ul>
        <li>
          <strong>2026 income cap (single applicant):</strong> ${fmt(state.incomeCap2026)}/month. If the
          applicant's countable monthly income — Social Security, pension, annuity, VA benefits, and any other
          recurring income — exceeds this number by even one dollar, Medicaid long-term-care benefits are denied
          unless the excess is diverted through a QIT.
        </li>
        {hcb ? (
          <Fragment>
            <li>
              <strong>Married couples:</strong> each spouse is tested individually against the HCB income maximum —
              there is no higher combined "couple" limit. If both spouses are over the maximum and both want HCB
              services, each needs their own Qualified Income Trust.
            </li>
            <li>
              <strong>What the applicant keeps:</strong> because HCB care is delivered at home, there is no
              nursing-facility Personal Needs Allowance. The applicant keeps their income up to the HCB maximum in
              their own name; only the income <em>above</em> the maximum goes into the trust, and the trust spends it
              on the applicant's own allowable medical and care costs (see below). Source: {state.agencyAbbreviation}
              {' '}{state.policyManualSection}.
            </li>
            <li>
              <strong>Effective date:</strong> the income disregard begins the first month a valid QIT is signed, the
              trust account is opened, and enough of the over-the-maximum income is deposited to bring the applicant's
              remaining countable income below the HCB maximum — all in the same calendar month. Coverage does not
              back-date to before the trust is funded, so start in the month you intend eligibility to begin.
            </li>
          </Fragment>
        ) : (
          <Fragment>
            <li>
              <strong>2026 income cap (couple, both applying):</strong> ${fmt(state.incomeCapCouple2026)}/month combined.
            </li>
            <li>
              <strong>Personal Needs Allowance:</strong> ${fmt(state.personalNeedsAllowance)}/month. This is the
              amount of the applicant's income that stays with the applicant for personal expenses while in a nursing
              facility (toiletries, clothing, etc.). Source: {state.agencyAbbreviation} {state.policyManualSection}.
            </li>
            <li>
              <strong>Effective date:</strong> The income disregard begins the first month a valid QIT is signed, the
              QIT account is opened, and enough income is deposited to bring the remaining countable income below the
              special income limit. If all three were true in months <em>before</em> the Medicaid application was
              filed, {state.agencyAbbreviation} can apply the income disregard up to <strong>three months retroactive</strong> to the file
              date — provided all other eligibility requirements were met in those months.
            </li>
          </Fragment>
        )}
      </ul>

      <div class="kit-no-break">
        <h3>How the diversion works, mechanically</h3>
        {hcb ? (
          <Fragment>
            <p>
              Each month, the applicant keeps their income up to the HCB maximum in their own name and moves only the
              portion <em>above</em> the maximum into the QIT bank account — by direct deposit or a routine transfer
              (the income may not be assigned to the trust as payee). From the trust account, the third-party trustee
              spends that money only on the applicant's own allowable costs:
            </p>
            <ol>
              <li>The applicant's non-covered medical and care costs — dental, therapy, rehabilitation, medically necessary items, and transportation to medical and care appointments.</li>
              <li>Health-insurance premiums other than {state.ltcProgramAbbrev} (for example, a Medicare premium or a Medicare supplement).</li>
              <li>The trust's own allowable costs — bank fees and a capped trustee fee.</li>
            </ol>
            <p>
              Income moved through the QIT this way is not counted toward the HCB income maximum. Unlike a
              nursing-facility trust, nothing is paid to a facility as "patient liability," and the trust may hold
              accumulated income to spend on the applicant's care over time — so the balance is not expected to zero
              out each month.
            </p>
          </Fragment>
        ) : (
          <Fragment>
            <p>
              Each month, the trustee deposits the applicant's countable income into the QIT bank account. From the
              QIT account, the trustee distributes:
            </p>
            <ol>
              <li>The Personal Needs Allowance to the applicant (${fmt(state.personalNeedsAllowance)}/month).</li>
              <li>Any spousal allowance to the community spouse, if applicable.</li>
              <li>The remainder to the nursing facility as the applicant's "patient liability" or "share of cost."</li>
            </ol>
            <p>
              Income that passes through the QIT this way is not counted toward the income cap. The QIT is therefore
              an accounting and routing structure, not a savings vehicle. <strong>At the end of each month the trust
              account balance is typically zero or near-zero.</strong>
            </p>
          </Fragment>
        )}
      </div>

      {hcb ? (
        <div class="kit-callout kit-no-break">
          <p style="font-weight: 600; margin-bottom: 6pt;">Worked example — excess-only funding</p>
          <p style="margin-bottom: 6pt;">
            The most common misunderstanding: families assume the whole income check goes into the trust. In an HCB
            waiver trust it does not. Say a <strong>single</strong> applicant has <strong>$2,000/month</strong> in
            gross income and the HCB income maximum is <strong>${fmt(state.incomeCap2026)}</strong> (figures are
            illustrative). Each month:
          </p>
          <ol style="margin-bottom: 6pt;">
            <li>The applicant keeps <strong>${fmt(state.incomeCap2026)}</strong> — income up to the HCB maximum — in their own account, to live on.</li>
            <li>Only the excess — here <strong>${fmt(2000 - state.incomeCap2026)}</strong> — is moved into the trust, within the same month it is received.</li>
            <li>The trustee spends that ${fmt(2000 - state.incomeCap2026)} on the applicant's own allowable medical and care costs (for example, a Medicare premium or uncovered care).</li>
          </ol>
          <p style="margin-bottom: 0;">
            So the trust handles only the small over-the-maximum slice, not the whole $2,000 — and none of it is paid
            to a facility, because HCB care is provided in the applicant's home. {state.agencyAbbreviation} confirms
            the exact figures on the eligibility determination; the arithmetic here only shows that the trust receives
            the <em>excess</em>, never the gross income.
          </p>
        </div>
      ) : (
        <div class="kit-callout kit-no-break">
          <p style="font-weight: 600; margin-bottom: 6pt;">Worked example — where the money actually goes</p>
          <p style="margin-bottom: 6pt;">
            The single most common misunderstanding: families assume the whole deposit is handed to the nursing
            facility. It is not. Say a <strong>single</strong> applicant in a nursing facility has
            <strong>$4,000/month</strong> in gross income, all of it deposited into the QIT (figures are illustrative).
            Each month the trustee pays out, <strong>in this order</strong>:
          </p>
          <ol style="margin-bottom: 6pt;">
            <li>Personal Needs Allowance to the applicant — <strong>${fmt(state.personalNeedsAllowance)}</strong>.</li>
            <li>The community-spouse allowance, <em>if</em> the applicant is married and a spouse remains at home (see Section&nbsp;4, worksheet line&nbsp;J).</li>
            <li>Any allowable health-insurance premium — for example, the Medicare Part&nbsp;B premium.</li>
            <li>Everything that remains — the <strong>patient-liability / share of cost</strong> — to the nursing facility.</li>
          </ol>
          <p style="margin-bottom: 0;">
            So with a ${fmt(state.personalNeedsAllowance)} Personal Needs Allowance and no community spouse, the
            facility would receive roughly <strong>${fmt(4000 - state.personalNeedsAllowance)}</strong> — the $4,000
            minus the allowance and any health-insurance premium — <strong>not</strong> the full $4,000. The exact
            amounts are set by {state.agencyAbbreviation} on your post-eligibility budget; the arithmetic here only
            shows the order, and that the facility receives the <em>remainder</em>, never the gross deposit.
          </p>
        </div>
      )}

      {hcb ? (
        <div class="kit-callout">
          <p>
            <strong>The QIT does not affect asset eligibility.</strong> The QIT is an <em>income</em>-management tool.
            The countable-resource limit is a separate test — for {state.name}'s HCB waiver it is $6,220.50 for an
            individual applicant ($12,441.00 for a couple where both are eligible for HCB or Division of Assets),
            per {state.agencyAbbreviation}'s Non-MAGI Eligibility table. If your family member has resources above
            the limit, address those separately before applying; resource planning often requires an attorney
            (see Section 9).
          </p>
        </div>
      ) : (
        <div class="kit-callout">
          <p>
            <strong>The QIT does not affect asset eligibility.</strong> The QIT is an <em>income</em>-management tool.
            The asset (countable resource) limit is separate — generally $2,000 in countable assets for a single
            applicant. If your family member has assets above the limit, you may also need to address those before
            Medicaid will approve coverage. Asset-side planning often requires an attorney; see Section 9.
          </p>
        </div>
      )}

      <h3>What the trust is, legally</h3>
      <p>
        The QIT is an <strong>irrevocable</strong> trust — once funded, you cannot dissolve it and take the money
        back. It exists for one purpose: to receive and disburse the applicant's income according to the trust's
        own terms and the {state.agencyAbbreviation} requirements. The applicant retains beneficial use of the
        funds through the monthly distributions, but does not "own" the trust account in the conventional sense.
      </p>

      <p class="kit-cite">
        Source: {state.agencyAbbreviation} {state.policyManualSection}. Federal authority:
        {' '}{state.federalStatuteCitation}.
      </p>
    </section>

    {/* ============================ SECTION 2 ============================ */}
    <section id="section-2" class="kit-page-break">
      <p class="kit-eyebrow kit-section-title">Section 2 &middot; Where to download the official {state.agencyAbbreviation} template</p>
      <h1>Where to download the official {state.agencyAbbreviation} template</h1>

      <p>
        {state.agencyName} publishes the {state.name} Qualified Income Trust template and the policy instructions
        for using it on its official .gov website. <strong>This is the only template you should use.</strong>
        {state.agencyAbbreviation} accepts QITs drafted on its own published template; QITs drafted on alternate
        templates can be — and often are — rejected on technical grounds even when the substance is identical.
      </p>

      <h3>The download links</h3>
      <ul>
        <li>
          <strong>Official template page:</strong>{' '}
          <a href={state.officialTemplateUrl}>{state.officialTemplateUrl}</a>
          <br />
          <span class="kit-cite">{state.officialTemplateNote}</span>
        </li>
        <li>
          <strong>Policy manual section:</strong>{' '}
          <a href={state.policyManualUrl}>{state.policyManualUrl}</a>
          <br />
          <span class="kit-cite">Refer to {state.policyManualSection} for the operational rules and the
          {' '}requirements your trust must satisfy.</span>
        </li>
        {state.supplementalOfficialDocs.map((doc) => (
          <li>
            <strong>{doc.label}:</strong>{' '}
            <a href={doc.url}>{doc.url}</a>
            <br />
            <span class="kit-cite">{doc.note}</span>
          </li>
        ))}
      </ul>

      <div class="kit-callout kit-callout--warning">
        <p>
          <strong>If {state.agencyAbbreviation} has updated the template since {state.kitVersionDate}, use the
          updated version.</strong> Always download fresh from the link above on the day you sign the trust. Do not
          rely on a printed copy or a saved PDF. Template revisions sometimes change required clauses; using an
          outdated version is a documented denial cause (see Section 7).
        </p>
      </div>

      <h3>Why we don't host the template ourselves</h3>
      <p>
        Two reasons. First, drafting a trust instrument for another person is the practice of law in every state;
        publishing the state's own template would not change that analysis cleanly, so we link rather than host.
        Second, {state.agencyAbbreviation} occasionally revises its template, and a mirror on our site would go
        stale. Linking to the source guarantees you always get the current version {state.agencyAbbreviation}
        actually accepts.
      </p>
    </section>

    {/* ============================ SECTION 3 ============================ */}
    <section id="section-3" class="kit-page-break">
      <p class="kit-eyebrow kit-section-title">Section 3 &middot; Filling in the obvious fields</p>
      <h1>Filling in the obvious fields</h1>

      <p>
        The {state.agencyAbbreviation} template is a structured document with blanks. Most blanks ask for facts
        that are objectively true about your family — names, dates, income sources. This section walks through
        those obvious fields. <strong>Where the template asks you to make a substantive legal choice (residual
        beneficiary designations beyond Medicaid, complex trustee structures, anything the template's own
        instructions don't explain in plain English), stop and consult a {state.name} attorney</strong> — see
        Section 9.
      </p>

      <h3>1. Applicant identification</h3>
      <ul>
        <li><strong>Applicant's full legal name</strong> — exactly as it appears on the Social Security card.</li>
        <li><strong>Applicant's date of birth.</strong></li>
        <li><strong>Applicant's Social Security number.</strong></li>
        <li><strong>Applicant's current address</strong> — {hcb ? "the applicant's home, where HCB services are provided" : 'the nursing facility or current residence'}.</li>
      </ul>

      <h3>2. Trustee identification</h3>
      <p>
        The trustee is the person who manages the QIT bank account each month. Most families name an adult child
        of the applicant who has Power of Attorney for the applicant's finances. The applicant's spouse is also a
        common choice when the applicant is the institutionalized spouse and the community spouse is willing to
        serve.
      </p>

      <div class="kit-callout">
        <p style="font-weight: 600; margin-bottom: 6pt;">{state.agencyAbbreviation} guidance on trustee selection</p>
        <p style="margin-bottom: 0;">{state.trusteeGuidanceNote}</p>
        <p style="margin-top: 6pt; font-size: 9pt; color: #6B7280;">
          Source: {state.agencyAbbreviation} {state.policyManualSection}.
        </p>
      </div>

      <ul class="kit-no-break">
        <li><strong>Trustee's full legal name.</strong></li>
        <li><strong>Trustee's date of birth.</strong></li>
        <li><strong>Trustee's address and phone number.</strong></li>
        <li><strong>Trustee's relationship to applicant</strong> (e.g., "adult son," "spouse").</li>
      </ul>

      <h3>3. Income sources to list</h3>
      {hcb ? (
        <p>
          Add up <strong>all of the applicant's countable monthly income</strong> — Social Security, pension,
          annuity, and any other recurring income. In {state.name} you do not name each source for whole-source
          diversion the way some states require; instead you use the total to work out how much income sits
          {' '}<em>above</em> the HCB income maximum. Only that excess goes into the trust each month (Section 4 walks
          the math). The trust must hold only the applicant's own income — nothing that belongs to anyone else.
        </p>
      ) : (
        <p>
          List <strong>every recurring income source the applicant receives that counts toward the Medicaid income
          limit</strong>. The trust can only receive and divert income from sources named in the trust instrument.
          Once a source is named, <strong>the entire monthly amount from that source must be deposited into the QIT
          every month after the initial month</strong> — partial diversion of a listed source is a documented denial
          cause (Section 7).
        </p>
      )}

      <p>Common countable income sources to {hcb ? 'total up' : 'list'}:</p>
      <ul>
        <li>Social Security retirement or disability benefits</li>
        <li>Railroad Retirement Board benefits</li>
        <li>Pension (private employer or government)</li>
        <li>VA pension and compensation (see VA caveat below)</li>
        <li>Annuity payments</li>
        <li>Required Minimum Distributions (RMDs) from retirement accounts</li>
        <li>Any other recurring monthly payment the applicant receives that is countable for Medicaid eligibility</li>
      </ul>

      {hcb ? (
        <div class="kit-callout kit-callout--warning">
          <p style="font-weight: 600; margin-bottom: 6pt;">VA and other special benefits</p>
          <p style="margin-bottom: 0;">
            Some benefits — such as VA aid and attendance, housebound allowances, and reimbursements for unusual or
            continuing medical expenses — are treated differently from ordinary income in Medicaid budgeting. Before
            you decide how much to deposit, confirm with {state.agencyAbbreviation} which of the applicant's payments
            actually count toward the HCB income maximum. Only countable income above the maximum needs to go into the
            trust, so a benefit that does not count toward the maximum does not belong in the trust account.
          </p>
        </div>
      ) : (
        <div class="kit-callout kit-callout--warning">
          <p style="font-weight: 600; margin-bottom: 6pt;">VA aid and attendance caveat</p>
          <p style="margin-bottom: 0;">
            {state.agencyAbbreviation} {state.policyCitationShort} specifies that VA aid and attendance benefits, housebound
            allowances, and reimbursements for unusual or continuing medical expenses are <strong>exempt</strong>
            from both Medicaid eligibility and the co-payment calculation. <strong>Do not deposit these specific
            benefits into the QIT account</strong> — depositing them makes them countable for the co-payment
            budget. If the applicant receives a VA pension that includes these benefits, separate the aid and
            attendance, housebound, or unusual-medical-expense portion before depositing the rest of the VA pension
            into the QIT.
          </p>
        </div>
      )}

      <p>
        For each countable source you {hcb ? 'total' : 'list'}, write the source name (e.g., "Social Security Administration") and
        the monthly amount (gross, before any deductions). Pull these numbers from the most recent benefit-award
        letter or statement for each source.
      </p>

      <div class="kit-no-break">
        <h3>4. Residual beneficiary</h3>
        <p>
          Federal law requires the QIT to name the state Medicaid agency as the residual beneficiary
          <strong> up to the total amount of medical assistance paid on the applicant's behalf</strong>. The
          {state.agencyAbbreviation} template contains this clause pre-drafted. <strong>Do not edit, weaken,
          or remove it</strong> — a defective residual-beneficiary clause is a documented denial cause
          (Section 7).
        </p>
        <p>
          Anything remaining after the state's recovery passes to whatever party the template's secondary
          residual clause names. Some state templates leave this blank for the trustor to fill in (e.g.,
          children, named family members); others default to the applicant's probate estate. Read the
          template's instructions on this point. If you are unsure who to name, leave the field as the
          template's default — secondary residual designations are an estate-planning decision, not a
          Medicaid-qualification decision, and you can address them later without delaying eligibility.
        </p>
      </div>

      <h3>5. Signature, date, and witnessing</h3>
      <p>
        The trust must be signed by the applicant (or by the trustee acting under a valid POA for the applicant)
        and dated. Witnessing requirements vary by template — follow the template's own signature block. Most
        {' '}{state.agencyAbbreviation} templates require either a notary or two witnesses. <strong>Sign and date
        in the same calendar month you intend to fund the trust.</strong>
      </p>
    </section>

    {/* ============================ SECTION 4 ============================ */}
    <section id="section-4" class="kit-page-break">
      <p class="kit-eyebrow kit-section-title">Section 4 &middot; The monthly funding worksheet</p>
      <h1>The monthly funding worksheet</h1>

      <p>
        Use this worksheet to determine exactly how much income to redirect into the QIT each month. The worksheet
        is the same for every {state.name} buyer because the {state.agencyAbbreviation} math is the same; you fill
        in your family's specific numbers in the right column.
      </p>

      <table class="kit-worksheet">
        <thead>
          <tr>
            <th style="width: 60%;">Line</th>
            <th>Amount</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td><strong>A.</strong> Applicant's monthly income — Social Security (gross, before Medicare premium)</td>
            <td class="kit-fillable">$ ______</td>
          </tr>
          <tr>
            <td><strong>B.</strong> Applicant's monthly income — pension</td>
            <td class="kit-fillable">$ ______</td>
          </tr>
          <tr>
            <td><strong>C.</strong> Applicant's monthly income — VA benefits</td>
            <td class="kit-fillable">$ ______</td>
          </tr>
          <tr>
            <td><strong>D.</strong> Applicant's monthly income — annuity, RMD, other recurring</td>
            <td class="kit-fillable">$ ______</td>
          </tr>
          <tr>
            <td><strong>E. Total countable monthly income</strong> (A + B + C + D)</td>
            <td class="kit-fillable">$ ______</td>
          </tr>
          {hcb ? (
            <Fragment>
              <tr>
                <td><strong>F.</strong> {state.name} HCB income maximum (per applicant)</td>
                <td>${fmt(state.incomeCap2026)}</td>
              </tr>
              <tr>
                <td><strong>G.</strong> Amount above the maximum (E − F). If negative or zero, you do not need a QIT — see "When you do <em>not</em> need a QIT" below.</td>
                <td class="kit-fillable">$ ______</td>
              </tr>
              <tr>
                <td><strong>H.</strong> Amount to move into the trust each month — the excess over the maximum (line G). Keep the rest of your income (up to line F) in your own name.</td>
                <td class="kit-fillable">$ ______</td>
              </tr>
              <tr>
                <td><strong>I.</strong> Amount the trustee spends this month on the applicant's own allowable medical/care costs (e.g., a Medicare premium, uncovered care)</td>
                <td class="kit-fillable">$ ______</td>
              </tr>
              <tr>
                <td><strong>J.</strong> Allowable trustee/bank fees (trustee fee capped at the lesser of 3% of line H or $10)</td>
                <td class="kit-fillable">$ ______</td>
              </tr>
              <tr>
                <td><strong>K.</strong> Accumulated income carried in the trust (H − I − J), to be spent on the applicant's care over time</td>
                <td class="kit-fillable">$ ______</td>
              </tr>
            </Fragment>
          ) : (
            <Fragment>
              <tr>
                <td><strong>F.</strong> {state.name} 2026 income cap (single applicant)</td>
                <td>${fmt(state.incomeCap2026)}</td>
              </tr>
              <tr>
                <td><strong>G.</strong> Amount above the cap (E − F). If negative or zero, you do not need a QIT — see "When you do <em>not</em> need a QIT" below.</td>
                <td class="kit-fillable">$ ______</td>
              </tr>
              <tr>
                <td><strong>H.</strong> Minimum amount to deposit into QIT each month (G — but most attorneys recommend depositing all of line E to simplify accounting)</td>
                <td class="kit-fillable">$ ______</td>
              </tr>
              <tr>
                <td><strong>I.</strong> Personal Needs Allowance distribution from QIT to applicant</td>
                <td>${fmt(state.personalNeedsAllowance)}</td>
              </tr>
              <tr>
                <td><strong>J.</strong> Spousal allowance distribution from QIT to community spouse (if applicable; see {state.spousalCalcRef} for the calculation)</td>
                <td class="kit-fillable">$ ______</td>
              </tr>
              <tr>
                <td><strong>K. Patient liability / share of cost</strong> distribution from QIT to nursing facility (H − I − J)</td>
                <td class="kit-fillable">$ ______</td>
              </tr>
            </Fragment>
          )}
        </tbody>
      </table>

      <h3>How to read the result</h3>
      {hcb ? (
        <ul>
          <li>
            <strong>Line H</strong> — the excess over the HCB maximum — is all that goes into the trust account each
            month (see Section 6). Everything up to line F stays in the applicant's own account.
          </li>
          <li>
            <strong>Line I</strong> is what the trustee pays out of the trust for the applicant's own allowable
            medical and care costs.
          </li>
          <li>
            <strong>Line K</strong> is income the trust holds and carries forward to spend on the applicant's care
            later — there is no payment to a facility, because HCB care is provided at home.
          </li>
        </ul>
      ) : (
        <ul>
          <li>
            <strong>Line H</strong> is what hits the QIT bank account each month. Direct-deposit your income sources
            here (see Section 6 for the redirect process).
          </li>
          <li>
            <strong>Line I</strong> goes back to the applicant for personal expenses. The trustee can issue this as
            a check or a monthly transfer.
          </li>
          <li>
            <strong>Line K</strong> is the check the trustee writes to the nursing facility each month for the
            applicant's share of the cost of care. Medicaid covers the remainder.
          </li>
        </ul>
      )}

      <div class="kit-no-break">
        <h3>Gross income — and how the Medicare premium fits</h3>
        {hcb ? (
          <Fragment>
            <p>
              Two questions come up here constantly, so let's answer them head-on.
            </p>
            <p>
              <strong>Do I count income gross or net?</strong> Gross. Compare each source at its
              <strong> full, before-deductions amount</strong> to the HCB maximum. Enter Social Security on
              line&nbsp;A at the <em>gross</em> benefit — the figure before the Medicare Part&nbsp;B premium is
              withheld — so the excess on line&nbsp;G is measured against gross income, not a net figure.
            </p>
            <p>
              <strong>So where does the Medicare premium fit?</strong> A health-insurance premium such as Medicare
              Part&nbsp;B is one of the applicant's <em>allowable</em> costs the trust can pay from the excess it
              holds — it is not a way to shrink the amount you deposit. Use gross figures to work out the excess
              (line&nbsp;G); the trustee can then apply trust funds toward the applicant's allowable medical costs,
              including insurance premiums. {state.agencyAbbreviation} confirms which income counts toward the HCB
              maximum on the eligibility determination.
            </p>
          </Fragment>
        ) : (
          <Fragment>
            <p>
              Two questions come up here constantly, so let's answer them head-on.
            </p>
            <p>
              <strong>Do I count income gross or net?</strong> Gross. Medicaid counts each source at its
              <strong> full, before-deductions amount</strong>. Enter your Social Security on line&nbsp;A at the
              <em>gross</em> benefit — the figure before the Medicare Part&nbsp;B premium is withheld — and every other
              source at its gross amount too. That is why line&nbsp;A reads "gross, before Medicare premium."
            </p>
            <p>
              <strong>So where does the Medicare premium go?</strong> It is <em>not</em> subtracted before you fund the
              trust. You deposit the gross income; the health-insurance premium (Medicare Part&nbsp;B, or any other) is
              handled <strong>later</strong>, as an allowable deduction in the monthly distribution order — it is paid
              out of the trust <em>before</em> the patient-liability share. The federal post-eligibility rules
              (42&nbsp;CFR&nbsp;§§&nbsp;435.725–435.726) list health-insurance premiums as a permitted deduction. In
              practice, because Social Security often already has the Part&nbsp;B premium withheld before the check
              arrives, your {state.agencyAbbreviation} eligibility worker reconciles the exact monthly figures when
              they set your post-eligibility budget. Use gross figures on this worksheet; the worker confirms the final
              numbers.
            </p>
          </Fragment>
        )}
      </div>

      <h3>When you do <em>not</em> need a QIT</h3>
      <p>
        If line G is zero or negative — the applicant's total income is at or below ${fmt(state.incomeCap2026)}/month
        — the applicant is already income-eligible for {hcb ? `${state.name}'s HCB waiver` : `${state.name} long-term-care Medicaid`} without a QIT. You can
        skip this kit and proceed directly to the Medicaid application. Most families who reach this kit are
        above the {hcb ? 'maximum' : 'cap'} (often only by a few hundred dollars per month from Social Security cost-of-living increases),
        but verify before you set up a trust you may not need.
      </p>
    </section>

    {/* ============================ SECTION 5 ============================ */}
    <section id="section-5" class="kit-page-break">
      <p class="kit-eyebrow kit-section-title">Section 5 &middot; The bank-account walkthrough</p>
      <h1>The bank-account walkthrough</h1>

      <p>
        This is the section where most families get stuck. The mechanical reason: most retail bank branches have
        never opened a Qualified Income Trust account. The branch manager opens the same five or six account types
        every day; a QIT is not one of them. The first attempt is usually refused, not because there is anything
        wrong with the trust, but because the branch's account-opening system does not have a matching template.
      </p>

      <p>
        This section gives you the script, the documents, and the escalation path to open the account on your
        first or second visit. <strong>Read it before you walk into the bank.</strong>
      </p>

      <h3>Before you go: documents to bring</h3>
      <ul>
        <li><strong>The signed trust document</strong> — original or notary-certified copy, executed in the same calendar month you intend to fund the trust.</li>
        <li><strong>The applicant's Social Security card.</strong> The account is titled in the name of the trust but uses the applicant's SSN for IRS purposes (see "EIN" below).</li>
        <li><strong>The applicant's government-issued photo ID</strong> — driver's license, state ID, or passport.</li>
        <li><strong>The trustee's photo ID.</strong></li>
        <li><strong>Power of attorney documentation</strong> if the trustee is opening the account under POA for the applicant.</li>
        <li>
          <strong>A printed copy of the relevant {state.agencyAbbreviation} policy section</strong>
          ({state.policyManualSection}). Print pages 1–2 of the relevant section so you can hand them across the
          counter if needed.
        </li>
        <li><strong>The bank-refusal resolution letter</strong> at the end of this section, printed and ready to use.</li>
      </ul>

      <h3>On the EIN question</h3>
      {state.einRequired ? (
        <div class="kit-callout kit-callout--warning">
          <p>
            <strong>{state.name}'s trust is set up to file its own fiduciary tax return, so it generally needs its
            own EIN.</strong> {state.einRequiredNote} You can obtain the EIN online at the IRS (irs.gov) before your
            bank visit — the process takes about ten minutes and is free.
          </p>
        </div>
      ) : (
        <div class="kit-callout">
          <p>
            <strong>No EIN is required.</strong> {state.einRequiredNote} If the branch insists on an EIN, hand them
            the printed {state.agencyAbbreviation} policy section and ask the branch manager to escalate to the
            bank's trust department.
          </p>
        </div>
      )}

      <h3>The opening script</h3>
      <p>
        Use this verbatim at the counter. It establishes that the trust is authorized, that you know what you're
        asking for, and that the branch is dealing with an informed customer.
      </p>

      <div class="kit-callout">
        {hcb ? (
          <p style="font-style: italic;">
            "I'd like to open a checking account in the name of an irrevocable trust. The trust is a Qualified
            Income Trust authorized under {state.name} Medicaid policy ({state.policyManualSection}) and federal
            law at {state.federalStatuteCitation}. I have the trust document signed and dated. I'd like the
            account titled exactly as the trust is named, with the {' '}
            {state.einRequired ? 'EIN' : "applicant's Social Security number"} on file for IRS reporting. The
            trustee — not the applicant — is the only authorized signer. If your bank requires a small opening
            deposit to open the account, that's fine. After that, only the portion of the applicant's income
            above the state's income maximum will be deposited to this account."
          </p>
        ) : (
          <p style="font-style: italic;">
            "I'd like to open a checking account in the name of an irrevocable trust. The trust is a Qualified
            Income Trust authorized under {state.name} Medicaid policy ({state.policyManualSection}) and federal
            law at {state.federalStatuteCitation}. I have the trust document signed and dated. I'd like the
            account titled exactly as the trust is named, with the {' '}
            {state.einRequired ? 'EIN' : "applicant's Social Security number"} on file for IRS reporting. The
            trustee is the only authorized signer. If your bank requires a small opening deposit to open the
            account, that's fine — {state.agencyAbbreviation} expressly allows the standard $10–$20 opening
            deposit banks ask for. After that, only the applicant's listed income will be deposited to this
            account."
          </p>
        )}
      </div>

      {!hcb && (
        <p class="kit-cite">
          Source for the opening-deposit allowance: {state.agencyAbbreviation} {state.policyCitationShort}.
        </p>
      )}

      <h3>The five most common refusals — and how to respond</h3>

      {state.bankRefusalNotes.map((note, i) => (
        <div class="kit-callout kit-no-break" style="margin-top: 16pt;">
          <p style="font-weight: 600;">Refusal {i + 1}: {note.refusalType}</p>
          <p style="margin-bottom: 0;">{note.response}</p>
          {note.documentNeeded && (
            <p style="margin-top: 6pt; font-size: 9pt; color: #6B7280;">
              <strong>Document to bring:</strong> {note.documentNeeded}
            </p>
          )}
        </div>
      ))}

      <h3>If the branch still won't open the account</h3>
      <p>
        You have three escalation paths, in order of preference:
      </p>
      <ol>
        <li>
          <strong>Ask for the bank's trust department.</strong> Larger banks (Chase, Wells Fargo, Bank of America)
          have centralized trust departments that handle non-standard account types. The branch manager can submit
          an internal request; turnaround is typically 24–48 hours.
        </li>
        <li>
          <strong>Ask for a full-service branch.</strong> Some retail branches are limited to standard consumer
          accounts. A full-service branch (often the main branch of the local market) opens commercial and
          trust-style accounts routinely.
        </li>
        <li>
          <strong>Switch banks.</strong> Community banks and credit unions are often more willing than retail
          megabanks because their account-opening process involves a human review rather than a screen-driven
          template. Call ahead and ask: "Do you open Qualified Income Trust accounts for {state.name} Medicaid
          applicants?" If the answer is anything other than an immediate yes, call the next bank on your list.
        </li>
      </ol>

      <h3>Resolution letter for the branch manager</h3>
      <p>
        If the branch escalates internally, hand the manager the letter below. Print it on a clean sheet and bring
        it with you. It restates the policy citation in a form the branch's legal/compliance team can verify
        independently.
      </p>

      <div class="kit-callout kit-callout--rule">
        <p style="font-style: italic;">
          To: Branch Manager<br />
          From: [Trustee name], Trustee for the [Applicant name] Qualified Income Trust<br />
          Date: [Date]<br />
          Re: Account opening for {state.name} Medicaid Qualified Income Trust
        </p>
        <p style="font-style: italic;">
          I am the trustee of an irrevocable Qualified Income Trust drafted on the official template published by
          {' '}{state.agencyName} ({state.agencyAbbreviation}). The trust is authorized under federal law at
          {' '}{state.federalStatuteCitation} and {state.name} state policy at {state.agencyAbbreviation}
          {' '}{state.policyManualSection}.
        </p>
        {hcb ? (
          <Fragment>
            <p style="font-style: italic;">
              I am requesting a checking account opened in the name of the trust, with me — the trustee, who is not
              the beneficiary — as the sole authorized signer. If your bank requires a small opening deposit to open
              a new account, that is acceptable; those are the applicant's own funds. The account is generally set up
              using the applicant's Social Security number, and the trust holds only the applicant's income.
            </p>
            <p style="font-style: italic;">
              After the account is open, the trust will receive only the portion of the applicant's monthly income
              that exceeds the state's income maximum, and I will spend it only on the applicant's own allowable
              medical and care costs under {state.name} Medicaid rules. No third parties have access to the account,
              and I am the only authorized signer.
            </p>
          </Fragment>
        ) : (
          <Fragment>
            <p style="font-style: italic;">
              I am requesting a checking account opened in the name of the trust, with me as the sole authorized
              signer. If your bank requires a small opening deposit to open a new account, that is acceptable —
              {' '}{state.agencyAbbreviation} {state.policyCitationShort} expressly allows the standard $10–$20 opening deposit
              banks require and states it is not counted as a resource or income to the beneficiary. {state.einRequired
                ? `Because ${state.name}'s trust files its own fiduciary tax return, I have obtained a separate EIN for the trust from the IRS and have provided it with this letter.`
                : `Per ${state.agencyAbbreviation} ${state.policyCitationShort}, the QIT account is set up using the applicant's Social Security number — no separate EIN is required.`}
            </p>
            <p style="font-style: italic;">
              After the account is open, the trust will receive only the applicant's monthly Medicaid-countable
              income and disburse the Personal Needs Allowance, any spousal allowance, and the patient-liability
              share of care to the applicant's nursing facility, all by the last day of the month following each
              deposit. No third parties have access to the account; the account balance returns to near zero each
              month after distributions.
            </p>
          </Fragment>
        )}
        <p style="font-style: italic;">
          The signed trust document, my photo ID, the applicant's Social Security card, and a printed copy of the
          relevant {state.agencyAbbreviation} policy section are attached. Please contact your trust department
          if internal escalation is required. I am available at the contact information above for any follow-up.
        </p>
        <p style="font-style: italic;">
          Thank you,<br />
          [Trustee signature]
        </p>
      </div>
    </section>

    {/* ============================ SECTION 6 ============================ */}
    <section id="section-6" class="kit-page-break">
      <p class="kit-eyebrow kit-section-title">Section 6 &middot; Funding the trust month by month</p>
      <h1>Funding the trust month by month</h1>

      <p>
        Opening the account is the hard part. Keeping it funded correctly is mostly clerical work, but the
        clerical work has to happen <strong>every month, without missing a month</strong>. A missed funding month
        is a denied month of Medicaid coverage — there is no make-up provision.
      </p>

      <h3>Redirecting income sources to the QIT account</h3>
      <p>
        Once the QIT account is open, each income source listed in the trust needs to be redirected so it
        deposits into the QIT instead of the applicant's personal account. The redirect process differs by source.
      </p>

      <h4>Social Security</h4>
      <p>
        Submit a direct-deposit change request through one of three channels:
      </p>
      <ul>
        <li>Online at <a href="https://www.ssa.gov/myaccount/">ssa.gov/myaccount</a> — fastest, takes one to two business days to process.</li>
        <li>By phone with SSA — call your local SSA office (the national 800 line is also available; see ssa.gov for current numbers).</li>
        <li>By mail using SSA Form SF-1199A — typically two to three weeks to process.</li>
      </ul>
      <p>
        You will need the QIT account's routing and account numbers. Have the bank-issued direct-deposit
        confirmation slip on hand when you submit the request.
      </p>

      <h4>Pension and annuity</h4>
      <p>
        Each pension administrator has its own direct-deposit change form. Contact the plan administrator (the
        phone number is on the pension statement) and request the form. Most pensions process the change within
        one full pay cycle.
      </p>

      <h4>VA benefits</h4>
      <p>
        Update direct deposit through VA at <a href="https://www.va.gov/change-direct-deposit/">va.gov/change-direct-deposit</a>
        or by calling VA. The VA also accepts mailed forms.
      </p>

      <div class="kit-no-break">
        <h3>The first month — what to expect</h3>
        {hcb ? (
          <Fragment>
            <p>
              The first month is the most error-prone because income redirects rarely process in time. What matters in
              {' '}{state.name} is that the excess over the HCB maximum reaches the trust account in the month the
              income is received (or within 10 days if fewer than 10 days remain), so the applicant's remaining
              countable income is below the maximum for that month.
            </p>
            <ul>
              <li>
                <strong>Move the excess in the same month.</strong> If a redirect has not processed yet, transfer the
                over-the-maximum amount into the trust manually from the applicant's account, in the same calendar
                month the income is received. Do not assign the income to the trust as payee — move it by deposit or
                transfer.
              </li>
              <li>
                <strong>Keep the rest in the applicant's own name.</strong> Only the excess needs to move; income up
                to the HCB maximum stays with the applicant. Every following month, deposit at least that month's
                excess.
              </li>
            </ul>
          </Fragment>
        ) : (
          <Fragment>
            <p>
              The first month is the most error-prone because income redirects rarely process in time. Two important
              accommodations {state.agencyAbbreviation} makes for the initial month:
            </p>
            <ul>
              <li>
                <strong>A partial deposit in the initial month is allowed.</strong> If only part of an income source
                made it into the QIT in the first month — for example, the applicant already paid some bills before
                the trust was established — the QIT is still valid and the entire amount of that income source is
                disregarded from countable income for that month.
              </li>
              <li>
                <strong>In every month after the initial month, the entire listed source must be deposited.</strong>
                A partial deposit of a listed source in any non-initial month invalidates the QIT for that month.
              </li>
            </ul>
          </Fragment>
        )}
      </div>
      <p>
        Most families also manually transfer the first month's income into the QIT from the applicant's personal
        account in the same calendar month the trust is signed, to start the eligibility clock without waiting
        for the direct-deposit redirect to complete. Document any manual transfer with a memo line that
        identifies it as the QIT funding deposit for that month.
      </p>

      {hcb ? (
        <Fragment>
          <h3>The monthly funding and spending rule</h3>
          <p>
            <strong>The deadline that controls eligibility is the deposit, not a distribution date.</strong> Each
            month the excess over the HCB maximum must reach the trust account in the month the income is received
            (or within 10 days if fewer than 10 days remain). The trustee then spends the trust only on the
            applicant's allowable medical and care costs; unlike a nursing-facility trust, {state.name} lets the
            trust hold accumulated income to spend on the applicant's care over time, so there is no rule that the
            account must be emptied by month-end.
          </p>

          <div class="kit-callout kit-callout--warning">
            <p>
              <strong>Keep every payment inside the allowed list.</strong> A distribution that is not for the
              applicant's own allowable benefit can affect eligibility unless the trustee restores the funds, and
              every deposit and payment must be captured in the trust's monthly accounting, which
              {' '}{state.agencyAbbreviation} can request at the annual review. Just as important: if a month's excess
              is not deposited, the applicant is over-income for that month.
            </p>
          </div>
        </Fragment>
      ) : (
        <Fragment>
          <h3>The monthly distribution rule</h3>
          <p>
            <strong>Income deposited into the QIT account must be distributed by the last day of the following month.</strong>
            If income is deposited in March, the trustee has until April 30 to make the required distributions. This is
            the controlling deadline — not the end of the same month.
          </p>

          <div class="kit-callout kit-callout--warning">
            <p>
              <strong>Late distribution is treated as a transfer of assets.</strong> Per {state.agencyAbbreviation},
              if the trustee fails to distribute income deposited into the QIT account by the end of the following
              month, the failure is considered a transfer of assets. Transfers of assets can trigger a Medicaid
              penalty period (a period of ineligibility for benefits). Set a recurring monthly reminder to make
              distributions on the same day each month — well before the next-month deadline.
            </p>
          </div>
        </Fragment>
      )}

      <div class="kit-no-break">
        <h3>The monthly checklist</h3>
        {hcb ? (
          <Fragment>
            <p>Each month, the trustee should have:</p>
            <ol>
              <li>Moved the excess over the HCB maximum into the trust account, in the month the income was received (check the bank statement).</li>
              <li>Confirmed the applicant kept their income up to the HCB maximum in their own account.</li>
              <li>Spent trust funds only on the applicant's own allowable medical and care costs (and any allowable trustee or bank fee).</li>
              <li>Recorded every deposit and payment in the trust's monthly accounting.</li>
              <li>Saved the bank statement and any check copies in the trustee's monthly file (see Appendix B).</li>
            </ol>

            <p>
              Unlike a nursing-facility trust, the account is not expected to zero out each month — {state.name} lets
              the trust hold accumulated income to spend on the applicant's care over time. Keep every payment inside
              the allowable list, and keep the records current for {state.agencyAbbreviation}'s annual review.
            </p>
          </Fragment>
        ) : (
          <Fragment>
            <p>By the last day of the month following each deposit, the trustee should have:</p>
            <ol>
              <li>Confirmed the month's income deposited into the QIT account (check the bank statement).</li>
              <li>Distributed the Personal Needs Allowance (${fmt(state.personalNeedsAllowance)}) to the applicant.</li>
              <li>Distributed any spousal allowance (the Minimum Monthly Maintenance Needs Allowance, where applicable) to the community spouse.</li>
              <li>Distributed any court-ordered guardianship fees, if applicable.</li>
              <li>Distributed the cost of medical assistance (patient liability / share of cost) to the nursing facility.</li>
              <li>Saved the bank statement and any check copies in the trustee's monthly file (see Appendix B).</li>
            </ol>

            <p>
              After required distributions, the account should return to a near-zero balance. A residual balance of
              a few cents to a few dollars is normal and acceptable. Any residual amount left after the required
              distributions may be applied to the cost of trust administration — but {state.agencyAbbreviation}
              does not allow deductions for trust administration costs when computing the beneficiary's share of
              cost.
            </p>
          </Fragment>
        )}

        <h3>What happens if a month's income is not deposited</h3>
        <p>
          If a month's income is not deposited into the QIT (e.g., the redirect didn't process and the income
          landed in the applicant's personal account), {state.agencyAbbreviation} will count the income as the applicant's for that
          month, and the applicant will be income-ineligible for that month. Coverage for that month is denied.
          You cannot cure the month by transferring the money later — the deposit must have occurred in the
          calendar month the income was received.
        </p>

        <p>
          Resume normal funding the following month and the applicant's eligibility resumes for that month. The
          lost month is usually {hcb ? "paid out of pocket for the applicant's care" : 'billed at private-pay rates by the nursing facility'}.
        </p>
      </div>
    </section>

    {/* ============================ SECTION 7 ============================ */}
    <section id="section-7" class="kit-page-break">
      <p class="kit-eyebrow kit-section-title">Section 7 &middot; Common {state.name} Medicaid denials</p>
      <h1>The {state.commonDenialReasons.length} most common {state.name} Medicaid denials — and how to avoid each</h1>

      <p>
        Most {state.agencyAbbreviation} QIT denials are not substantive eligibility problems — they are technical
        compliance issues with the trust drafting or funding. Each denial cause below is a documented
        {' '}{state.agencyAbbreviation} requirement. Verify each item against your trust before you submit the
        Medicaid application.
      </p>

      <ol>
        {state.commonDenialReasons.map((r) => (
          <li class="kit-no-break" style="margin-bottom: 14pt;">
            <p style="font-weight: 600; margin-bottom: 4pt;">{r.title}</p>
            <p style="margin-bottom: 2pt;">{r.description}</p>
            <p class="kit-cite">Citation: {r.agencyCitation}</p>
          </li>
        ))}
      </ol>

      {/* Heading + intro + checklist box kept on one page. The hN+p break-after
          CSS rule alone was unreliable here because the 11-item callout is tall:
          it would jump to the next page (break-inside:avoid) and strand the
          heading+intro. Wrapping the trio in .kit-no-break moves them together. */}
      <div class="kit-no-break">
      <h3>Pre-submission checklist</h3>
      <p>Run this checklist the day before you file the Medicaid application:</p>
      <div class="kit-callout">
        <ul style="margin-bottom: 0;">
          <li>Trust signed and dated in the calendar month you intend coverage to begin (or earlier, if relying on the up-to-three-month retroactive disregard).</li>
          <li>Trust is irrevocable on its face — and the irrevocability is not contingent on court action.</li>
          <li>QIT account opened in the name of the trust, using the applicant's SSN (or EIN if your state requires one).</li>
          <li>Initial-month deposit visible on the QIT bank statement — a partial first-month deposit is acceptable; no deposit at all is not.</li>
          <li>Reversion (residuary beneficiary) clause names the State of {state.name} as the residuary up to total Medicaid assistance paid (verify the {state.agencyAbbreviation} template's pre-drafted language is intact).</li>
          {hcb ? (
            <li>At least the excess over the HCB income maximum is moved into the trust each month, in the month it is received (income up to the maximum stays in the applicant's own name).</li>
          ) : (
            <li>Every income source listed in the trust is direct-deposited to the QIT (full source amount each month after the initial month).</li>
          )}
          <li>No resources have been deposited into the QIT account (income only).</li>
          <li>VA aid &amp; attendance / housebound / unusual-medical-expense reimbursements are <em>not</em> being deposited to the QIT (see Section 3).</li>
          <li>Trustee selection is consistent with {state.agencyAbbreviation} guidance (see Section 3).</li>
          <li>Trust uses the current {state.agencyAbbreviation} template, downloaded fresh on the day of signing.</li>
          <li>Trustee has a monthly distribution reminder set to ensure deposits are distributed by the last day of the following month.</li>
        </ul>
      </div>
      </div>
    </section>

    {/* ============================ SECTION 8 ============================ */}
    <section id="section-8" class="kit-page-break">
      <p class="kit-eyebrow kit-section-title">Section 8 &middot; Post-death distribution</p>
      <h1>What happens to the QIT when the applicant dies</h1>

      <p>{state.postDeathDistribution}</p>

      <h3>The trustee's duties on death</h3>
      <ol>
        <li>
          <strong>Notify {state.agencyAbbreviation}</strong> of the applicant's death within the timeframe the
          agency requires (typically 10–30 days). The agency will send a final accounting request.
        </li>
        <li>
          <strong>Stop further deposits.</strong> The trust no longer needs new income — the applicant is no
          longer eligible after death. Contact each income source (SSA, pension, VA) to stop direct deposits to
          the QIT. SSA, in particular, will request return of any post-death payments.
        </li>
        {hcb ? (
          <li>
            <strong>Complete any allowable spending for the partial month of death</strong> — the trustee may still
            pay the applicant's own allowable medical and care costs for that month per the form and
            {' '}{state.agencyAbbreviation} guidance — then make no further distributions until the State's claim is resolved.
          </li>
        ) : (
          <li>
            <strong>Distribute the Personal Needs Allowance and patient liability for the partial month of death</strong>
            per normal procedure, prorated as the trust instrument or {state.agencyAbbreviation} guidance directs.
          </li>
        )}
        <li>
          <strong>Wait for {state.agencyAbbreviation}'s final accounting</strong> showing the total Medicaid
          benefits paid on the applicant's behalf. Do not distribute any remaining trust balance until you have
          that accounting in writing.
        </li>
        <li>
          <strong>Pay {state.agencyAbbreviation} the residual balance</strong> up to the total of medical
          assistance paid. {state.residuaryPaymentNote}
        </li>
        <li>
          <strong>Distribute any remainder</strong> to the secondary residual beneficiary named in the trust.
        </li>
        <li>
          <strong>Close the QIT bank account</strong> after all distributions are complete and
          {' '}{state.agencyAbbreviation} confirms the trust has satisfied its obligations.
        </li>
      </ol>

      <p class="kit-cite">
        Source: {state.agencyAbbreviation} {state.policyCitationShort} (reversion clause).
        {state.residuaryFormUrl && (
          <Fragment>
            {' '}{state.residuaryFormName} reference:
            {' '}<a href={state.residuaryFormUrl}>{state.residuaryFormUrl}</a>
          </Fragment>
        )}
      </p>

      <div class="kit-no-break">
        <h3>On estate recovery generally</h3>
        <p>
          The QIT residual-beneficiary clause is one piece of the larger Medicaid estate-recovery framework.
          {' '}{state.name}, like every state, has the right to seek recovery of Medicaid spending from the
          applicant's estate (the assets owned at death). Estate recovery rules are fact-intensive and vary by
          situation: homestead protections, surviving-spouse exemptions, dependent-relative exemptions, and
          hardship waivers all interact with the analysis.
        </p>

        <div class="kit-callout kit-callout--warning">
          <p>
            <strong>This kit does not address estate recovery beyond the QIT's own distribution clause.</strong>
            If the applicant owns a home, has assets outside the QIT, or has a surviving spouse with potential
            estate interests, consult a {state.name}-licensed elder-law attorney for the estate-recovery
            analysis. The State Bar of {state.name} referral service is below.
          </p>
        </div>
      </div>
    </section>

    {/* ============================ SECTION 9 ============================ */}
    <section id="section-9" class="kit-page-break">
      <p class="kit-eyebrow kit-section-title">Section 9 &middot; When to call an attorney</p>
      <h1>When to call an attorney — and how to find one</h1>

      <p>
        This kit handles the operational mechanics of setting up a {state.name} Qualified Income Trust. It does
        not handle situations that require legal judgment applied to specific facts. The list below is not
        exhaustive, but it covers the situations we see most often where a {state.name}-licensed elder-law
        attorney is the right call.
      </p>

      <h3>Call an attorney if any of these apply</h3>
      <ul>
        <li>
          <strong>The applicant has trusts other than the QIT</strong> — revocable living trusts, special needs
          trusts, irrevocable Medicaid asset protection trusts, or any other trust structure. The interaction
          between trusts is fact-specific and frequently changes Medicaid analysis.
        </li>
        <li>
          <strong>The applicant has made gifts or transferred assets in the last five years</strong> — to
          children, to a charity, to anyone for less than fair-market value. This implicates the 60-month
          look-back period and may trigger a transfer penalty (a period of Medicaid ineligibility).
        </li>
        <li>
          <strong>The applicant has assets above the countable resource limit</strong>{' '}
          {hcb
            ? '(for Missouri’s HCB waiver this is $6,220.50 for a single applicant, $12,441.00 for a couple where both are HCB-eligible)'
            : '(generally $2,000 for a single applicant)'}. Asset spend-down planning is separate from the QIT and often requires legal
          structuring (irrevocable trusts, annuities, exempt-asset purchases) that should be done with counsel.
        </li>
        <li>
          <strong>The applicant is married and one spouse is staying at home</strong> (the "community spouse").
          Married couples have an extra layer of Medicaid rules — the Community Spouse Resource Allowance and the
          Minimum Monthly Maintenance Needs Allowance — that protect the at-home spouse. See the dedicated
          community-spouse guidance immediately below.
        </li>
        <li>
          <strong>The applicant owns a home (homestead)</strong> and there is no surviving spouse, dependent
          child, or other exemption-qualifying occupant. Homestead disposition during Medicaid eligibility and
          post-death estate recovery is fact-specific.
        </li>
        <li>
          <strong>The applicant has a complicated income picture</strong> — multiple pensions from different
          countries, rental income, business income, irregular trust distributions, or anything that doesn't fit
          neatly into the worksheet in Section 4.
        </li>
        <li>
          <strong>The Medicaid application has already been denied</strong> for a substantive reason (not a fixable
          drafting error). Appeals require legal posture and statutory deadlines.
        </li>
        <li>
          <strong>You suspect fraud, identity-theft, or any criminal-history issue</strong> in the applicant's
          financial record. This is outside our scope entirely.
        </li>
      </ul>

      <h3>If you are the community spouse — what to know before the attorney visit</h3>
      {hcb ? (
        <p>
          A common married-couple situation is one spouse needing Medicaid-funded care — here, in-home HCB services —
          while the other, the <strong>community spouse</strong>, stays at home. The QIT in this kit solves the
          applicant spouse's <em>income</em> problem. It does not, by itself, address the separate set of federal
          protections built for the community spouse. Those protections are real money, and the kit cannot apply them
          to your numbers — but it can make sure you walk into an attorney consultation already understanding them.
        </p>
      ) : (
        <p>
          The most common married-couple situation is one spouse entering a nursing facility while the other — the
          <strong> community spouse</strong> — stays at home. The QIT in this kit solves the institutionalized
          spouse's <em>income</em> problem. It does not, by itself, address the separate set of federal protections
          built for the community spouse. Those protections are real money, and the kit cannot apply them to your
          numbers — but it can make sure you walk into an attorney consultation already understanding them.
        </p>
      )}

      <p>Two protections do the heavy lifting, both required by federal Medicaid law:</p>
      <ul>
        <li>
          <strong>Community Spouse Resource Allowance (CSRA).</strong> When a married applicant applies for
          long-term-care Medicaid, the couple's countable assets are assessed together — but the community spouse
          is allowed to keep a protected share, the CSRA, rather than spending down to the single-applicant
          $2,000 limit. The federal minimum and maximum CSRA figures are set annually by CMS; your state applies
          them within that federal range. This is an <em>asset</em>-side protection and is entirely separate from
          the QIT.
        </li>
        <li>
          <strong>Minimum Monthly Maintenance Needs Allowance (MMMNA).</strong> If the community spouse's own
          monthly income is low, a portion of the {hcb ? 'applicant' : 'institutionalized'} spouse's income can be directed to the
          community spouse {hcb ? '' : 'rather than paid to the nursing facility '}— so the at-home spouse is not left without
          enough to live on. The MMMNA floor is also set annually by CMS and applied by the state.
        </li>
      </ul>

      <div class="kit-callout">
        <p style="font-weight: 600; margin-bottom: 6pt;">Bring this to your attorney consultation</p>
        <p style="margin-bottom: 6pt;">
          A community-spouse case is fact-specific and is genuine attorney territory — but a prepared client gets
          far more from a 30-minute consultation. Before you go, write down:
        </p>
        <ul style="margin-bottom: 0;">
          <li>Every countable asset the couple owns, with rough current values, and whose name each is in.</li>
          <li>Each spouse's monthly income, by source (Social Security, pension, annuity, VA).</li>
          <li>Whether the home is owned, in whose name, and whether the community spouse will keep living in it.</li>
          <li>The date the {hcb ? 'applicant spouse began (or will begin) Medicaid-funded HCB services' : 'institutionalized spouse entered (or will enter) the facility'} — the asset assessment is tied to that date.</li>
          <li>Any asset transfers or gifts in the last five years (the look-back period applies to couples too).</li>
        </ul>
      </div>

      <p>
        With that information in hand, ask the attorney three questions: <em>what is our CSRA</em>, <em>does the
        community spouse qualify for an MMMNA income diversion</em>, and <em>does the QIT in this kit still cover
        the {hcb ? 'applicant' : 'institutionalized'} spouse's income side</em> (it does — the community-spouse rules sit alongside the
        QIT, they do not replace it). You will typically leave that consultation knowing exactly what to protect
        and exactly which parts you can still handle yourself with this kit.
      </p>

      <h3>How to find a {state.name} elder-law attorney</h3>
      <p>
        The most reliable starting point is the
        {' '}<a href={state.stateBarLrsUrl}>{state.stateBarLrsName}</a>. The referral service matches you with a
        bar-member attorney whose practice includes elder law or Medicaid planning. Most state bar referrals
        offer a low-cost initial consultation (typically $30 for 30 minutes) — enough time to understand whether
        your situation needs full representation or whether a one-time consultation will resolve the question.
      </p>

      <p>
        Two additional national directories are useful as cross-references:
      </p>
      <ul>
        <li>
          <a href="https://www.naela.org/findlawyer">National Academy of Elder Law Attorneys (NAELA) — Find a Lawyer</a>:
          NAELA members specialize in elder law as a practice area. Useful for vetting credentials.
        </li>
        <li>
          <a href="https://www.nelf.org/attorney-directory-search">National Elder Law Foundation (NELF) — Certified Elder Law Attorneys</a>:
          CELA certification is the recognized specialty credential for elder-law practice. CELAs are credentialed
          through a process the ABA accredits.
        </li>
      </ul>

      {state.additionalLegalAidReferrals.length > 0 && (
        <>
          <h3>Low-income legal aid resources {state.agencyAbbreviation} names</h3>
          <p>
            {state.agencyAbbreviation} {state.policyCitationShort} specifically directs people with low or limited income to
            consider the following resources in addition to the state bar referral service:
          </p>
          <ul>
            {state.additionalLegalAidReferrals.map((r) => <li>{r}</li>)}
          </ul>
        </>
      )}

      <p>
        For initial consultations, bring this kit, the worksheet in Section 4 filled in with the applicant's
        actual numbers, and a list of the applicant's assets. The attorney can scan the QIT side in five minutes
        and focus the consultation on whatever is actually complex about your situation.
      </p>
    </section>

    {/* ============================ SECTION 10 =========================== */}
    <section id="section-10" class="kit-page-break">
      <p class="kit-eyebrow kit-section-title">Section 10 &middot; What to say to family members</p>
      <h1>What to say to family members</h1>

      <p>
        Setting up a Miller Trust yourself is a sound, legal choice for a straightforward situation — but it is
        also a choice other family members may question. The most common version: a sibling, often one who lives
        farther away and is less involved in the day-to-day caregiving, asks some form of <em>"shouldn't we just
        hire a lawyer for this?"</em> That question is usually not really about the trust. It is about wanting
        reassurance that the family member in care is protected and that nothing is being done carelessly.
      </p>

      <p>
        This section gives you language to answer it calmly. None of this is legal advice — it is simply a way to
        explain a decision you have already thought through. Use what fits; ignore what doesn't.
      </p>

      <h3>The short answer</h3>
      <div class="kit-callout">
        <p style="font-style: italic; margin-bottom: 0;">
          "I looked into it carefully. A Miller Trust for a straightforward income situation is mostly paperwork
          and one specific kind of bank account — it is built on {state.name}'s own official template, the one
          the state publishes and accepts. I used a step-by-step guide that walks through exactly that, and it is
          cited to {state.agencyAbbreviation} policy throughout. If anything about our situation turns out to be
          complicated — and I know what those red flags are — I will bring in an attorney for that specific part.
          For the trust itself, this is the same work an attorney would do, and I have it covered."
        </p>
      </div>

      <h3>If they push — three honest points</h3>
      <ol>
        <li>
          <strong>This is not the same as "skipping the lawyer."</strong> An elder-law attorney is the right call
          for asset planning, transfers in the last five years, complicated estates, or a married-couple
          resource-allowance question. The Miller Trust itself — diverting income through the state's own
          template so the applicant qualifies — is a defined, repeatable process. Section 9 of this kit lists
          exactly when an attorney <em>is</em> needed, and that list has been checked against our situation.
        </li>
        <li>
          <strong>The cost difference is real and it is the family's money.</strong> An attorney typically
          charges $1,000–$2,500 to set up a Miller Trust. That money either stays available for the applicant's
          care or it doesn't. Choosing to do the defined paperwork ourselves, carefully, is a responsible use of
          the family's resources — not a corner cut.
        </li>
        <li>
          <strong>There is a safety net.</strong> The guide was bought with a money-back guarantee tied to the
          one outcome that matters: if {state.agencyAbbreviation} rejects the trust for a reason traceable to
          following the kit, the purchase is refunded. The downside is bounded.
        </li>
      </ol>

      <h3>When you should agree with the skeptical sibling</h3>
      <p>
        If a family member raises one of the genuine red flags from Section 9 — a recent gift or property
        transfer, assets well above the limit, a second trust, a contested estate — they are right, and the
        answer is not to defend the DIY approach. It is to say: <em>"That is exactly the kind of thing I'd take
        to an attorney, and I will."</em> Using this kit for the trust and an attorney for the genuinely complex
        parts is not a contradiction. It is the plan.
      </p>

      <h3>Keep the focus where it belongs</h3>
      <p>
        Family disagreements about money during a health crisis are rarely about the dollars. If the conversation
        gets heated, it is usually fear talking. The most useful thing you can say is often the simplest:
        <em> "We are all trying to do right by [name]. Here is what I've done, here is why, and here is where I'll
        get help. Look it over with me."</em> Handing a skeptical relative this kit to read is frequently more
        persuasive than any argument — it lets them see the work for themselves.
      </p>
    </section>

