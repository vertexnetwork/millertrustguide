---
import BaseLayout from '~/layouts/BaseLayout.astro';
import ConsentBuyButton from '~/components/ConsentBuyButton.astro';
import ComparisonTable from '~/components/ComparisonTable.astro';
import ReassuranceBlock from '~/components/ReassuranceBlock.astro';
import MoneyBackGuarantee from '~/components/MoneyBackGuarantee.astro';
import PdfPreview from '~/components/PdfPreview.astro';
import StickyBuyBar from '~/components/StickyBuyBar.astro';
import SocialProof from '~/components/SocialProof.astro';
import Testimonial from '~/components/Testimonial.astro';
import TrustStrip from '~/components/TrustStrip.astro';
import LeadMagnetForm from '~/components/LeadMagnetForm.astro';
import InlineLeadCapture from '~/components/InlineLeadCapture.astro';
import LeadCaptureSlideIn from '~/components/LeadCaptureSlideIn.astro';
import ExitIntentModal from '~/components/ExitIntentModal.astro';
import {
  articleSchema,
  faqPageSchema,
  breadcrumbSchema,
  medicalWebPageSchema,
  governmentServiceSchema,
  productSchema,
  howToSchema,
} from '~/lib/schema';
import type { StateData } from '~/content/config';
import { FOUNDER } from '~/config/founder';
import FounderLive from '~/components/FounderLive.astro';
import { firstSentence } from '~/lib/text';
import { REVIEWER } from '~/config/identity';
import { getResolvedTestimonials, orderForState } from '~/lib/testimonials-display';
import { getAllArticleMeta } from '~/lib/articles';

interface Props {
  state: StateData;
}

const { state } = Astro.props;

const canonical = `https://millertrustguide.com/states/${state.slug}`;
const isLive = state.status === 'live';
const blocked = state.status === 'blocked';
const draft = state.status === 'draft';

const fmt = (n: number) => n.toLocaleString('en-US');

// Founder pricing. The display is gated on the operator-maintained
// unitsSold count; Stripe's max-redemptions coupon is the actual charge
// enforcement (see create-checkout.ts). Keep unitsSold current so the
// displayed offer never outlives the coupon.
const sp = state.socialProof;
// GLOBAL founder offer (shared across ALL states) — see src/config/founder.ts.
// founderActive / spotsLeft / displayPrice all read the global counter, so the
// first 25 buyers across the whole site get $99, then every state flips to full
// price together. The shared Stripe coupon enforces the actual charge.
const founderActive = isLive && FOUNDER.unitsSold < FOUNDER.unitLimit;
const founderSpotsLeft = founderActive ? FOUNDER.unitLimit - FOUNDER.unitsSold : 0;
// Founder-aware price for ALL visible price displays (top panel, bottom CTA,
// sticky bar, comparison table) so they stay congruent. Display only; the actual
// charge is server-side (create-checkout: Stripe price + the shared founder coupon).
const displayPrice = founderActive ? FOUNDER.price : state.price;

// Operational long-tail articles for this state (live states only). Linked from
// the body so the deeper queries cluster under the state hub and pass relevance
// back with descriptive, head-term-bearing anchor text.
const articleLinks = isLive ? getAllArticleMeta(state) : [];

// Brand-level proof stack: all switched-on testimonials, THIS state's own first,
// up to six. Each is labeled with its OWN state's badge (honest cross-state
// framing), so one real buyer can provide proof site-wide until each state earns
// its own. Config is 'off' by default; empty → the section is gated out below.
const proofTestimonials = isLive
  ? orderForState(await getResolvedTestimonials(), state.slug, 6)
  : [];

// GEO/AI-citation lede. First ~80 words must directly answer the primary
// query — Princeton GEO + 2026 AI Overview research both prioritize
// answer-first content. We mark this passage as speakable so voice/AI
// assistants can lift it verbatim.
const tldr = blocked
  ? `Miller Trust Guide does not currently publish a kit for ${state.name}. ${state.blockedReason ?? 'For advice on your situation, consult a licensed elder-law attorney in your state.'}`
  : `A ${state.name} Miller Trust (Qualified Income Trust) is an irrevocable trust used to qualify a Medicaid applicant whose monthly income exceeds the ${state.name} long-term-care income cap of $${fmt(state.incomeCap2026)} per month (${state.asOf}). The trust must be drafted, signed, and funded in the same calendar month using the official ${state.agencyAbbreviation} template (${state.policyManualSection}). Medicaid eligibility begins the month the trust is funded — there is no retroactive effect, and every month of delay is another month of full private-pay nursing-home cost ($${fmt(state.privatePayMonthlyLow)}–$${fmt(state.privatePayMonthlyHigh)}/mo in ${state.name}). This guide is the step-by-step operational walkthrough most families need: $${state.price}, instant download, money-back if ${state.agencyAbbreviation} rejects the QIT for a reason traceable to following the kit.`;

// Authoritative citations used in this article — feeds the Article@citation
// JSON-LD array (2026 entity-binding signal).
const citationUrls = [state.officialTemplateUrl, state.policyManualUrl];

// Persona-tuned emphasis line (research-backed personaLean; see
// docs/state-persona-modifiers-research.md). Flexes WHICH fear the page leads
// with — never regional culture (the buyer usually lives out of state). Renders
// only for a state with a verified directional lean; the 8 'balanced' states
// show nothing extra, so their carefully-tuned hero copy is untouched. The
// sentence itself is universally accurate (it doesn't cite a per-state statistic),
// so it stays true even if a lean were later reclassified.
const personaLede =
  state.personaLean === 'community-spouse'
    ? `Is it your husband or wife entering care? This kit handles the income side — the ${state.primaryTerm ?? 'Qualified Income Trust'} — and points you to the separate spousal rules that protect the home and savings you keep as the spouse staying home.`
    : state.personaLean === 'daughter'
      ? `Doing this for a parent? It's the step-by-step way to qualify them before the next facility bill — without paying $1,000–$2,500 for what is, in practice, mostly paperwork.`
      : null;

// ── Long-tail FAQ expansion (ADDITIVE — does not change head-term targeting) ──
// Surfaces vetted per-state frontmatter (EIN, trustee, funding-month, post-death,
// DIY/cost) as query-matched Q&As. These capture the operational long-tail
// searches the kit actually answers — "do you need an EIN for a miller trust",
// "who can be trustee", "when does coverage begin", "without a lawyer" — and feed
// the FAQPage + speakable schema for AI Overviews / "People also ask". Built from
// required frontmatter fields, so every state gets them automatically (pSEO).
const derivedFaq: Array<{ question: string; answer: string }> = [
  {
    question: `Do you need an EIN to open a ${state.name} Miller Trust account?`,
    answer: state.einRequiredNote,
  },
  {
    question: `Who can serve as trustee of a ${state.name} Miller Trust?`,
    answer: state.trusteeGuidanceNote,
  },
  {
    question: `When does ${state.name} Medicaid coverage begin after the Qualified Income Trust is set up?`,
    answer: `Coverage begins the calendar month the QIT is signed, the trust account is opened, and enough of the applicant's income is deposited to bring remaining countable income below the ${state.asOf} special income limit of $${fmt(state.incomeCap2026)}/month — all in the same calendar month. There is no back-dating, so every month of delay is another month of full private-pay care ($${fmt(state.privatePayMonthlyLow)}–$${fmt(state.privatePayMonthlyHigh)}/month in ${state.name}). Source: ${state.agencyAbbreviation} ${state.policyManualSection}.`,
  },
  {
    question: `What happens to the money in a ${state.name} Miller Trust when the beneficiary dies?`,
    answer: state.postDeathDistribution,
  },
  {
    question: `Can you set up a ${state.name} Miller Trust without a lawyer?`,
    answer: `For the core Qualified Income Trust setup, the task is following ${state.agencyAbbreviation}'s publicly-published template and opening a specific kind of bank account — work many families do themselves. Attorneys typically charge $1,000–$2,500 for it. For complex situations (significant assets, prior gifting, second marriages, multi-state property), consult a ${state.name}-licensed elder-law attorney. Miller Trust Guide is informational only and is not legal advice; we do not draft the trust or advise on individual situations.`,
  },
];
const allFaq = [...state.faq, ...derivedFaq];

const jsonLd: object[] = [
  articleSchema({
    headline: state.metaTitle,
    description: state.metaDescription,
    url: canonical,
    dateModified: state.reviewedDate,
    lastReviewed: state.reviewedDate,
    reviewedBy: REVIEWER, // from src/config/identity.ts (null per anonymity doctrine)
    speakableCssSelectors: ['#tldr', '.faq-question', '.faq-answer__lead'],
    citations: citationUrls,
  }),
  medicalWebPageSchema({
    url: canonical,
    name: state.metaTitle,
    description: state.metaDescription,
    dateModified: state.reviewedDate,
    lastReviewed: state.reviewedDate,
    reviewedBy: REVIEWER,
    audience: 'Patient',
  }),
  governmentServiceSchema({
    url: canonical,
    stateName: state.name,
    agencyName: state.agencyName,
    policyManualUrl: state.policyManualUrl,
  }),
  faqPageSchema(allFaq),
  breadcrumbSchema([
    { name: 'Home', url: 'https://millertrustguide.com/' },
    { name: 'State Guides', url: 'https://millertrustguide.com/#states' },
    { name: state.name, url: canonical },
  ]),
];

// Only render Product schema when the state is actually purchasable.
if (isLive) {
  jsonLd.push(
    productSchema({
      url: canonical,
      name: `${state.name} Miller Trust Setup Kit`,
      description: state.metaDescription,
      price: state.price,
      stateAbbreviation: state.abbreviation,
      inStock: true,
      // Product images — cover-page screenshot first (literally the
      // product), per-state OG card second. Both absolute URLs.
      images: [
        `https://millertrustguide.com/kit-previews/${state.slug}/01-cover.png`,
        `https://millertrustguide.com/og/states/${state.slug}.png`,
      ],
    })
  );
  jsonLd.push(
    howToSchema({
      url: canonical,
      name: `How to set up a ${state.name} Miller Trust (Qualified Income Trust)`,
      description: `Step-by-step procedure for setting up a ${state.name} Medicaid Qualified Income Trust using the official ${state.agencyAbbreviation} template.`,
      totalTime: 'PT3H',
      estimatedCost: { value: state.price, currency: 'USD' },
      steps: [
        {
          name: `Download the official ${state.agencyAbbreviation} QIT template`,
          text: `Visit ${state.agencyAbbreviation}'s published template page and download the most current version.`,
          url: state.officialTemplateUrl,
        },
        {
          name: 'Fill in the obvious data fields',
          text: 'Enter the applicant name, trustee name, and listed income sources per the state-published instructions.',
        },
        {
          name: 'Sign the trust',
          text: 'Execute the signed trust in the same calendar month you intend to fund it.',
        },
        {
          name: 'Open a bank account in the name of the trust',
          text: `Open the account using the applicant's Social Security number${state.einRequired ? ' or the trust EIN where required' : ''}. ${state.agencyAbbreviation} allows the small opening deposit banks typically require to open a new account. Use the kit's bank-refusal script and printed ${state.agencyAbbreviation} policy section to handle first-attempt refusals.`,
        },
        {
          name: 'Redirect income sources to the trust account',
          text: 'Submit direct-deposit redirect requests for each listed income source.',
        },
        {
          name: 'Submit the Medicaid application',
          text: 'File the LTC Medicaid application; coverage begins the month the QIT is funded.',
        },
      ],
    })
  );
}
---

<BaseLayout
  title={state.metaTitle}
  description={state.metaDescription}
  canonical={canonical}
  jsonLd={jsonLd}
  ogType="article"
  ogImage={`https://millertrustguide.com/og/states/${state.slug}.png`}
  ogImageAlt={`${state.name} Miller Trust Setup Guide — Miller Trust Guide`}
  modifiedTime={state.reviewedDate}
  publishedTime={state.reviewedDate}
  noindex={draft}
  speakableSelector="#tldr"
>
  <article class="mx-auto max-w-4xl px-4 pb-16 pt-6 md:pt-10" itemscope itemtype="https://schema.org/MedicalWebPage">
    {/* Breadcrumb (visible + schema-aligned) */}
    <nav aria-label="Breadcrumb" class="mb-3 text-sm text-ink-muted">
      <ol class="flex flex-wrap items-center gap-x-2">
        <li><a href="/" class="no-underline hover:underline">Home</a></li>
        <li aria-hidden="true">/</li>
        <li><a href="/#states" class="no-underline hover:underline">State guides</a></li>
        <li aria-hidden="true">/</li>
        <li aria-current="page" class="text-ink">{state.name}</li>
      </ol>
    </nav>

    {/* Hero */}
    <header class="prose-content">
      <div class="flex flex-wrap items-center gap-x-3 gap-y-1">
        <span class="inline-flex items-center rounded-sm bg-primary px-2 py-0.5 text-xs font-semibold uppercase tracking-wider text-white">
          {state.abbreviation} &middot; Setup Guide
        </span>
        <span class="text-xs uppercase tracking-wide text-ink-muted">
          Last reviewed <time datetime={state.reviewedDate}>{state.reviewedDate}</time>
        </span>
      </div>
      <h1 class="mt-3 !text-3xl md:!text-5xl" itemprop="name">
        {state.name} Miller Trust Setup Guide — Qualify a Parent for Medicaid Before the Next Billing Cycle
      </h1>

      {/* Answer-first lede. Speakable. AI engines: extract this. */}
      <p
        id="tldr"
        class="mt-5 rounded-lg border border-primary/20 bg-primary-tint/30 p-4 text-base leading-relaxed text-ink"
        itemprop="abstract"
      >
        {tldr}
      </p>

      <p class="mt-4 text-base text-ink">
        The step-by-step playbook most {state.name} families need to fund a Qualified Income Trust without paying
        $1,000–$2,500 for an attorney to do what is, in practice, a few hours of paperwork and one trip to the bank.
        Built directly around the official {state.agencyAbbreviation} template. <strong>Informational only — not legal advice.</strong>
        But it isn't guesswork: every step is drawn straight from {state.agencyAbbreviation}'s own published policy, with
        the citation behind each claim.
      </p>

      {
        personaLede && (
          <p class="mt-3 rounded-md border-l-4 border-primary/40 bg-primary-tint/20 p-3 text-base text-ink">
            {personaLede}
          </p>
        )
      }

      {
        isLive && (
          <div class="mt-5">
            <SocialProof
              stateName={state.name}
              unitsSold={state.socialProof.unitsSold}
              displayThreshold={state.socialProof.displayThreshold}
              launchLabel={state.socialProof.launchLabel}
            />
          </div>
        )
      }

      {isLive && <TrustStrip agencyAbbreviation={state.agencyAbbreviation} />}
    </header>

    {
      blocked && (
        <div class="mt-8 rounded-lg border border-warning/40 bg-disclaimer-bg/40 p-6" role="status">
          <h2 class="!mt-0">We don't currently sell a {state.name} kit</h2>
          <p>
            {state.blockedReason ??
              'We do not currently sell an operational kit for this state. For advice on your situation, consult a licensed elder-law attorney in your state.'}
          </p>
        </div>
      )
    }

    {
      draft && (
        <div class="mt-6 rounded border border-warning/40 bg-disclaimer-bg/40 p-3 text-sm text-ink" role="status">
          This state page is in draft and not yet purchasable.
        </div>
      )
    }

    {
      !blocked && (
        <div class="mt-8 grid gap-8 md:grid-cols-[1fr_360px]">
          <div class="prose-content">
            {/* Delay-cost anchor (DEMOGRAPHICS lever #1) */}
            <div class="rounded-lg border-l-4 border-primary bg-primary-tint/30 p-5">
              <p class="!mt-0 text-base">
                <strong>Why this can't wait:</strong> {state.name} private-pay nursing care runs
                <strong> ${fmt(state.privatePayMonthlyLow)}–${fmt(state.privatePayMonthlyHigh)} a month.</strong>{' '}
                Medicaid coverage begins the calendar month the QIT is signed <em>and</em> funded — there is no
                back-dating. A 30-day delay is a five-figure check your family writes out of pocket.
              </p>
            </div>

            <h2>What's in the {state.name} kit</h2>
            <p class="!mt-0 text-sm font-medium text-ink-muted">
              10 operational sections and 3 reference appendices. Here are the six pieces buyers tell
              other buyers made the difference:
            </p>
            <ul>
              <li>
                <strong>The bank-refusal playbook.</strong> The single thing buyers tell other buyers about. Most
                {' '}{state.name} branches have never opened a Miller Trust account and refuse on first request.
                The kit includes a verbatim script citing {state.policyManualSection}, the five most common refusals
                and how to respond to each, and a one-page resolution letter you can hand to the branch manager.
              </li>
              <li>
                <strong>The {state.commonDenialReasons.length} {state.agencyAbbreviation} denial traps and how to
                avoid each one.</strong> Every trap cites the exact {state.agencyAbbreviation} policy section behind it,
                so you can verify before you submit — not after the denial letter arrives.
              </li>
              <li>
                <strong>A pre-filled monthly funding worksheet</strong> using the {state.asOf} income cap of
                ${fmt(state.incomeCap2026)} so you know exactly how much income to redirect each month.
              </li>
              <li>
                <strong>The direct link to the official {state.agencyAbbreviation} .gov template</strong> and a
                plain-English walkthrough of every field you fill in yourself.
              </li>
              <li>
                <strong>The "what to say to family" page</strong> — short script for when a sibling asks why you didn't
                just hire an attorney. Pre-empts the family-conflict fight before it starts.
              </li>
              <li>
                <strong>The month-by-month income redirect checklist</strong> for after the account opens, so the trust
                stays compliant every month and Medicaid never has a reason to pull benefits.
              </li>
            </ul>

            {/* T5 — own the "isn't the form free?" objection head-on, right after
                the manifest. The honest two-number framing IS our moat. */}
            <div class="rounded-lg border-l-4 border-primary bg-primary-tint/20 p-5">
              <p class="!my-0 text-base">
                <strong>"Isn't the QIT form free from {state.agencyAbbreviation}?"</strong> It is — and the kit links
                you straight to it, at no charge. You're not paying for the form. You're paying for the part that
                actually trips families up: the same-calendar-month funding rule, the word-for-word bank-refusal
                script, and the {state.commonDenialReasons.length} {state.agencyAbbreviation} denial traps with the
                policy citation behind each. The form is a couple of pages; getting it accepted is where a month of
                coverage gets lost.
              </p>
            </div>

            <div class="rounded-lg border border-border bg-surface-elevated p-4 text-sm">
              <p class="!mt-0">
                <strong>If your spouse is the one entering care:</strong> this kit covers the Qualified Income Trust
                — the income side of qualifying. If you're the spouse staying at home (the "community spouse"), the
                kit walks you through the trust itself and Section&nbsp;9 orients you on the separate
                resource-allowance rules that protect your home and savings — but those rules are fact-specific, and
                for them you'll likely also want a {state.name} elder-law attorney. The kit tells you exactly what to
                bring to that meeting — the trust you've already set up, the resource questions to ask, and the
                documents to have ready — so you're paying the attorney to answer your specific questions, not to
                explain the basics.
              </p>
            </div>

            <h2>The {state.asOf} {state.name} income cap</h2>
            <p>
              Setting up a Miller Trust in {state.name} starts with one number — the income cap.
              The {state.name} {state.asOf} Medicaid long-term-care income limit is{' '}
              <strong>${fmt(state.incomeCap2026)}/month</strong> for a single applicant. If your family member's
              countable monthly income exceeds this limit, a properly drafted, signed, and funded QIT diverts the excess
              and brings countable income below the cap. The applicant's Personal Needs Allowance in {state.name} is{' '}
              <strong>${fmt(state.personalNeedsAllowance)}/month</strong>. Source:{' '}
              <a href={state.policyManualUrl} rel="external nofollow">{state.agencyAbbreviation} {state.policyManualSection}</a>.
            </p>

            {
              articleLinks.length > 0 && (
                <>
                  <h2>Step-by-step {state.name} guides</h2>
                  <p>
                    Free operational walkthroughs that go deeper on the questions families ask most before they buy:
                  </p>
                  <ul>
                    {articleLinks.map((a) => (
                      <li>
                        <a href={a.path}>{a.h1}</a>
                      </li>
                    ))}
                  </ul>
                </>
              )
            }
          </div>

          {/* Sticky buy panel on desktop */}
          <aside class="md:sticky md:top-24 md:self-start" id="primary-buy-panel">
            <div class="overflow-hidden rounded-lg border border-border bg-surface-elevated shadow-sm">
              <div class="h-1 bg-primary" aria-hidden="true"></div>
              <div class="p-6">
                <p class="text-xs font-semibold uppercase tracking-wider text-primary">{state.name} Kit</p>
                {
                  founderActive ? (
                    <>
                      <p class="mt-2 flex items-baseline gap-2">
                        <span class="text-4xl font-bold text-ink-heading" aria-label={`${FOUNDER.price} dollars founder price`}>
                          ${FOUNDER.price}
                        </span>
                        <span class="text-lg text-ink-muted line-through" aria-label={`regular price ${state.price} dollars`}>
                          ${state.price}
                        </span>
                      </p>
                      <p class="mt-1 text-sm font-medium text-primary">
                        Founding price — only <span data-founder-spots>{founderSpotsLeft}</span> <span data-founder-spot-word>{founderSpotsLeft === 1 ? 'spot' : 'spots'}</span> left at this rate.
                      </p>
                    </>
                  ) : (
                    <p class="mt-2 text-4xl font-bold text-ink-heading">
                      <span aria-label={`${state.price} dollars`}>${state.price}</span>
                    </p>
                  )
                }
                <p class="mt-2 text-sm text-ink">
                  Less than one hour of an elder-law attorney's time — and it covers the whole Qualified
                  Income Trust setup.
                </p>
                <p class="mt-1 text-sm text-ink-muted">
                  Instant download &middot; Money-back if {state.agencyAbbreviation} rejects
                </p>
                <div class="mt-5">
                  <ConsentBuyButton stateSlug={state.slug} price={displayPrice} />
                </div>
                {/* Guarantee at the decision point — the #1 de-risker for a
                    $-purchase from a new publisher, surfaced next to the button
                    rather than only further down the page. */}
                <div class="mt-4 flex items-start gap-2 rounded-md border border-primary/20 bg-primary-tint/30 p-3">
                  <svg aria-hidden="true" viewBox="0 0 24 24" class="mt-0.5 h-4 w-4 flex-shrink-0 text-primary" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M9 12l2 2 4-4" stroke-linecap="round" stroke-linejoin="round" />
                    <circle cx="12" cy="12" r="10" />
                  </svg>
                  <p class="!my-0 text-xs leading-relaxed text-ink">
                    <strong>If {state.agencyAbbreviation} rejects the trust, you pay nothing.</strong> Full refund
                    within one business day — no forms, no phone tag.
                  </p>
                </div>
                {/* T11 — risk reversal at the decision point: let the buyer see
                    real pages before paying. Jumps to the PdfPreview gallery. */}
                <p class="mt-4 text-center text-sm">
                  <a href="#preview-heading" class="font-medium text-primary">See real sample pages from the kit &rarr;</a>
                </p>
              </div>
            </div>
          </aside>
        </div>
      )
    }

    {!blocked && <PdfPreview stateSlug={state.slug} />}

    {/* Brand-level proof stack — real, permissioned buyers, THIS state's own
        first, each labeled with its TRUE state badge (Gary's quote shown here
        reads "Verified buyer of the New Jersey Kit", never a false same-state
        claim). Renders only when at least one is switched on (config off by
        default). Sits right after the product preview: strongest spot for a voice. */}
    {proofTestimonials.length > 0 && (
      <section class="mx-auto max-w-3xl px-4 py-8" aria-labelledby="proof-heading">
        <h2 id="proof-heading">What early buyers say</h2>
        <p class="mt-2 text-sm text-ink-muted">
          Real buyers, in their own words. We only publish verified customers who gave permission — no invented
          reviews, no stock quotes.
        </p>
        <div class:list={['mt-5 grid gap-6', proofTestimonials.length > 1 && 'md:grid-cols-2']}>
          {proofTestimonials.map(({ testimonial, stateName }) => (
            <Testimonial testimonial={testimonial} stateName={stateName} compact />
          ))}
        </div>
      </section>
    )}

    {!blocked && (
      <ComparisonTable
        stateName={state.name}
        price={displayPrice}
        privatePayMonthlyLow={state.privatePayMonthlyLow}
        privatePayMonthlyHigh={state.privatePayMonthlyHigh}
      />
    )}

    {/* Bank-refusal teaser (the moat) */}
    {
      !blocked && (
        <section class="prose-content my-12" aria-labelledby="bank-heading">
          <p class="text-xs font-semibold uppercase tracking-wider text-primary">The bank step</p>
          <h2 id="bank-heading" class="!mt-1">The bank refusal nobody warns you about</h2>
          <p>
            You walk into your branch with the signed trust. The teller calls a manager. The manager has never seen one.
            They ask for an EIN. They tell you to come back with an attorney. You drive home with an empty trust account
            and a Medicaid clock ticking.
          </p>
          <p>
            This is the single most common reason {state.name} families lose a month of benefits, and it has nothing to
            do with the trust itself — it is a bank-procedure problem. The kit's bank section gives you the exact
            language to cite at the counter, the {state.agencyAbbreviation} policy reference to read aloud, and a
            printable resolution letter you can hand to the branch manager so they can escalate inside their own bank
            instead of sending you away.
          </p>
          <p class="text-sm font-medium text-ink-muted">Refusals the kit walks you through:</p>
          <ul>
            {state.bankRefusalNotes.map((note) => (
              <li>
                <strong>{note.refusalType}.</strong>
              </li>
            ))}
          </ul>
          <p class="text-sm text-ink-muted">
            Each refusal has a corresponding response in the kit, with the {state.agencyAbbreviation} citation behind it.
          </p>
          {/* T15 — one oddly-specific, credibility-signaling insider tip (the
              "blue-ink" move), drawn straight from the kit's bank section. */}
          <div class="not-prose rounded-md border-l-4 border-primary bg-primary-tint/20 p-4 text-sm">
            <p class="!my-0">
              <strong>The thing that saves a second trip:</strong> bring the printed {state.agencyAbbreviation} policy
              page to the counter — not just the signed trust. A teller who can read the rule in black and white
              escalates in minutes; one who only has your word for it sends you home. The kit tells you exactly which
              page to print and hand across.
            </p>
          </div>
        </section>
      )
    }

    {!blocked && <ReassuranceBlock stateAgencyAbbreviation={state.agencyAbbreviation} />}

    {!blocked && <MoneyBackGuarantee stateAgencyAbbreviation={state.agencyAbbreviation} />}

    {/* Common denial reasons */}
    {
      !blocked && (
        <section class="prose-content my-12" aria-labelledby="denials-heading">
          <p class="text-xs font-semibold uppercase tracking-wider text-primary">Avoid these</p>
          <h2 id="denials-heading" class="!mt-1">
            The {state.commonDenialReasons.length} most common {state.name} denial reasons
          </h2>
          <p>
            Every denial reason below cites {state.agencyAbbreviation} policy. The full kit explains how to avoid each
            and the order in which to verify them before submitting the Medicaid application.
          </p>
          <ol>
            {state.commonDenialReasons.map((r) => (
              <li>
                <strong>{r.title}.</strong> {r.description}{' '}
                <span class="text-sm text-ink-muted">— {r.agencyCitation}</span>
              </li>
            ))}
          </ol>
        </section>
      )
    }

    {/* Emotional-peak inline capture — placed right after the bank-refusal +
        denial-reasons fear content, where the not-ready-to-buy reader is most
        motivated to take the free checklist. */}
    {
      isLive && (
        <InlineLeadCapture
          stateSlug={state.slug}
          stateName={state.name}
          agencyAbbreviation={state.agencyAbbreviation}
        />
      )
    }

    {/* About the kit author */}
    <section class="prose-content my-12" aria-labelledby="author-heading">
      <p class="text-xs font-semibold uppercase tracking-wider text-primary">The author</p>
      <h2 id="author-heading" class="!mt-1">Why I wrote this</h2>
      <p>
        I'm <a href="/authors/james-whitfield" rel="author">James Whitfield</a>. I built this site after spending weeks
        helping a family member through a Miller Trust setup. The free state PDF told us what fields to fill in and
        stopped there. The first attorney we called quoted $2,200. The second wanted $1,500 and a six-week wait.
        The bank refused to open the account twice. Between the policy manual, the bank counter, and the Medicaid
        application window, there was a real gap — and that gap is what this kit fills.
      </p>
      <p>
        I'm not an attorney. I'm a researcher who has now read every {state.agencyAbbreviation} policy section that
        covers Qualified Income Trusts. I publish what I learned, with citations on every claim. I won't advise you
        on your specific situation; for that, you need a {state.name}-licensed attorney.
      </p>
    </section>

    {/* FAQ */}
    {
      !blocked && (
        <section class="prose-content my-12" aria-labelledby="faq-heading">
          <p class="text-xs font-semibold uppercase tracking-wider text-primary">Questions</p>
          <h2 id="faq-heading" class="!mt-1">Frequently asked questions</h2>
          <dl>
            {allFaq.map((f) => {
              const { lead, rest } = firstSentence(f.answer);
              return (
                <div class="mt-6">
                  <dt class="faq-question font-semibold text-ink-heading">{f.question}</dt>
                  <dd class="faq-answer mt-1">
                    <span class="faq-answer__lead">{lead}</span>
                    {rest && <> {rest}</>}
                  </dd>
                </div>
              );
            })}
          </dl>
        </section>
      )
    }

    {/* State agency citations panel */}
    <section class="prose-content my-12" aria-labelledby="sources-heading">
      <p class="text-xs font-semibold uppercase tracking-wider text-primary">Primary sources</p>
      <h2 id="sources-heading" class="!mt-1">State agency sources</h2>
      <p>
        Every operational claim in this kit cites a primary {state.agencyAbbreviation} document. Verify directly:
      </p>
      <ul>
        <li>
          <strong>Official template:</strong>{' '}
          <a href={state.officialTemplateUrl} rel="external nofollow noopener">
            {state.agencyAbbreviation} — {state.policyManualSection}
          </a>
          . {state.officialTemplateNote}
        </li>
        <li>
          <strong>Policy manual:</strong>{' '}
          <a href={state.policyManualUrl} rel="external nofollow noopener">
            {state.agencyAbbreviation} policy manual
          </a>{' '}
          (section {state.policyManualSection}).
        </li>
        {state.supplementalOfficialDocs.map((doc) => (
          <li>
            <strong>{doc.label}:</strong>{' '}
            <a href={doc.url} rel="external nofollow noopener">
              {state.agencyAbbreviation} — {doc.label}
            </a>
            . {doc.note}
          </li>
        ))}
      </ul>
    </section>

    {/* Email capture — recovers the not-ready-today visitor */}
    {
      isLive && (
        <LeadMagnetForm
          stateSlug={state.slug}
          heading={`Not ready to buy? Get the free ${state.name} denial-trap checklist.`}
          blurb={`One page: the ${state.name} denial traps with the ${state.agencyAbbreviation} citation behind each — plus a few short, plain-English emails on the funding-month rule, the bank step, and the traps. No sales pressure. Unsubscribe anytime.`}
        />
      )
    }

    {/* Buy CTA repeat */}
    {
      !blocked && (
        <section
          class="prose-content my-12 rounded-lg border border-border bg-surface-elevated p-6"
          aria-labelledby="cta-heading"
        >
          <h2 id="cta-heading" class="!mt-0">Ready to start?</h2>
          <p>
            {founderActive ? (
              <>
                <strong>${FOUNDER.price} founding price</strong> (<span data-founder-spots>{founderSpotsLeft}</span> <span data-founder-spot-word>{founderSpotsLeft === 1 ? 'spot' : 'spots'}</span> left at this rate), then ${state.price}.
              </>
            ) : (
              <>${state.price}.</>
            )}{' '}
            Instant download. Money-back if {state.agencyAbbreviation} rejects your QIT for any reason traceable to
            following the kit.
          </p>
          <p class="text-sm text-ink-muted">
            No waiting room, no six-week retainer. Most {state.name} families have the trust signed, the account open,
            and the first month's income redirected within a week — fast enough to catch the next eligibility month.
          </p>
          <div class="mt-6">
            <ConsentBuyButton
              stateSlug={state.slug}
              price={displayPrice}
              buttonLabel={`Get the ${state.name} kit — $${displayPrice}`}
            />
          </div>
        </section>
      )
    }
  </article>
  {
    isLive && (
      <StickyBuyBar
        stateName={state.name}
        price={displayPrice}
        agencyAbbreviation={state.agencyAbbreviation}
      />
    )
  }

  {/* Interruptive capture surfaces — engagement slide-in (all devices) and
      desktop exit-intent. They share ONE prompt budget: a visitor sees at most
      one pop, ever, and never after subscribing (see src/lib/lead-capture.ts). */}
  {
    isLive && (
      <>
        <LeadCaptureSlideIn
          stateSlug={state.slug}
          stateName={state.name}
          agencyAbbreviation={state.agencyAbbreviation}
        />
        <ExitIntentModal
          stateSlug={state.slug}
          stateName={state.name}
          agencyAbbreviation={state.agencyAbbreviation}
        />
      </>
    )
  }
  <FounderLive />
</BaseLayout>
