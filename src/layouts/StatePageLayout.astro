---
import BaseLayout from '~/layouts/BaseLayout.astro';
import ConsentBuyButton from '~/components/ConsentBuyButton.astro';
import ComparisonTable from '~/components/ComparisonTable.astro';
import ReassuranceBlock from '~/components/ReassuranceBlock.astro';
import MoneyBackGuarantee from '~/components/MoneyBackGuarantee.astro';
import PdfPreview from '~/components/PdfPreview.astro';
import StickyBuyBar from '~/components/StickyBuyBar.astro';
import {
  articleSchema,
  faqPageSchema,
  breadcrumbSchema,
  medicalWebPageSchema,
  governmentServiceSchema,
  productSchema,
  howToSchema,
} from '~/lib/schema';
import type { StateData } from '~/content/config';

interface Props {
  state: StateData;
}

const { state } = Astro.props;

const canonical = `https://millertrustguide.com/states/${state.slug}`;
const isLive = state.status === 'live';
const blocked = state.status === 'blocked';
const draft = state.status === 'draft';

const fmt = (n: number) => n.toLocaleString('en-US');

// GEO/AI-citation lede. First ~80 words must directly answer the primary
// query — Princeton GEO + 2026 AI Overview research both prioritize
// answer-first content. We mark this passage as speakable so voice/AI
// assistants can lift it verbatim.
const tldr = blocked
  ? `Miller Trust Guide does not currently publish a kit for ${state.name}. ${state.blockedReason ?? 'For advice on your situation, consult a licensed elder-law attorney in your state.'}`
  : `A ${state.name} Miller Trust (Qualified Income Trust) is an irrevocable trust used to qualify a Medicaid applicant whose monthly income exceeds the ${state.name} long-term-care income cap of $${fmt(state.incomeCap2026)} per month (${state.asOf}). The trust must be drafted, signed, and funded in the same calendar month using the official ${state.agencyAbbreviation} template (${state.policyManualSection}). Medicaid eligibility begins the month the trust is funded — there is no retroactive effect, and every month of delay is another month of full private-pay nursing-home cost ($${fmt(state.privatePayMonthlyLow)}–$${fmt(state.privatePayMonthlyHigh)}/mo in ${state.name}). This guide is the step-by-step operational walkthrough most families need: $${state.price}, instant download, money-back if ${state.agencyAbbreviation} rejects the QIT for a reason traceable to following the kit.`;

// Authoritative citations used in this article — feeds the Article@citation
// JSON-LD array (2026 entity-binding signal).
const citationUrls = [state.officialTemplateUrl, state.policyManualUrl];

const jsonLd: object[] = [
  articleSchema({
    headline: state.metaTitle,
    description: state.metaDescription,
    url: canonical,
    dateModified: state.reviewedDate,
    lastReviewed: state.reviewedDate,
    reviewedBy: null, // anonymity doctrine; replace when a credentialed reviewer is wired in
    speakableCssSelectors: ['#tldr', '.faq-question', '.faq-answer'],
    citations: citationUrls,
  }),
  medicalWebPageSchema({
    url: canonical,
    name: state.metaTitle,
    description: state.metaDescription,
    dateModified: state.reviewedDate,
    lastReviewed: state.reviewedDate,
    reviewedBy: null,
    audience: 'Patient',
  }),
  governmentServiceSchema({
    url: canonical,
    stateName: state.name,
    agencyName: state.agencyName,
    policyManualUrl: state.policyManualUrl,
  }),
  faqPageSchema(state.faq),
  breadcrumbSchema([
    { name: 'Home', url: 'https://millertrustguide.com/' },
    { name: 'State Guides', url: 'https://millertrustguide.com/#states' },
    { name: state.name, url: canonical },
  ]),
];

// Only render Product schema when the state is actually purchasable.
if (isLive) {
  jsonLd.push(
    productSchema({
      url: canonical,
      name: `${state.name} Miller Trust Setup Kit`,
      description: state.metaDescription,
      price: state.price,
      stateAbbreviation: state.abbreviation,
      inStock: true,
    })
  );
  jsonLd.push(
    howToSchema({
      url: canonical,
      name: `How to set up a ${state.name} Miller Trust (Qualified Income Trust)`,
      description: `Step-by-step procedure for setting up a ${state.name} Medicaid Qualified Income Trust using the official ${state.agencyAbbreviation} template.`,
      totalTime: 'PT3H',
      estimatedCost: { value: state.price, currency: 'USD' },
      steps: [
        {
          name: `Download the official ${state.agencyAbbreviation} QIT template`,
          text: `Visit ${state.agencyAbbreviation}'s published template page and download the most current version.`,
          url: state.officialTemplateUrl,
        },
        {
          name: 'Fill in the obvious data fields',
          text: 'Enter the applicant name, trustee name, and listed income sources per the state-published instructions.',
        },
        {
          name: 'Sign the trust',
          text: 'Execute the signed trust in the same calendar month you intend to fund it.',
        },
        {
          name: 'Open a zero-balance bank account in the name of the trust',
          text: `Use the bank-refusal script and printed ${state.agencyAbbreviation} policy section to handle first-attempt refusals.`,
        },
        {
          name: 'Redirect income sources to the trust account',
          text: 'Submit direct-deposit redirect requests for each listed income source.',
        },
        {
          name: 'Submit the Medicaid application',
          text: 'File the LTC Medicaid application; coverage begins the month the QIT is funded.',
        },
      ],
    })
  );
}
---

<BaseLayout
  title={state.metaTitle}
  description={state.metaDescription}
  canonical={canonical}
  jsonLd={jsonLd}
  ogType="article"
  ogImage={`https://millertrustguide.com/og/states/${state.slug}.png`}
  ogImageAlt={`${state.name} Miller Trust Setup Guide — Miller Trust Guide`}
  modifiedTime={state.reviewedDate}
  publishedTime={state.reviewedDate}
  noindex={draft}
  speakableSelector="#tldr"
>
  <article class="mx-auto max-w-4xl px-4 pb-16 pt-6 md:pt-10" itemscope itemtype="https://schema.org/MedicalWebPage">
    {/* Breadcrumb (visible + schema-aligned) */}
    <nav aria-label="Breadcrumb" class="mb-3 text-sm text-ink-muted">
      <ol class="flex flex-wrap items-center gap-x-2">
        <li><a href="/" class="no-underline hover:underline">Home</a></li>
        <li aria-hidden="true">/</li>
        <li><a href="/#states" class="no-underline hover:underline">State guides</a></li>
        <li aria-hidden="true">/</li>
        <li aria-current="page" class="text-ink">{state.name}</li>
      </ol>
    </nav>

    {/* Hero */}
    <header class="prose-content">
      <div class="flex flex-wrap items-center gap-x-3 gap-y-1">
        <span class="inline-flex items-center rounded-sm bg-primary px-2 py-0.5 text-xs font-semibold uppercase tracking-wider text-white">
          {state.abbreviation} &middot; Setup Guide
        </span>
        <span class="text-xs uppercase tracking-wide text-ink-muted">
          Last reviewed <time datetime={state.reviewedDate}>{state.reviewedDate}</time>
        </span>
      </div>
      <h1 class="mt-3 !text-3xl md:!text-5xl" itemprop="name">
        {state.name} Miller Trust Setup Guide — Qualify a Parent for Medicaid Before the Next Billing Cycle
      </h1>

      {/* Answer-first lede. Speakable. AI engines: extract this. */}
      <p
        id="tldr"
        class="mt-5 rounded-lg border border-primary/20 bg-primary-tint/30 p-4 text-base leading-relaxed text-ink"
        itemprop="abstract"
      >
        {tldr}
      </p>

      <p class="mt-4 text-base text-ink">
        The step-by-step playbook most {state.name} families need to fund a Qualified Income Trust without paying
        $1,000–$2,500 for an attorney to do what is, in practice, a few hours of paperwork and one trip to the bank.
        Built directly around the official {state.agencyAbbreviation} template. <strong>Informational only — not legal advice.</strong>
      </p>
    </header>

    {
      blocked && (
        <div class="mt-8 rounded-lg border border-warning/40 bg-disclaimer-bg/40 p-6" role="status">
          <h2 class="!mt-0">We don't currently sell a {state.name} kit</h2>
          <p>
            {state.blockedReason ??
              'We do not currently sell an operational kit for this state. For advice on your situation, consult a licensed elder-law attorney in your state.'}
          </p>
        </div>
      )
    }

    {
      draft && (
        <div class="mt-6 rounded border border-warning/40 bg-disclaimer-bg/40 p-3 text-sm text-ink" role="status">
          This state page is in draft and not yet purchasable.
        </div>
      )
    }

    {
      !blocked && (
        <div class="mt-8 grid gap-8 md:grid-cols-[1fr_360px]">
          <div class="prose-content">
            {/* Delay-cost anchor (DEMOGRAPHICS lever #1) */}
            <div class="rounded-lg border-l-4 border-primary bg-primary-tint/30 p-5">
              <p class="!mt-0 text-base">
                <strong>Why this can't wait:</strong> {state.name} private-pay nursing care runs
                <strong> ${fmt(state.privatePayMonthlyLow)}–${fmt(state.privatePayMonthlyHigh)} a month.</strong>{' '}
                Medicaid coverage begins the calendar month the QIT is signed <em>and</em> funded — there is no
                back-dating. A 30-day delay is a five-figure check your family writes out of pocket.
              </p>
            </div>

            <h2>What you get when you buy the kit</h2>
            <ul>
              <li>
                <strong>The bank-refusal playbook.</strong> The single thing buyers tell other buyers about. Most
                {' '}{state.name} branches have never opened a Miller Trust account and refuse on first request.
                The kit includes a verbatim script citing {state.policyManualSection}, the five most common refusals
                and how to respond to each, and a one-page resolution letter you can hand to the branch manager.
              </li>
              <li>
                <strong>The {state.commonDenialReasons.length} {state.agencyAbbreviation} denial traps and how to
                avoid each one.</strong> Every trap cites the exact {state.agencyAbbreviation} policy section behind it,
                so you can verify before you submit — not after the denial letter arrives.
              </li>
              <li>
                <strong>A pre-filled monthly funding worksheet</strong> using the {state.asOf} income cap of
                ${fmt(state.incomeCap2026)} so you know exactly how much income to redirect each month.
              </li>
              <li>
                <strong>The direct link to the official {state.agencyAbbreviation} .gov template</strong> and a
                plain-English walkthrough of every field you fill in yourself.
              </li>
              <li>
                <strong>The "what to say to family" page</strong> — short script for when a sibling asks why you didn't
                just hire an attorney. Pre-empts the family-conflict fight before it starts.
              </li>
              <li>
                <strong>The month-by-month income redirect checklist</strong> for after the account opens, so the trust
                stays compliant every month and Medicaid never has a reason to pull benefits.
              </li>
            </ul>

            <h2>The {state.asOf} {state.name} income cap</h2>
            <p>
              The {state.name} {state.asOf} Medicaid long-term-care income limit is{' '}
              <strong>${fmt(state.incomeCap2026)}/month</strong> for a single applicant. If your family member's
              countable monthly income exceeds this limit, a properly drafted, signed, and funded QIT diverts the excess
              and brings countable income below the cap. The applicant's Personal Needs Allowance in {state.name} is{' '}
              <strong>${fmt(state.personalNeedsAllowance)}/month</strong>. Source:{' '}
              <a href={state.policyManualUrl} rel="external nofollow">{state.agencyAbbreviation} {state.policyManualSection}</a>.
            </p>
          </div>

          {/* Sticky buy panel on desktop */}
          <aside class="md:sticky md:top-24 md:self-start" id="primary-buy-panel">
            <div class="overflow-hidden rounded-lg border border-border bg-surface-elevated shadow-sm">
              <div class="h-1 bg-primary" aria-hidden="true"></div>
              <div class="p-6">
                <p class="text-xs font-semibold uppercase tracking-wider text-primary">{state.name} Kit</p>
                <p class="mt-2 text-4xl font-bold text-ink-heading">
                  <span aria-label={`${state.price} dollars`}>${state.price}</span>
                </p>
                <p class="mt-1 text-sm text-ink-muted">
                  Instant download &middot; Money-back if {state.agencyAbbreviation} rejects
                </p>
                <div class="mt-5">
                  <ConsentBuyButton stateSlug={state.slug} price={state.price} />
                </div>
              </div>
            </div>
          </aside>
        </div>
      )
    }

    {!blocked && <PdfPreview />}

    {!blocked && <ComparisonTable stateName={state.name} price={state.price} />}

    {/* Bank-refusal teaser (the moat) */}
    {
      !blocked && (
        <section class="prose-content my-12" aria-labelledby="bank-heading">
          <p class="text-xs font-semibold uppercase tracking-wider text-primary">The bank step</p>
          <h2 id="bank-heading" class="!mt-1">The bank refusal nobody warns you about</h2>
          <p>
            You walk into your branch with the signed trust. The teller calls a manager. The manager has never seen one.
            They ask for an EIN. They tell you to come back with an attorney. You drive home with an empty trust account
            and a Medicaid clock ticking.
          </p>
          <p>
            This is the single most common reason {state.name} families lose a month of benefits, and it has nothing to
            do with the trust itself — it is a bank-procedure problem. The kit's bank section gives you the exact
            language to cite at the counter, the {state.agencyAbbreviation} policy reference to read aloud, and a
            printable resolution letter you can hand to the branch manager so they can escalate inside their own bank
            instead of sending you away.
          </p>
          <p class="text-sm font-medium text-ink-muted">Refusals the kit walks you through:</p>
          <ul>
            {state.bankRefusalNotes.map((note) => (
              <li>
                <strong>{note.refusalType}.</strong>
              </li>
            ))}
          </ul>
          <p class="text-sm text-ink-muted">
            Each refusal has a corresponding response in the kit, with the {state.agencyAbbreviation} citation behind it.
          </p>
        </section>
      )
    }

    {!blocked && <ReassuranceBlock stateAgencyAbbreviation={state.agencyAbbreviation} />}

    {!blocked && <MoneyBackGuarantee stateAgencyAbbreviation={state.agencyAbbreviation} />}

    {/* Common denial reasons */}
    {
      !blocked && (
        <section class="prose-content my-12" aria-labelledby="denials-heading">
          <p class="text-xs font-semibold uppercase tracking-wider text-primary">Avoid these</p>
          <h2 id="denials-heading" class="!mt-1">
            The {state.commonDenialReasons.length} most common {state.name} denial reasons
          </h2>
          <p>
            Every denial reason below cites {state.agencyAbbreviation} policy. The full kit explains how to avoid each
            and the order in which to verify them before submitting the Medicaid application.
          </p>
          <ol>
            {state.commonDenialReasons.map((r) => (
              <li>
                <strong>{r.title}.</strong> {r.description}{' '}
                <span class="text-sm text-ink-muted">— {r.agencyCitation}</span>
              </li>
            ))}
          </ol>
        </section>
      )
    }

    {/* About the kit author */}
    <section class="prose-content my-12" aria-labelledby="author-heading">
      <p class="text-xs font-semibold uppercase tracking-wider text-primary">The author</p>
      <h2 id="author-heading" class="!mt-1">Why I wrote this</h2>
      <p>
        I'm <a href="/authors/james-whitfield" rel="author">James Whitfield</a>. I built this site after spending weeks
        helping a family member through a Miller Trust setup. The free state PDF told us what fields to fill in and
        stopped there. The first attorney we called quoted $2,200. The second wanted $1,500 and a six-week wait.
        The bank refused to open the account twice. Between the policy manual, the bank counter, and the Medicaid
        application window, there was a real gap — and that gap is what this kit fills.
      </p>
      <p>
        I'm not an attorney. I'm a researcher who has now read every {state.agencyAbbreviation} policy section that
        covers Qualified Income Trusts. I publish what I learned. I will not advise you on your specific situation;
        for that, you need a {state.name}-licensed attorney. I work anonymously because the state agency manuals are
        the authority, not me.
      </p>
    </section>

    {/* FAQ */}
    {
      !blocked && (
        <section class="prose-content my-12" aria-labelledby="faq-heading">
          <p class="text-xs font-semibold uppercase tracking-wider text-primary">Questions</p>
          <h2 id="faq-heading" class="!mt-1">Frequently asked questions</h2>
          <dl>
            {state.faq.map((f) => (
              <div class="mt-6">
                <dt class="faq-question font-semibold text-ink-heading">{f.question}</dt>
                <dd class="faq-answer mt-1">{f.answer}</dd>
              </div>
            ))}
          </dl>
        </section>
      )
    }

    {/* State agency citations panel */}
    <section class="prose-content my-12" aria-labelledby="sources-heading">
      <p class="text-xs font-semibold uppercase tracking-wider text-primary">Primary sources</p>
      <h2 id="sources-heading" class="!mt-1">State agency sources</h2>
      <p>
        Every operational claim in this kit cites a primary {state.agencyAbbreviation} document. Verify directly:
      </p>
      <ul>
        <li>
          <strong>Official template:</strong>{' '}
          <a href={state.officialTemplateUrl} rel="external nofollow noopener">
            {state.agencyAbbreviation} — {state.policyManualSection}
          </a>
          . {state.officialTemplateNote}
        </li>
        <li>
          <strong>Policy manual:</strong>{' '}
          <a href={state.policyManualUrl} rel="external nofollow noopener">
            {state.agencyAbbreviation} policy manual
          </a>{' '}
          (section {state.policyManualSection}).
        </li>
      </ul>
    </section>

    {/* Buy CTA repeat */}
    {
      !blocked && (
        <section
          class="prose-content my-12 rounded-lg border border-border bg-surface-elevated p-6"
          aria-labelledby="cta-heading"
        >
          <h2 id="cta-heading" class="!mt-0">Ready to start?</h2>
          <p>
            ${state.price}. Instant download. Money-back if {state.agencyAbbreviation} rejects your QIT for any reason
            traceable to following the kit.
          </p>
          <div class="mt-6">
            <ConsentBuyButton
              stateSlug={state.slug}
              price={state.price}
              buttonLabel={`Get the ${state.name} kit — $${state.price}`}
            />
          </div>
        </section>
      )
    }
  </article>
  {
    isLive && (
      <StickyBuyBar
        stateName={state.name}
        price={state.price}
        agencyAbbreviation={state.agencyAbbreviation}
      />
    )
  }
</BaseLayout>
