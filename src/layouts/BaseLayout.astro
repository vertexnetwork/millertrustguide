---
import '~/styles/global.css';
import DisclaimerBanner from '~/components/DisclaimerBanner.astro';
import SiteHeader from '~/components/SiteHeader.astro';
import Footer from '~/components/Footer.astro';
import { organizationSchema, websiteSchema, personSchema } from '~/lib/schema';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  jsonLd?: object[];
  ogType?: 'website' | 'article' | 'product';
  ogImage?: string;
  ogImageAlt?: string;
  noindex?: boolean;
  // 2026 GEO addition: pages that want their answer-first lede marked as
  // speakable pass a CSS selector for the lede element.
  speakableSelector?: string;
  // Optional per-page article meta for og:article:* tags.
  publishedTime?: string;
  modifiedTime?: string;
}

const {
  title,
  description,
  canonical,
  jsonLd = [],
  ogType = 'website',
  ogImage,
  ogImageAlt,
  noindex = false,
  publishedTime,
  modifiedTime,
} = Astro.props;

const SITE_URL = 'https://millertrustguide.com';
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, SITE_URL).toString();
const ogImageUrl = ogImage ?? `${SITE_URL}/og-default.png`;
const ogImageAltText =
  ogImageAlt ?? 'Miller Trust Guide — state-specific operational guides for Medicaid Qualified Income Trusts.';

// Site-wide JSON-LD that must appear on every page: Organization + WebSite + author Person.
const ldBlocks = [organizationSchema(), websiteSchema(), personSchema(), ...jsonLd];
---

<!doctype html>
<html lang="en-US" dir="ltr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="color-scheme" content="light" />
    <meta name="theme-color" content="#115E59" />
    <meta name="format-detection" content="telephone=no" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="James Whitfield" />
    <meta name="publisher" content="Miller Trust Guide" />
    <meta name="generator" content="Astro" />

    {/* Robots: indexable by default; opt-out via noindex prop. AI snippets
       allowed by default so we appear in Google AI Overviews and SGE. */}
    <meta
      name="robots"
      content={noindex ? 'noindex,nofollow' : 'index,follow,max-snippet:-1,max-image-preview:large,max-video-preview:-1'}
    />
    <meta name="googlebot" content={noindex ? 'noindex,nofollow' : 'index,follow'} />

    <link rel="canonical" href={canonicalUrl} />

    {/* Open Graph */}
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Miller Trust Guide" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:alt" content={ogImageAltText} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
    {ogType === 'article' && <meta property="article:author" content="James Whitfield" />}
    {ogType === 'article' && <meta property="article:publisher" content="Miller Trust Guide" />}

    {/* X / Twitter card (we maintain no social account — these tags help
       link unfurls in DMs and shares without claiming an account). */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={ogImageAltText} />

    {/* Hreflang: single-language site; explicit x-default for clarity. */}
    <link rel="alternate" hreflang="en-US" href={canonicalUrl} />
    <link rel="alternate" hreflang="x-default" href={canonicalUrl} />

    {/* Icons + manifest + opensearch */}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" sizes="any" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" sizes="180x180" />
    <link rel="manifest" href="/site.webmanifest" />
    <link
      rel="search"
      type="application/opensearchdescription+xml"
      title="Miller Trust Guide"
      href="/opensearch.xml"
    />

    {/* Discoverability of LLM-friendly indexes (informational; not a spec
       requirement, but cheap and helps agentic tools find the index). */}
    <link rel="alternate" type="text/markdown" title="LLM-friendly site index" href="/llms.txt" />
    <link rel="alternate" type="text/markdown" title="LLM-friendly full index" href="/llms-full.txt" />

    {/* Fonts: rsms.me Inter; the body has Source Serif Pro fallback chain. */}
    <link rel="preconnect" href="https://rsms.me" crossorigin />
    <link rel="stylesheet" href="https://rsms.me/inter/inter.css" />

    {/* JSON-LD */}
    {
      ldBlocks.map((block) => (
        <script type="application/ld+json" set:html={JSON.stringify(block)} />
      ))
    }
  </head>
  <body class="flex min-h-screen flex-col">
    {/* Skip-to-content link (a11y heuristic #7 — user control + nav). */}
    <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:left-2 focus:top-2 focus:z-50 focus:rounded focus:bg-primary focus:px-3 focus:py-2 focus:text-white">
      Skip to content
    </a>
    <DisclaimerBanner />
    <SiteHeader />
    <main id="main" class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
