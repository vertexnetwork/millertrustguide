# ============================================================================
# Miller Trust Guide — env vars
# Copy this file to `.env` for local development.
# In Vercel, configure these under Project Settings → Environment Variables.
# ============================================================================

# Stripe (TEST keys for local dev; LIVE keys in Vercel production env only)
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
# Founder-pricing coupon ID. Create a coupon in Stripe (amount-off, USD,
# duration once, max_redemptions = founder limit). Checkout applies it
# automatically while valid; Stripe stops honoring it past the redemption
# limit. Leave blank to sell at full price with no founder discount.
STRIPE_FOUNDER_COUPON_ID=

# Resend — transactional email (kit delivery) + nurture series + audience.
# Send from a dedicated subdomain with DKIM/SPF/DMARC configured in Resend.
RESEND_API_KEY=re_replace_me
RESEND_FROM_ADDRESS=support@millertrustguide.com
RESEND_FROM_NAME="James Whitfield at Miller Trust Guide"
# Audience (contact list) ID for the nurture series — create it in the
# Resend dashboard, then paste its UUID here.
RESEND_AUDIENCE_ID=replace_me

# Operator alert inbox — the Stripe webhook emails here whenever a PAID order
# fails to deliver (e.g. kit PDF missing in Blob), so it can never fail
# silently. Defaults to RESEND_FROM_ADDRESS if unset. Use an inbox you watch.
OPERATOR_ALERT_EMAIL=support@millertrustguide.com

# Vercel Blob — kit PDF storage (token auto-injected when the Blob store is
# linked to the Vercel project; copy it here for local dev).
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_replace_me

# Download-token signing secret. Signs the time-limited /api/download links
# sent in kit-delivery emails. Generate a long random value, e.g.:
#   openssl rand -hex 32
# Keep this stable — rotating it invalidates every outstanding download link.
DOWNLOAD_TOKEN_SECRET=replace_me

# Cron secret — guards the nurture drip endpoint (/api/cron/nurture).
# Vercel auto-attaches this as a Bearer token on cron invocations when set.
# Generate with: openssl rand -hex 32
CRON_SECRET=replace_me

# Canonical site URL — used in Stripe Checkout success/cancel URLs
SITE_URL=https://millertrustguide.com

# ============================================================================
# B2B recurring-license tier (nursing-home subscriptions)
# ============================================================================

# Session/magic-link signing secret for the /business portal. SEPARATE from
# DOWNLOAD_TOKEN_SECRET so rotating B2B sessions never invalidates outstanding
# B2C download links. Generate with: openssl rand -hex 32
B2B_SESSION_SECRET=replace_me

# All-states bundle recurring Price IDs (for multi-state chains). Per-STATE B2B
# Price IDs live in each state's .mdx frontmatter (stripeB2BPriceMonthly /
# stripeB2BPriceAnnual), mirroring stripePriceId. Leave the bundle blank to
# hide the bundle option until you create those prices.
STRIPE_B2B_BUNDLE_MONTHLY=
STRIPE_B2B_BUNDLE_ANNUAL=

# Optional: a custom Stripe Customer Portal configuration ID. Leave blank to
# use the account's default portal configuration.
STRIPE_PORTAL_CONFIG_ID=

# Optional tunables (minutes). Defaults: session 60, magic link 15.
B2B_SESSION_TTL_MINUTES=60
B2B_MAGICLINK_TTL_MINUTES=15

# Vercel KV (Upstash Redis) — provisioned via Vercel → Storage → Marketplace →
# Upstash for Redis, then connected to this project (auto-injects these). Used
# ONLY for magic-link single-use nonces, login rate-limiting, and a short
# entitlement-status cache — NOT a customer database (Stripe is source of
# truth). If unset, the portal still works but links are not single-use and
# login is not rate-limited (a warning is logged).
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Google Ads conversion tracking (paid search — see docs/ad-campaign-playbook.md
# §0.5). Both are PUBLIC (they ship in page source; not secrets). Leave BLANK and
# the gtag + purchase conversion stay fully inert — nothing is injected.
# After setting these in Vercel you must REDEPLOY (PUBLIC_ vars inline at build).
#   PUBLIC_GOOGLE_ADS_ID            → the "AW-XXXXXXXXXX" conversion/account id
#   PUBLIC_GOOGLE_ADS_PURCHASE_LABEL→ the label after the slash in the event
#     snippet's send_to (e.g. from "AW-123/AbC-D_efG" the label is "AbC-D_efG")
PUBLIC_GOOGLE_ADS_ID=
PUBLIC_GOOGLE_ADS_PURCHASE_LABEL=
