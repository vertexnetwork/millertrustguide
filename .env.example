# ============================================================================
# Miller Trust Guide — env vars
# Copy this file to `.env` for local development.
# In Vercel, configure these under Project Settings → Environment Variables.
# ============================================================================

# Stripe (TEST keys for local dev; LIVE keys in Vercel production env only)
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
# Founder-pricing coupon ID. Create a coupon in Stripe (amount-off, USD,
# duration once, max_redemptions = founder limit). Checkout applies it
# automatically while valid; Stripe stops honoring it past the redemption
# limit. Leave blank to sell at full price with no founder discount.
STRIPE_FOUNDER_COUPON_ID=

# Resend — transactional email (kit delivery) + nurture series + audience.
# Send from a dedicated subdomain with DKIM/SPF/DMARC configured in Resend.
RESEND_API_KEY=re_replace_me
RESEND_FROM_ADDRESS=support@millertrustguide.com
RESEND_FROM_NAME="James Whitfield at Miller Trust Guide"
# Audience (contact list) ID for the nurture series — create it in the
# Resend dashboard, then paste its UUID here.
RESEND_AUDIENCE_ID=replace_me

# Vercel Blob — kit PDF storage (token auto-injected when the Blob store is
# linked to the Vercel project; copy it here for local dev).
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_replace_me

# Download-token signing secret. Signs the time-limited /api/download links
# sent in kit-delivery emails. Generate a long random value, e.g.:
#   openssl rand -hex 32
# Keep this stable — rotating it invalidates every outstanding download link.
DOWNLOAD_TOKEN_SECRET=replace_me

# Cron secret — guards the nurture drip endpoint (/api/cron/nurture).
# Vercel auto-attaches this as a Bearer token on cron invocations when set.
# Generate with: openssl rand -hex 32
CRON_SECRET=replace_me

# Canonical site URL — used in Stripe Checkout success/cancel URLs
SITE_URL=https://millertrustguide.com
